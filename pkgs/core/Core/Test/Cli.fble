
Bool@ = /Std/Bool%.Bool@;

Output@ = /Std/Char/Output%.Output@;
Put@ = /Core/Char/Stream%.Put@;

List@ = /Std/List%.List@;

Monad@ = /Std/Monad%.Monad@;
Io@ = /Std/Io%.Io@;

Main@ = /Std/Io/Cli%.Main@;
Success = /Std/Io/Cli%.Success;
Failure = /Std/Io/Cli%.Failure;

String@ = /Std/String%.String@;
Str = /Std/Char/Ascii%.Str;

Test@ = /Std/Test%.Test@;

# Run --
#   A cli program to run a set of tests.
#
# Inputs:
#   tests - the tests to run.
#
# Result:
#   A cli Main@ program to run the tests.
(Test@) { Main@; } Run = (Test@ tests) {
  <<@>@ M@>(Monad@<M@> m, Io@<M@> io, List@<String@> args) {
    String@ prefix = {
      args.?(empty: Str|'');
      /Std/String/Eq%.Eq(Str|'--prefix', args.items.head).?(false: Str|'');
      args.items.tail.items.head;
    };

    Put@<M@, Output@> out := m.do(/Core/Stdio/FFI%.Text.Stdout(m, io));
    Bool@ passed := m.do(/Core/Test/Run%.Run(m, out, prefix, tests));
    m.return(passed.?(true: Success, false: Failure));
  };
};

@(Run);
