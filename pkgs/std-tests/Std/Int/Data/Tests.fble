
Ascii@, Str, OnAscii .= /Std/Char/Ascii%;
AssertEquals .= /Std/Eq/Assert%;
Int@, Neg .= /Std/Int%;
Int .= /Std/Int/Lit%;
Lazy@, Lazy .= /Std/Lazy%;
List@, Empty, Items, Reverse .= /Std/List%;
ToList .= /Std/Stream/List%;
Test@, TestResult@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@, Unit .= /Std/Unit%;

(List@<Ascii@>, Lazy@<TestResult@>) { TestResult@; }
ExpectFails = (List@<Ascii@> msg, Lazy@<TestResult@> result) {
  /Std/Test%.ExpectFails(Str(msg), result(Unit));
};

Test@ Tests = TestSuite|Data[
  Test|Order({
    # Test that the data implementation for Int@ puts integers in the order
    # you expect.
    Unit@ _ := Lazy;
    Set@, Set, ForEach .= /Std/Set%.Of(/Std/Int/Data%.Data);
    List@<Int@> ints = ToList(/Std/Int/Stream%.Range(Neg(Int|5), Int|6));
    Set@ set = Set(ints);
    List@<Int@> wnt = ints;
    List@<Int@> got = Reverse(ForEach(set, Empty<Int@>, Items<Int@>));

    # TODO: Fix the implementation of Data@<Int@>.
    Unit@ _ := ExpectFails|'but got [-1, -2, -4, -3, -5, 0, 1, 2, 4, 3, 5]';
    AssertEquals(
      /Std/List/Eq%.Eq(/Std/Int/Eq%.Eq),
      /Std/List/Show%.Show(/Std/Int/Show%.Show), wnt, got);
  })
];

@(Tests);
