
@ Bool@ = /Std/Bool%.Bool@;

<@>@ List@ = /Std/List%.List@;

<@>@ Output@ = /Std/Char/Output%.Output@;
% ToString = /Std/Char/Output%.ToString;

@ String@ = /Std/String%.String@;

% String = /Std/Char/Ascii/Output%.String;
% Format = /Std/Char/Ascii/Output%.Format;

@ Unit@ = /Std/Unit%.Unit@;
% Unit = /Std/Unit%.Unit;

@ TestResult@ = +(Unit@ pass, Output@ fail, Unit@ expected_fail, Output@ skip);
@ TestCase@ = *(String@ name, (Unit@) { TestResult@; } test);
@ TestSuite@ = *(String@ name, List@<Test@> tests),
@ Test@ = +(TestCase@ case, TestSuite@ suite);

# A passing test result.
TestResult@ Pass = TestResult@(pass: Unit);

# A failing test result.
(Output@) { TestResult@; } Fail = (Output@ msg) {
  TestResult@(fail: msg);
};

# ExpectFails --
#   Change the test result to expected failure if the given test result is
#   failing and msg is contained somewhere in the failure message.
(String@, TestResult@) { TestResult@; }
ExpectFails = (String@ msg, TestResult@ result) {
  result.?(pass: Fail(String|'Expected failure, but test passed'));
  result.?(expected_fail: Fail(String|'Expected failure, but was expected_fail'));
  result.?(skip: Fail(String|'Expected failure, but was skip'));

  String@ failure = ToString(result.fail);
  /Std/String/Eq%.Contains(failure, msg).?(true: TestResult@(expected_fail: Unit));

  Fail(Format|'Expected failure containing "%s", but failed with "%s"'
        [/Std/Char/Output%.String(msg), /Std/Char/Output%.String(failure)]);
};

# Skip --
#   A skipped test result.
(Output@) { TestResult@; }
Skip = (Output@ msg) {
  TestResult@(skip: msg);
};

# Test --
#   Creates an individual test.
#
# Inputs:
#   name - the name of the test
#   test - a function that returns the result of the test
(String@, (Unit@) { TestResult@; }) { Test@; }
Test = (String@ name, (Unit@) { TestResult@; } test) {
  Test@(case: TestCase@(name, test));
};

# TestSuite --
#   Creates a suite of tests.
#
# Inputs:
#   name - the name of the test suite.
#   tests - the list of tests in the test suite.
(String@, List@<Test@>) { Test@; }
TestSuite = (String@ name, List@<Test@> tests) {
  Test@(suite: TestSuite@(name, tests));
};

(Output@, Test@) { Test@; }
SkipTest = (Output@ msg, Test@ test) {
  test.?(case: Test(test.case.name, (Unit@ _) { Skip(msg); }));
  TestSuite(test.suite.name, /Std/List%.Map(test.suite.tests, SkipTest(msg)));
};

(Bool@, Output@, Test@) { Test@; }
SkipTestIf = (Bool@ if, Output@ msg) {
  if.?(true: SkipTest(msg), false: /Std/Func%.Id<Test@>);
};

(Bool@, Output@, Test@) { Test@; }
SkipTestUnless = (Bool@ unless, Output@ msg) {
  unless.?(true: /Std/Func%.Id<Test@>, false: SkipTest(msg));
};

@(TestResult@, Test@, TestSuite@, TestCase@,
  Pass, Fail, ExpectFails, Skip,
  Test, TestSuite,
  SkipTest, SkipTestIf, SkipTestUnless
);
