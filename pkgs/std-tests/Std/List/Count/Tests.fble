
OnAscii .= /Std/Char/Ascii%;
AssertEquals .= /Std/Eq/Assert%;
Int@ .= /Std/Int%;
Int .= /Std/Int/Lit%;
Lazy .= /Std/Lazy%;
Count = /Std/List/Count%.Count;
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

Elem, Elems, Eq .= /Std/List/Tests/Elem%;

Test@ Tests = TestSuite|Count[
  Test|Count({
    Unit@ _ := Lazy;
    Int@ wnt = Int|5;
    Int@ got = Count(Elems|ABCBBAABCEB, Eq(Elem.B));
    AssertEquals(/Std/Int/Eq%.Eq, /Std/Int/Show%.Show, wnt, got);
  })
];

@(Tests);
