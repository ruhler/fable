
<@>% AssertEquals = /Core/Eq/Assert%.AssertEquals;

@ Int@ = /Std/Int%.Int@;
% Decr = /Std/Int%.Decr;
% IsZero = /Std/Int/Sign%.IsZero;
% Int = /Std/Int/Lit%.Int;

<@>% List = /Std/List%.List;

% Str = /Std/Char/Ascii%.Str;

@ Test@ = /Core/Test%.Test@;
% Test = /Core/Test%.Test;
% TestSuite = /Core/Test%.TestSuite;

@ Unit@ = /Std/Unit%.Unit@;

<@>% Entries = /Computrainer/Grid%.Entries;

% Car = /Computrainer/Car%;
@ Car@ = Car.Car@;
@ Cars@ = Car.Cars@;

@ Model@ = /Computrainer/Model%.Model@;
% Tick = /Computrainer/Model%.Tick;

(Int@, Model@) { Model@; }
TickN = (Int@ n, Model@ m) {
    IsZero(n).?(true: m);
    TickN(Decr(n), Tick(m));
};

