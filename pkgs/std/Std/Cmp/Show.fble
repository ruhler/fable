# @module[/Std/Cmp/Show%]
#  The Show@ instance for Compared@.

String .= /Std/Char/Ascii/Output%;
Compared@ .= /Std/Cmp%;
Show@ .= /Std/Show%;

# @value[Show] Show@ instance for Compared@.
#  @type[Show@<Compared@>]
Show@<Compared@>
Show = (Compared@ a) {
  a.?(less: String|Less, equal: String|Equal, greater: String|Greater);
};

@(Show);
