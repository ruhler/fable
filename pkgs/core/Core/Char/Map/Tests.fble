
Test@ = /Std/Test%.Test@;

Char@ = /Std/Char%.Char@;
Char = /Std/Char/Ascii%.Char;

# Note: Iteration order isn't quite what you expect.
Test@ Tests = /Core/Map/Test%.Test</Core/Char/Map%.Map.Map@, Char@>(
  /Core/Char/Map%.Map, /Std/Char/Eq%.Eq, /Std/Char/Show%.Show, 
  Char|B, Char|A, Char|C);

@(Tests);
