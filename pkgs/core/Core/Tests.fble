
List = /Std/List%.List;

Str = /Std/Char/Ascii%.Str;

Test@ = /Std/Test%.Test@;
TestSuite = /Std/Test%.TestSuite;

Test@ Tests = TestSuite(Str|Core, List[
  /Core/Debug/Tests%.Tests,
  /Core/Random/Lcg/Tests%.Tests,
  /Core/Random/Lfsr/Tests%.Tests,
  /Core/Map/Tests%.Tests,
  /Core/Set/Tests%.Tests,
  /Core/String/Tests%.Tests,
  /Core/Test/Tests%.Tests
]);

/Std/Test/Cli%.Run(Tests);
