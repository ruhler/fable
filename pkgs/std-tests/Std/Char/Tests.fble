
Char@, Char, Pos .= /Std/Char%;
OnAscii .= /Std/Char/Ascii%;
AssertEquals .= /Std/Eq/Assert%;
Int .= /Std/Int/Lit%;
Lazy .= /Std/Lazy%;
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

Char@ A = /Std/Char/Ascii%.Char|A;

Test@ Tests = TestSuite|Char[
  Test|Char({
    Unit@ _ := Lazy;
    AssertEquals(/Std/Char/Eq%.Eq, /Std/Char/Show%.Show, A, Char(Int|65));
  }),

  Test|Pos({
    Unit@ _ := Lazy;
    AssertEquals(/Std/Int/Eq%.Eq, /Std/Int/Show%.Show, Int|65, Pos(A));
  }),

  /Std/Char/Ascii/Tests%.Tests,
  /Std/Char/Lit/Tests%.Tests,
  /Std/Char/Show/Tests%.Tests
];

@(Tests);
