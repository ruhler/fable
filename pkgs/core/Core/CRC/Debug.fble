
% True = /Std/Bool%.True;

@ CRC@ = /Core/CRC%.CRC@;
% Feed = /Core/CRC%.Feed;

@ Bit@ = /Core/Digits%.Bit@;
% Bit = /Core/Digits%.Bit;

% HexToBits = /Core/Digits/String%.HexToBits;

% ShowBits = /Core/Digits/Show%.ShowBits;

<@>@ List@ = /Std/List%.List@;
<@>% Items = /Std/List%.Items;

@ String@ = /Std/String%.String@;

<<@>@>@ Monad@ = /Core/Monad%.Monad@;

<<@>@>@ Stdio@ = /Core/Stdio%.Stdio@;
<<@>@>@ Main@ = /Core/Stdio%.Main@;

@ Unit@ = /Std/Unit%.Unit@;


Main@ Debug = <<@>@ M@>(Stdio@<M@> stdio, Monad@<M@> m) {
  % O = /Core/Stream/OStream%(m);
  
  (List@<String@> _args) {
    (CRC@, List@<Bit@>) { M@<CRC@>; } DFeeds = (CRC@ crc, List@<Bit@> bits) {
      bits.?(empty: m.return(crc));

      CRC@ ncrc = Feed(crc, bits.items.head);
      Unit@ _ <- m.do(O.PutLine(stdio.out, ShowBits(ncrc.checksum)));
      DFeeds(ncrc, bits.items.tail);
    };

    List@<Bit@> poly = Items(Bit.1, HexToBits|04C11DB7);
    List@<Bit@> init = HexToBits|00000000;
    CRC@ crc = CRC@(poly, init);
    CRC@ _result <- m.do(DFeeds(crc, HexToBits|31323334353637383900000000));

    m.return(True);
  };
};

/Core/Stdio/IO%.Run(Debug);
