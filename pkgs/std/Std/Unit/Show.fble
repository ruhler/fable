# @module[/Std/Unit/Show%]
#  The Show@ instance for Unit@.

String .= /Std/Char/Ascii/Stream%;
Show@ .= /Std/Show%;
Unit@ .= /Std/Unit%;

# @func[Show] Show a Unit@ value.
#  @arg[Unit@][x] The value to show.
#  @returns[Stream@] Output that shows the value.
Show@<Unit@> Show = (Unit@ _) {
  String|Unit;
};

@(Show);
