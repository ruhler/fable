
Int@ = /Std/Int%.Int@;
Hex = /Std/Int/Lit%.Hex;

List = /Std/List%.List;

Prng@ = /Std/Random/Prng%.Prng@;
Rand48 = /Std/Random/Lcg%.Rand48;

Str = /Std/Char/Ascii%.Str;

Test@ = /Std/Test%.Test@;
TestSuite = /Std/Test%.TestSuite;
Test = /Std/Test%.Test;

AssertSequence = /Std/Random/Prng/Assert%.AssertSequence;

Unit@ = /Std/Unit%.Unit@;

Test@ Tests = TestSuite(Str|Lcg, List[
  Test(Str|Rand48, (Unit@ _) {
    Prng@<Int@> prng = Rand48;
    AssertSequence(
      /Std/Int/Eq%.Eq, /Std/Int/Show%.Show, prng)[
        Hex|000000000000,
        Hex|00000000000B,
        Hex|0040942dE6BA,
        Hex|0AA8544E593D,
        Hex|2D3873C4Cd04,
        Hex|5D5692ACE2Bf,
        Hex|17617168255E,
        Hex|17A0D1925D11];
  })
]);

@(Tests);
