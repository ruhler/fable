
Ascii@, OnAscii .= /Std/Char/Ascii%;
Int@, Neg .= /Std/Int%;
Int .= /Std/Int/Lit%;
List@ .= /Std/List%;
AssertStream = OnAscii(/Std/Stream/String/Assert%.AssertStream);
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

(List@<Ascii@>, List@<Ascii@>, Int@) { Test@; }
TestShow = (List@<Ascii@> name, List@<Ascii@> expected, Int@ value) {
  Test(name, (Unit@ _) { AssertStream(expected, /Std/Int/Show%.Show(value)); });
};

Test@ Tests = TestSuite|'Show'[
  TestShow|P|1029384756(Int|1029384756),
  TestShow|N|'-1029384756'(Neg(Int|1029384756)),
  TestShow|0|0(Int|0)
];

@(Tests);
