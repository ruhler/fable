
% True = /Std/Bool%.True;
% False = /Std/Bool%.False;

<@>@ Eq@ = /Std/Eq%.Eq@;

@ Compared@ = /Std/Cmp%.Compared@;

Eq@<Compared@> Eq = (Compared@ a, Compared@ b) {
  a.?(
    less: b.?(less: True, : False),
    equal: b.?(equal: True, : False),
    greater: b.?(greater: True, : False));
};

@(Eq);
