
OnAscii .= /Std/Char/Ascii%;
AssertEquals .= /Std/Eq/Assert%;
Lazy .= /Std/Lazy%;
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

Neg, Int .= /Pinball/Num%;
Rotate .= /Pinball/Rotate%;
Vec@ .= /Pinball/Vec%;

Test@ Tests = TestSuite|Rotate[
  Test|'Unrotated Q1'({
    # Rotation a vector by an angle of 0 should not change the vector.
    Unit@ _ := Lazy;
    Vec@ v = Vec@(Int|2, Int|3);
    Vec@ want = v;
    Vec@ got = Rotate(v, Int|0);
    AssertEquals(/Pinball/Vec%.Eq, /Pinball/Vec%.Show, want, got);
  }),

  Test|'Unrotated Q2'({
    # Rotation a vector by an angle of 0 should not change the vector.
    Unit@ _ := Lazy;
    Vec@ v = Vec@(Neg(Int|2), Int|3);
    Vec@ want = v;
    Vec@ got = Rotate(v, Int|0);
    AssertEquals(/Pinball/Vec%.Eq, /Pinball/Vec%.Show, want, got);
  }),

  Test|'Unrotated Q3'({
    # Rotation a vector by an angle of 0 should not change the vector.
    Unit@ _ := Lazy;
    Vec@ v = Vec@(Neg(Int|2), Neg(Int|3));
    Vec@ want = v;
    Vec@ got = Rotate(v, Int|0);
    AssertEquals(/Pinball/Vec%.Eq, /Pinball/Vec%.Show, want, got);
  }),

  Test|'Unrotated Q4'({
    # Rotation a vector by an angle of 0 should not change the vector.
    Unit@ _ := Lazy;
    Vec@ v = Vec@(Int|2, Neg(Int|3));
    Vec@ want = v;
    Vec@ got = Rotate(v, Int|0);
    AssertEquals(/Pinball/Vec%.Eq, /Pinball/Vec%.Show, want, got);
  })
];

@(Tests);
