
Data@, 0, 1 .= /Core/Data%;
Int@ .= /Std/Int%;
Do, Put .= /Core/Stream%;
Unit@ .= /Std/Unit%;

Data@<Int@> Data = (Int@ x) {
  x.?(
    n: {
      Unit@ _ := Do(Put(0));
      Unit@ _ := Do(Put(0));
      /Core/Int/IntP/Data%.Data(x.n);
    }, 
    0: {
      Unit@ _ := Do(Put(0));
      Put(1);
    },
    p: {
      Unit@ _ := Do(Put(1));
      /Core/Int/IntP/Data%.Data(x.p);
    });
};

@(Data);

