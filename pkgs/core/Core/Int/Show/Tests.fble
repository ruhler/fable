
<@>% AssertEquals = /Core/Eq/Assert%.AssertEquals;

<@>% List = /Std/List%.List;

% ToString = /Std/Char/Output%.ToString;

@ String@ = /Std/String%.String@;
% Str = /Std/Char/Ascii%.Str;

@ Test@ = /Core/Test%.Test@;
% Test = /Core/Test%.Test;
% TestSuite = /Core/Test%.TestSuite;

@ Unit@ = /Std/Unit%.Unit@;

@ Int@ = /Std/Int%.Int@;
% Neg = /Std/Int%.Neg;
% Int = /Std/Int/Lit%.Int;

% Read = /Core/Int/Read%.Read;
% Show = /Core/Int/Show%.Show;

Test@ Tests = TestSuite(Str|Show, List[
  Test(Str|Read_Positive, (Unit@ _) {
    Int@ wnt = Int|49113;
    Int@ got = Read(Str|49113);
    AssertEquals(/Std/Int/Eq%.Eq, Show, wnt, got);
  }),

  Test(Str|Read_Negative, (Unit@ _) {
    Int@ wnt = Neg(Int|49113);
    Int@ got = Read(Str|'-49113');
    AssertEquals(/Std/Int/Eq%.Eq, Show, wnt, got);
  }),

  Test(Str|Read_AllDigits, (Unit@ _) {
    Int@ wnt = Int|1234567890;
    Int@ got = Read(Str|1234567890);
    AssertEquals(/Std/Int/Eq%.Eq, Show, wnt, got);
  }),

  Test(Str|Read_empty, (Unit@ _) {
    Int@ wnt = Int|0;
    Int@ got = Read(Str|'');
    AssertEquals(/Std/Int/Eq%.Eq, Show, wnt, got);
  }),

  Test(Str|Show_Positive, (Unit@ _) {
    String@ wnt = Str|'10325487960';
    String@ got = ToString(Show(Int|10325487960));
    AssertEquals(/Std/String/Eq%.Eq, /Core/String/Show%.Show, wnt, got);
  }),

  Test(Str|Show_Zero, (Unit@ _) {
    String@ wnt = Str|'0';
    String@ got = ToString(Show(Int|0));
    AssertEquals(/Std/String/Eq%.Eq, /Core/String/Show%.Show, wnt, got);
  }),

  Test(Str|Show_Negative, (Unit@ _) {
    String@ wnt = Str|'-42';
    String@ got = ToString(Show(Neg(Int|42)));
    AssertEquals(/Std/String/Eq%.Eq, /Core/String/Show%.Show, wnt, got);
  }),

  Test(Str|Show_AllDigits, (Unit@ _) {
    String@ wnt = Str|'1234567890';
    String@ got = ToString(Show(Int|1234567890));
    AssertEquals(/Std/String/Eq%.Eq, /Core/String/Show%.Show, wnt, got);
  })
]);

@(Tests);
