
<<@>@>@ Monad@ = /Std/Monad%.Monad@;

# Standard interface for a random number generator.
# Randomly chooses 1 of two values to return.
<<@>@>@ Rng@ = <<@>@ M@> { *(
  <@ A@>(A@, A@) { M@<A@>; } choose
); };

# Monadic interface for generating random numbers.
<<@>@>@ RngM@ = <<@>@ M@> { *(
  @<M@> M@,
  Monad@<M@> m,
  Rng@<M@> r
); };

@(Rng@, RngM@);

