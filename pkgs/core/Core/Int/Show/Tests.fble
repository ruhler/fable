
<@>% AssertEquals = /Std/Eq/Assert%.AssertEquals;

<@>% List = /Std/List%.List;

% Str = /Std/Char/Ascii%.Str;

@ Test@ = /Std/Test%.Test@;
% Test = /Std/Test%.Test;
% TestSuite = /Std/Test%.TestSuite;

@ Unit@ = /Std/Unit%.Unit@;

@ Int@ = /Std/Int%.Int@;
% Neg = /Std/Int%.Neg;
% Int = /Std/Int/Lit%.Int;

% Read = /Core/Int/Read%.Read;
% Show = /Std/Int/Show%.Show;

Test@ Tests = TestSuite(Str|Show, List[
  Test(Str|Read_Positive, (Unit@ _) {
    Int@ wnt = Int|49113;
    Int@ got = Read(Str|49113);
    AssertEquals(/Std/Int/Eq%.Eq, Show, wnt, got);
  }),

  Test(Str|Read_Negative, (Unit@ _) {
    Int@ wnt = Neg(Int|49113);
    Int@ got = Read(Str|'-49113');
    AssertEquals(/Std/Int/Eq%.Eq, Show, wnt, got);
  }),

  Test(Str|Read_AllDigits, (Unit@ _) {
    Int@ wnt = Int|1234567890;
    Int@ got = Read(Str|1234567890);
    AssertEquals(/Std/Int/Eq%.Eq, Show, wnt, got);
  }),

  Test(Str|Read_empty, (Unit@ _) {
    Int@ wnt = Int|0;
    Int@ got = Read(Str|'');
    AssertEquals(/Std/Int/Eq%.Eq, Show, wnt, got);
  })
]);

@(Tests);
