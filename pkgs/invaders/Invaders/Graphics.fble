# String --
#   Draw a string of letters.
(String@) { Drawing@; } String = {
  Map@, Value@, Key, Get .= /Std/Map%.Of(/Std/Char/Data%.Data)<Drawing@>;
  Entries .= /Std/Map/List%.Of(Key)<Value@>;
  Map@ letters = Entries[
    @(key: Char|0, value: Digit0),
    @(key: Char|1, value: Digit1),
    @(key: Char|2, value: Digit2),
    @(key: Char|3, value: Digit3),
    @(key: Char|4, value: Digit4),
    @(key: Char|5, value: Digit5),
    @(key: Char|6, value: Digit6),
    @(key: Char|7, value: Digit7),
    @(key: Char|8, value: Digit8),
    @(key: Char|9, value: Digit9),

    @(key: Char|A, value: LetterA),
    @(key: Char|C, value: LetterC),
    @(key: Char|E, value: LetterE),
    @(key: Char|G, value: LetterG),
    @(key: Char|H, value: LetterH),
    @(key: Char|I, value: LetterI),
    @(key: Char|L, value: LetterL),
    @(key: Char|M, value: LetterM),
    @(key: Char|O, value: LetterO),
    @(key: Char|R, value: LetterR),
    @(key: Char|S, value: LetterS),
    @(key: Char|V, value: LetterV)
  ];
 
  (String@ str) {
    str.?(empty: Blank);
    Char@ c = str.items.head;
    Drawing@ first = Default(Blank, Get(letters, c));
    Over(first, Translate(Int|8, Int|0, String(str.items.tail)));
  };
};

