
<@>@ Eq@ = /Std/Eq%.Eq@;

<@>@ Show@ = /Core/Show%.Show@;

% Format = /Core/Char/Ascii/Output%.Format;

@ TestResult@ = /Core/Test%.TestResult@;
% Pass = /Core/Test%.Pass;
% Fail = /Core/Test%.Fail;

<@ T@>(Eq@<T@>, Show@<T@>, T@, T@) { TestResult@; }
AssertEquals = <@ T@>(Eq@<T@> eq, Show@<T@> show, T@ a, T@ b) {
  eq(a, b).?(true: Pass);
  Fail(Format|'%s != %s'[show(a), show(b)]);
};

<@ T@>(Eq@<T@>, Show@<T@>, T@, T@) { TestResult@; }
AssertNotEquals = <@ T@>(Eq@<T@> eq, Show@<T@> show, T@ a, T@ b) {
  eq(a, b).?(false: Pass);
  Fail(Format|'%s == %s'[show(a), show(b)]);
};

@(AssertEquals, AssertNotEquals);
