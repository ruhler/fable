
@ Bool@ = /Std/Bool%.Bool@;
% True = /Std/Bool%.True;
% False = /Std/Bool%.False;

<@>% AssertEquals = /Std/Eq/Assert%.AssertEquals;
<@>% AssertNotEquals = /Std/Eq/Assert%.AssertNotEquals;

% Str = /Std/Char/Ascii%.Str;

@ Test@ = /Std/Test%.Test@;
% Test = /Std/Test%.Test;
% TestSuite = /Std/Test%.TestSuite;

@ Unit@ = /Std/Unit%.Unit@;

<@>@ List@ = /Std/List%.List@;
<@>% List = /Std/List%.List;

<@>% HasItems = /Std/List/Eq%.HasItems;
<@>% IsEmpty = /Std/List/Eq%.IsEmpty;
<@>% StartsWith = /Std/List/Eq%.StartsWith;
<@>% EndsWith = /Std/List/Eq%.EndsWith;
<@>% Contains = /Std/List/Eq%.Contains;
<@>% Skip = /Std/List/Eq%.Skip;
<@>% Trim = /Std/List/Eq%.Trim;
<@>% Strip = /Std/List/Eq%.Strip;
<@>% Search = /Std/List/Eq%.Search;
<@>% SearchR = /Std/List/Eq%.SearchR;
<@>% Until = /Std/List/Eq%.Until;
<@>% Break = /Std/List/Eq%.Break;
<@>% Split = /Std/List/Eq%.Split;
<@>% Replace = /Std/List/Eq%.Replace;

@ Elem@ = /Core/List/Tests/Elem%.Elem@;
% Eq = /Core/List/Tests/Elem%.Eq;
% Show = /Core/List/Tests/Elem%.Show;
% EL = /Core/List/Tests/Elem%.EL;
% ElemEq = /Core/List/Tests/Elem%.ElemEq;

Test@ Tests = TestSuite(Str|Eq, List[
  Test(Str|'Same', (Unit@ _) {
    List@<Elem@> a = EL|ABCDE;
    List@<Elem@> b = EL|ABCDE;

    AssertEquals(Eq, Show, a, b);
  }),

  Test(Str|'DiffElem', (Unit@ _) {
    List@<Elem@> a = EL|ABCDE;
    List@<Elem@> b = EL|ABDDE;

    AssertNotEquals(Eq, Show, a, b);
  }),

  Test(Str|'DiffSize', (Unit@ _) {
    List@<Elem@> a = EL|ABCDE;
    List@<Elem@> b = EL|ABCD;

    AssertNotEquals(Eq, Show, a, b);
  }),

  Test(Str|HasItems_yes, (Unit@ _) {
    List@<Elem@> list = EL|'ABBCCDDE';
    Bool@ got = HasItems(list);
    Bool@ wnt = True;
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|HasItems_no, (Unit@ _) {
    List@<Elem@> list = EL|'';
    Bool@ got = HasItems(list);
    Bool@ wnt = False;
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|IsEmpty_yes, (Unit@ _) {
    List@<Elem@> list = EL|'';
    Bool@ got = IsEmpty(list);
    Bool@ wnt = True;
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|IsEmpty_no, (Unit@ _) {
    List@<Elem@> list = EL|'ABBCCDDE';
    Bool@ got = IsEmpty(list);
    Bool@ wnt = False;
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|StartsWith, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'ABBC';
    Bool@ got = StartsWith(ElemEq, haystack, needle);
    Bool@ wnt = True;
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|StartsWith_Mismatch, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'ABC';
    Bool@ got = StartsWith(ElemEq, haystack, needle);
    Bool@ wnt = False;
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|StartsWith_EndOfString, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBC';
    List@<Elem@> needle = EL|'ABBCD';
    Bool@ got = StartsWith(ElemEq, haystack, needle);
    Bool@ wnt = False;
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|EndsWith, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'CDDE';
    Bool@ got = EndsWith(ElemEq, haystack, needle);
    Bool@ wnt = True;
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|EndsWith_Mismatch, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'CDD';
    Bool@ got = EndsWith(ElemEq, haystack, needle);
    Bool@ wnt = False;
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|EndsWith_EndOfString, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBC';
    List@<Elem@> needle = EL|'ABBCD';
    Bool@ got = EndsWith(ElemEq, haystack, needle);
    Bool@ wnt = False;
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|Contains, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'BCCD';
    Bool@ got = Contains(ElemEq, haystack, needle);
    Bool@ wnt = True;
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|Contains_mismatch, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'DCCB';
    Bool@ got = Contains(ElemEq, haystack, needle);
    Bool@ wnt = False;
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|Skip, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'ABBC';
    List@<Elem@> got = Skip(ElemEq, haystack, needle);
    List@<Elem@> wnt = EL|'CDDE';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Skip_mismatch, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'ABCD';
    List@<Elem@> got = Skip(ElemEq, haystack, needle);
    List@<Elem@> wnt = haystack;
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Trim, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'CDDE';
    List@<Elem@> got = Trim(ElemEq, haystack, needle);
    List@<Elem@> wnt = EL|'ABBC';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Trim_mismatch, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'EDDC';
    List@<Elem@> got = Trim(ElemEq, haystack, needle);
    List@<Elem@> wnt = haystack;
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Strip, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDEABBC';
    List@<Elem@> needle = EL|'ABBC';
    List@<Elem@> got = Strip(ElemEq, haystack, needle);
    List@<Elem@> wnt = EL|'CDDE';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Strip_mismatch, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'EDDC';
    List@<Elem@> got = Strip(ElemEq, haystack, needle);
    List@<Elem@> wnt = haystack;
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Strip_overlap, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABABA';
    List@<Elem@> needle = EL|'ABA';
    List@<Elem@> got = Strip(ElemEq, haystack, needle);
    List@<Elem@> wnt = EL|'BA';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Search_found, (Unit@ _) {
    List@<Elem@> list = EL|'ABCADBADE';
    List@<Elem@> got = Search(ElemEq, list, EL|'AD');
    List@<Elem@> wnt = EL|'ADBADE';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Search_not_found, (Unit@ _) {
    List@<Elem@> list = EL|'ABCADBE';
    List@<Elem@> got = Search(ElemEq, list, EL|'AC');
    List@<Elem@> wnt = EL|'';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|SearchR_found, (Unit@ _) {
    List@<Elem@> list = EL|'ABCADBADE';
    List@<Elem@> got = SearchR(ElemEq, list, EL|'AD');
    List@<Elem@> wnt = EL|'ADE';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|SearchR_notfound, (Unit@ _) {
    List@<Elem@> list = EL|'ABCADBADE';
    List@<Elem@> got = SearchR(ElemEq, list, EL|'AC');
    List@<Elem@> wnt = EL|'';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|SearchR_empty, (Unit@ _) {
    List@<Elem@> list = EL|'ABCADBADE';
    List@<Elem@> got = SearchR(ElemEq, list, EL|'');
    List@<Elem@> wnt = EL|'';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Until, (Unit@ _) {
    List@<Elem@> list = EL|'ABCADBADE';
    List@<Elem@> got = Until(ElemEq, list, EL|'AD');
    List@<Elem@> wnt = EL|'ABC';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Until_not_found, (Unit@ _) {
    List@<Elem@> list = EL|'ABCADBADE';
    List@<Elem@> got = Until(ElemEq, list, EL|'AC');
    List@<Elem@> wnt = EL|'ABCADBADE';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Break_span, (Unit@ _) {
    List@<Elem@> list = EL|'ABCADBE';
    List@<Elem@> got = Break(ElemEq, list, EL|'AD').span;
    List@<Elem@> wnt = EL|'ABC';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Break_tail, (Unit@ _) {
    List@<Elem@> list = EL|'ABCADBE';
    List@<Elem@> got = Break(ElemEq, list, EL|'AD').tail;
    List@<Elem@> wnt = EL|'ADBE';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|'Split', (Unit@ _) {
    List@<Elem@> list = EL|'ABCDEBCABC';
    List@<Elem@> delim = EL|'BC';
    List@<List@<Elem@>> wnt = List[EL|'A', EL|'DE', EL|'A', EL|''];
    List@<List@<Elem@>> got = Split(ElemEq, list, delim);
    AssertEquals(
      /Std/List/Eq%.Eq(Eq),
      /Std/List/Show%.Show(Show),
      wnt, got);
  }),

  Test(Str|'Replace', (Unit@ _) {
    List@<Elem@> list = EL|'ABCDEBCABC';
    List@<Elem@> delim = EL|'BC';
    List@<Elem@> target = EL|'EA';
    List@<Elem@> wnt = EL|'AEADEEAAEA';
    List@<Elem@> got = Replace(ElemEq, list, delim, target);
    AssertEquals(Eq, Show, wnt, got);
  })
]);

@(Tests);
