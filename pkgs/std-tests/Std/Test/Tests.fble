
Bool@, True, False .= /Std/Bool%;
Char@ .= /Std/Char%;
OnAscii, Str .= /Std/Char/Ascii%;
String .= /Std/Char/Ascii/Stream%;
Stream@, Out@ .= /Std/Stream%;
AssertEquals .= /Std/Eq/Assert%;
Lazy .= /Std/Lazy%;
Test@, Pass, Fail, ExpectFails, Skip .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@, Unit .= /Std/Unit%;

# Run a test with the test runner, for testing purposes.
# Returns whether the test passed or failed.
(Test@) { Bool@; }
Run = (Test@ test) {
  M@ = <@ A@> { A@; };
  return = <@ A@>(A@ x) { x; };
  do = <@ A@>(M@<A@> ma)<@ B@>((A@) { M@<B@>; } f) { f(ma); };
  Out@<Char@, M@> out = (Stream@<Char@> _) { Unit; };
  /Std/Test/Run%.Run(@(M@, return, do), out, Str|TestTest, test);
};

Test@ pass = Test|pass({
  Unit@ _ := Lazy;
  Pass;
});

Test@ fail = Test|fail({
  Unit@ _ := Lazy;
  Fail(String|Failed);
});

Test@ xfail = Test|xfail({
  Unit@ _ := Lazy;
  ExpectFails(Str|Failed, Fail(String|Failed));
});

Test@ skip = Test|skip({
  Unit@ _ := Lazy;
  Skip(String|Skipped);
});

Test@ Tests = TestSuite|Test[
  Test|Pass({
    Unit@ _ := Lazy;
    Bool@ wnt = True;
    Bool@ got = Run(pass);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test|Fail({
    Unit@ _ := Lazy;
    Bool@ wnt = False;
    Bool@ got = Run(fail);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test|XFail({
    Unit@ _ := Lazy;
    Bool@ wnt = True;
    Bool@ got = Run(xfail);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test|Skip({
    Unit@ _ := Lazy;
    Bool@ wnt = True;
    Bool@ got = Run(skip);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test|SuitePass({
    Unit@ _ := Lazy;
    Test@ suite = TestSuite|Suite[pass, skip, xfail, pass];
    Bool@ wnt = True;
    Bool@ got = Run(suite);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test|SuiteFail({
    Unit@ _ := Lazy;
    Test@ suite = TestSuite|Suite[pass, skip, xfail, fail, pass];
    Bool@ wnt = False;
    Bool@ got = Run(suite);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  })
];

@(Tests);
