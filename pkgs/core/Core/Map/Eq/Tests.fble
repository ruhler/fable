
Bool@ = /Std/Bool%.Bool@;
True = /Std/Bool%.True;
False = /Std/Bool%.False;

AssertEquals = /Std/Eq/Assert%.AssertEquals;

Int@ .= /Std/Int%;
Int .= /Std/Int/Lit%;

List = /Std/List%.List;

Str = /Std/Char/Ascii%.Str;

Test@ = /Std/Test%.Test@;
Test = /Std/Test%.Test;
TestSuite = /Std/Test%.TestSuite;

Unit@ = /Std/Unit%.Unit@;

Int@ A = Int|0;
Int@ B = Int|1;
Int@ C = Int|2;

Map@, Empty, Put, Remove .= /Std/Map%.Of(/Core/Int/Data%.Data)<Bool@>;
Eq = /Core/Map/Eq%.Eq(/Std/Int/Eq%.Eq);

Test@ Tests = TestSuite(Str|Eq, List[
  Test(Str|'eq: equal', (Unit@ _) {
    Map@ a = Put(Put(Put(Empty, A, True), B, False), C, False);
    Map@ b = Put(Put(Put(Empty, A, True), B, False), C, False);

    Bool@ wnt = True;
    Bool@ got = Eq(/Std/Bool/Eq%.Eq, a, b);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|'eq: value mismatch', (Unit@ _) {
    Map@ a = Put(Put(Put(Empty, A, True), B, True), C, False);
    Map@ b = Put(Put(Put(Empty, A, True), B, False), C, False);

    Bool@ wnt = False;
    Bool@ got = Eq(/Std/Bool/Eq%.Eq, a, b);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|'eq: different number of elements', (Unit@ _) {
    Map@ a = Put(Put(Put(Empty, A, True), B, False), C, False);
    Map@ b = Put(Put(Empty, A, True), B, False);

    Bool@ wnt = False;
    Bool@ got = Eq(/Std/Bool/Eq%.Eq, a, b);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|'eq: deleted to empty', (Unit@ _) {
    Map@ a = Remove(Put(Empty, A, True), A);
    Map@ b = Empty;

    Bool@ wnt = True;
    Bool@ got = Eq(/Std/Bool/Eq%.Eq, a, b);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|'eq: empty from deleted', (Unit@ _) {
    Map@ a = Empty;
    Map@ b = Remove(Put(Empty, A, True), A);

    Bool@ wnt = True;
    Bool@ got = Eq(/Std/Bool/Eq%.Eq, a, b);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|'eq: empty from deleted pair second', (Unit@ _) {
    Map@ a = Put(Empty, A, True);
    Map@ b = Remove(Put(a, B, True), B);

    Bool@ wnt = True;
    Bool@ got = Eq(/Std/Bool/Eq%.Eq, a, b);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|'eq: empty from deleted pair first', (Unit@ _) {
    Map@ a = Put(Empty, A, True);
    Map@ b = Remove(Put(a, C, True), C);

    Bool@ wnt = True;
    Bool@ got = Eq(/Std/Bool/Eq%.Eq, a, b);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|'eq: equal any order', (Unit@ _) {
    Map@ a = Put(Put(Put(Empty, B, False), C, False), A, True);
    Map@ b = Put(Put(Put(Empty, A, True), B, False), C, False);

    Bool@ wnt = True;
    Bool@ got = Eq(/Std/Bool/Eq%.Eq, a, b);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  })
]);

@(Tests);
