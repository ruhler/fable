
Char@ .= /Std/Char%;
Char, Str .= /Std/Char/Ascii%;
Int .= /Std/Int/Lit%;
Default .= /Std/Maybe%;
String@ .= /Std/String%;

Color@, Drawing@, Blank, Color, Drawings,
Over, Rect, Translate .= /App/Drawing%;


