
Bool@, True, False .= /Std/Bool%;
OnAscii .= /Std/Char/Ascii%;
AssertNotEquals .= /Std/Eq/Assert%;
Neg .= /Std/Int%;
Int .= /Std/Int/Lit%;
Lazy .= /Std/Lazy%;
List@ .= /Std/List%;
Lfsr3 .= /Std/Random/Lfsr%;
AssertSequence .= /Std/Random/Prng/Assert%;
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

S@ = List@<Bool@>;
Bit@ = +(Unit@ 0, Unit@ 1);

(List@<Bit@>) { S@; }
S = (List@<Bit@> xs) {
  Bit@ bit := /Std/List%.Map(xs);
  bit.?(0: False, 1: True);
};

Test@ Tests = TestSuite|Lfsr[
  Test|Basic({
    # Validate the full sequence of a 3 bit LFSR.
    Unit@ _ := Lazy;
    AssertSequence(
      /Std/List/Eq%.Eq(/Std/Bool/Eq%.Eq),
      /Std/List/Show%.Show(/Std/Bool/Show%.Show), Lfsr3)[
        S|010, S|101, S|011, S|111,
        S|110, S|100, S|001, S|010];
  }),

  TestSuite|Seed[
    Test|0({
      # Make sure the LFSR works with a seed of zero.
      Unit@ _ := Lazy;
      S@ seeded = Lfsr3.seed(Int|0);
      S@ next = Lfsr3.next(seeded);
      AssertNotEquals(
        /Std/List/Eq%.Eq(/Std/Bool/Eq%.Eq),
        /Std/List/Show%.Show(/Std/Bool/Show%.Show), seeded, next);
    }),

    Test|'-1'({
      # Make sure the LFSR works with a seed of -1.
      Unit@ _ := Lazy;
      S@ seeded = Lfsr3.seed(Neg(Int|1));
      S@ next = Lfsr3.next(seeded);
      AssertNotEquals(
        /Std/List/Eq%.Eq(/Std/Bool/Eq%.Eq),
        /Std/List/Show%.Show(/Std/Bool/Show%.Show), seeded, next);
    })
  ],

  Test|Feed({
    # Regression test for a case where feeding overwrote the bits of the LFSR
    # without accounting for the existing bits, thus losing all the randomness
    # involved.
    Unit@ _ := Lazy;
    S@ seeded = Lfsr3.seed(Int|0);
    S@ a = Lfsr3.feed(Int|4, Int|0, seeded);
    S@ b = Lfsr3.feed(Int|4, Int|0, a);
    AssertNotEquals(
        /Std/List/Eq%.Eq(/Std/Bool/Eq%.Eq),
        /Std/List/Show%.Show(/Std/Bool/Show%.Show),
        a, b);
  })

];

@(Tests);
