
% True = /Std/Bool%.True;
% False = /Std/Bool%.False;
% And = /Std/Bool%.And;

<@>@ Eq@ = /Std/Eq%.Eq@;

<@>% List = /Std/List%.List;

<@>@ Cmp@ = /Std/Cmp%.Cmp@;
@ Compared@ = /Std/Cmp%.Compared@;
% Less = /Std/Cmp%.Less;
% Equal = /Std/Cmp%.Equal;
% Greater = /Std/Cmp%.Greater;

<@>@ Show@ = /Std/Show%.Show@;
% Do = /Std/Char/Output%.Do;

% Str = /Std/Char/Ascii%.Str;
% String = /Core/Char/Ascii/Output%.String;

@ Test@ = /Core/Test%.Test@;
% TestSuite = /Core/Test%.TestSuite;

@ Unit@ = /Std/Unit%.Unit@;
% Unit = /Std/Unit%.Unit;

@ Bit1@ = +(Unit@ 0, Unit@ 1);
@ Bit2@ = *(Bit1@ h, Bit1@ l);

Bit2@ A = Bit2@(Bit1@(0: Unit), Bit1@(0: Unit));
Bit2@ B = Bit2@(Bit1@(0: Unit), Bit1@(1: Unit));
Bit2@ C = Bit2@(Bit1@(1: Unit), Bit1@(0: Unit));

Eq@<Bit1@> EqBit1 = (Bit1@ a, Bit1@ b) {
  a.?(
    0: b.?(0: True, 1: False),
    1: b.?(0: False, 1: True));
};

Cmp@<Bit1@> OrdBit1 = (Bit1@ a, Bit1@ b) {
  a.?(
    0: b.?(0: Equal, 1: Less),
    1: b.?(0: Greater, 1: Equal));
};

Show@<Bit1@> ShowBit1 = (Bit1@ x) {
  x.?(0: String|0, 1: String|1);
};

Eq@<Bit2@> EqBit2 = (Bit2@ a, Bit2@ b) {
  And(EqBit1(a.h, b.h), EqBit1(a.l, b.l));
};

Cmp@<Bit2@> OrdBit2 = (Bit2@ a, Bit2@ b) {
  Compared@ oh = OrdBit1(a.h, b.h);
  oh.?(equal: OrdBit1(a.l, b.l), : oh);
};

Show@<Bit2@> ShowBit2 = (Bit2@ x) {
  Unit@ _ <- Do(ShowBit1(x.h));
  ShowBit1(x.l);
};

% Map = /Core/Map/Tree%.Map<Bit2@>(OrdBit2);
<@>@ Map@ = Map.Map@;

Test@ Tests = TestSuite(Str|Tree, List[
  /Core/Map/Test%.Test<Map@, Bit2@>(Map, EqBit2, ShowBit2, A, B, C)
]);

@(Tests);
