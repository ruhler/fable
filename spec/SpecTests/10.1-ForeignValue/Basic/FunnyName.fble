# @@fble-test@@ no-error

Unit@ = *();
Unit@ Unit = Unit@();

Bool@ = +(Unit@ true, Unit@ false);
Bool@ True = Bool@(true: Unit@());
Bool@ False = Bool@(false: Unit@());

# Use of a foreign function with a funny name.
# The foreign function for this module must be supplied by the test driver
# somewhere. It should behave as a boolean 'Not' function.
(Bool@) { Bool@; } 'N!./t';

Unit@ _ = 'N!./t'(True).false;
Unit@ _ = 'N!./t'(False).true;
Unit;
