
Bool@, True, False .= /Std/Bool%;
OnAscii .= /Std/Char/Ascii%;
AssertEquals .= /Std/Eq/Assert%;
Lazy .= /Std/Lazy%;
List@, List .= /Std/List%;
HasItems, IsEmpty, StartsWith, EndsWith, Contains, Skip,
Trim, Strip, Search, SearchR, Until, Break, Split, Replace .= /Std/List/Eq%;
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

Elem@, Elems, Eq, Eqs, Shows .= /Std/List/Tests/Elem%;

Test@ Tests = TestSuite|Eq[
  TestSuite|HasItems[
    Test|T({
      Unit@ _ := Lazy;
      Bool@ wnt = True;
      Bool@ got = HasItems(Elems|ABBCCDDE);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|F({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = HasItems(Elems|'');
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    })
  ],

  TestSuite|IsEmpty[
    Test|T({
      Unit@ _ := Lazy;
      Bool@ wnt = True;
      Bool@ got = IsEmpty(Elems|'');
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|F({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = IsEmpty(Elems|ABBCCDDE);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    })
  ],

  TestSuite|Eq[
    Test|T({
      Unit@ _ := Lazy;
      Bool@ wnt = True;
      Bool@ got = Eqs(Elems|ABCDE, Elems|ABCDE);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|DiffElem({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = Eqs(Elems|ABCDE, Elems|ABDDE);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|DiffSize({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = Eqs(Elems|ABCDE, Elems|ABCD);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    })
  ],

  TestSuite|StartsWith[
    Test|T({
      Unit@ _ := Lazy;
      Bool@ wnt = True;
      Bool@ got = StartsWith(Eq, Elems|ABBCCDDE, Elems|ABBC);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|Mismatch({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = StartsWith(Eq, Elems|ABBCCDDE, Elems|ABC);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|EndOfString({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = StartsWith(Eq, Elems|ABBC, Elems|ABBCD);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    })
  ],

  TestSuite|EndsWith[
    Test|T({
      Unit@ _ := Lazy;
      Bool@ wnt = True;
      Bool@ got = EndsWith(Eq, Elems|ABBCCDDE, Elems|CDDE);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|Mismatch({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = EndsWith(Eq, Elems|ABBCCDDE, Elems|CDD);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|EndOfString({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = EndsWith(Eq, Elems|ABBC, Elems|ABBCD);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    })
  ],

  TestSuite|Contains[
    Test|T({
      Unit@ _ := Lazy;
      Bool@ wnt = True;
      Bool@ got = Contains(Eq, Elems|ABBCCDDE, Elems|BCCD);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|F({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = Contains(Eq, Elems|ABBCCDDE, Elems|DCCB);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    })
  ],

  TestSuite|Skip[
    Test|Match({
      Unit@ _ := Lazy;
      List@<Elem@> wnt = Elems|CDDE;
      List@<Elem@> got = Skip(Eq, Elems|ABBCCDDE, Elems|ABBC);
      AssertEquals(Eqs, Shows, wnt, got);
    }),

    Test|Mismatch({
      Unit@ _ := Lazy;
      List@<Elem@> wnt = Elems|ABBCCDDE;
      List@<Elem@> got = Skip(Eq, Elems|ABBCCDDE, Elems|ABCD);
      AssertEquals(Eqs, Shows, wnt, got);
    })
  ],

  TestSuite|Trim[
    Test|Match({
      Unit@ _ := Lazy;
      List@<Elem@> wnt = Elems|ABBC;
      List@<Elem@> got = Trim(Eq, Elems|ABBCCDDE, Elems|CDDE);
      AssertEquals(Eqs, Shows, wnt, got);
    }),

    Test|Mismatch({
      Unit@ _ := Lazy;
      List@<Elem@> wnt = Elems|ABBCCDDE;
      List@<Elem@> got = Trim(Eq, Elems|ABBCCDDE, Elems|EDDC);
      AssertEquals(Eqs, Shows, wnt, got);
    })
  ],

  TestSuite|Strip[
    Test|Match({
      Unit@ _ := Lazy;
      List@<Elem@> wnt = Elems|CDDE;
      List@<Elem@> got = Strip(Eq, Elems|ABBCCDDEABBC, Elems|ABBC);
      AssertEquals(Eqs, Shows, wnt, got);
    }),

    Test|Mismatch({
      Unit@ _ := Lazy;
      List@<Elem@> wnt = Elems|ABBCCDDE;
      List@<Elem@> got = Strip(Eq, Elems|ABBCCDDE, Elems|EDDC);
      AssertEquals(Eqs, Shows, wnt, got);
    }),

    Test|Overlap({
      Unit@ _ := Lazy;
      List@<Elem@> wnt = Elems|BA;
      List@<Elem@> got = Strip(Eq, Elems|ABABA, Elems|ABA);
      AssertEquals(Eqs, Shows, wnt, got);
    })
  ],

  TestSuite|Search[
    Test|Match({
      Unit@ _ := Lazy;
      List@<Elem@> wnt = Elems|ADBADE;
      List@<Elem@> got = Search(Eq, Elems|ABCADBADE, Elems|AD);
      AssertEquals(Eqs, Shows, wnt, got);
    }),

    Test|Mismatch({
      Unit@ _ := Lazy;
      List@<Elem@> wnt = Elems|'';
      List@<Elem@> got = Search(Eq, Elems|ABCADBE, Elems|AC);
      AssertEquals(Eqs, Shows, wnt, got);
    })
  ],

  TestSuite|SearchR[
    Test|Match({
      Unit@ _ := Lazy;
      List@<Elem@> wnt = Elems|ADE;
      List@<Elem@> got = SearchR(Eq, Elems|ABCADBADE, Elems|AD);
      AssertEquals(Eqs, Shows, wnt, got);
    }),

    Test|Mismatch({
      Unit@ _ := Lazy;
      List@<Elem@> wnt = Elems|'';
      List@<Elem@> got = SearchR(Eq, Elems|ABCADBADE, Elems|AC);
      AssertEquals(Eqs, Shows, wnt, got);
    }),

    Test|Empty({
      Unit@ _ := Lazy;
      List@<Elem@> wnt = Elems|'';
      List@<Elem@> got = SearchR(Eq, Elems|ABCADBADE, Elems|'');
      AssertEquals(Eqs, Shows, wnt, got);
    })
  ],

  TestSuite|Until[
    Test|Match({
      Unit@ _ := Lazy;
      List@<Elem@> wnt = Elems|ABC;
      List@<Elem@> got = Until(Eq, Elems|ABCADBADE, Elems|AD);
      AssertEquals(Eqs, Shows, wnt, got);
    }),

    Test|Mismatch({
      Unit@ _ := Lazy;
      List@<Elem@> wnt = Elems|ABCADBADE;
      List@<Elem@> got = Until(Eq, Elems|ABCADBADE, Elems|AC);
      AssertEquals(Eqs, Shows, wnt, got);
    })
  ],

  TestSuite|Break[
    Test|span({
      Unit@ _ := Lazy;
      List@<Elem@> wnt = Elems|ABC;
      List@<Elem@> got = Break(Eq, Elems|ABCADBE, Elems|AD).span;
      AssertEquals(Eqs, Shows, wnt, got);
    }),

    Test|tail({
      Unit@ _ := Lazy;
      List@<Elem@> wnt = Elems|ADBE;
      List@<Elem@> got = Break(Eq, Elems|ABCADBE, Elems|AD).tail;
      AssertEquals(Eqs, Shows, wnt, got);
    })
  ],

  Test|Split({
    Unit@ _ := Lazy;
    List@<List@<Elem@>> wnt = List[Elems|A, Elems|DE, Elems|A, Elems|''];
    List@<List@<Elem@>> got = Split(Eq, Elems|ABCDEBCABC, Elems|BC);
    AssertEquals(
      /Std/List/Eq%.Eq(Eqs),
      /Std/List/Show%.Show(Shows),
      wnt, got);
  }),

  Test|Replace({
    Unit@ _ := Lazy;
    List@<Elem@> wnt = Elems|AEADEEAAEA;
    List@<Elem@> got = Replace(Eq, Elems|ABCDEBCABC, Elems|BC, Elems|EA);
    AssertEquals(Eqs, Shows, wnt, got);
  })
];

@(Tests);
