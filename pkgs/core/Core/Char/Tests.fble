
% True = /Std/Bool%.True;
% False = /Std/Bool%.False;

% Char = /Std/Char/Ascii%.Char;

% Chr = /Std/Char%.Char;
% Pos = /Std/Char%.Pos;

% IsAlNum = /Core/Char/Type%.IsAlNum;
% IsAlpha = /Core/Char/Type%.IsAlpha;
% IsLower = /Core/Char/Type%.IsLower;

<@>% AssertEquals = /Core/Eq/Assert%.AssertEquals;

% Int = /Std/Int/Lit%.Int;

<@>% List = /Std/List%.List;

% Str = /Std/Char/Ascii%.Str;

@ Test@ = /Core/Test%.Test@;
% Test = /Core/Test%.Test;
% TestSuite = /Core/Test%.TestSuite;

@ Unit@ = /Std/Unit%.Unit@;

Test@ Tests = TestSuite(Str|Char, List[
  Test(Str|'Char', (Unit@ _) {
    AssertEquals(/Std/Char/Eq%.Eq, /Core/Char/Show%.Show,
      Char|A, Chr(Int|65));
  }),

  Test(Str|'Pos', (Unit@ _) {
    AssertEquals(/Std/Int/Eq%.Eq, /Std/Int/Show%.Show,
      Int|65, Pos(Char|A));
  }),

  Test(Str|'IsLower', (Unit@ _) {
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show,
      True, IsLower(Char|e));
  }),

  Test(Str|'IsLower no', (Unit@ _) {
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show,
      False, IsLower(Char|E));
  }),

  Test(Str|'IsAlpha', (Unit@ _) {
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show,
      True, IsAlpha(Char|e));
  }),

  Test(Str|'IsAlpha no', (Unit@ _) {
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show,
      False, IsAlpha(Char|4));
  }),

  Test(Str|'IsAlnum', (Unit@ _) {
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show,
      True, IsAlNum(Char|e));
  }),

  Test(Str|'IsAlnum no', (Unit@ _) {
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show,
      False, IsAlNum(Char|' '));
  }),

  /Core/Char/Map/Tests%.Tests
]);

@(Tests);
