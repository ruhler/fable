
<@>@ Show@ = /Core/Show%.Show@;

% Format = /Core/Char/Ascii/Output%.Format;

<@>@ Result@ = /Fbld/Result%.Result@;

<@ T@> { Show@<Result@<T@>>; }
ShowErrors = <@ T@>(Result@<T@> r) {
  r.errors;
};

<@ T@>(Show@<T@>) { Show@<Result@<T@>>; }
Show = <@ T@>(Show@<T@> show, Result@<T@> r) {
  r.failed.?(false: Format|'ok: '[show(r.value.just)]);
  Format|'failed: %s, %s'[r.errors, /Core/Maybe/Show%.Show(show, r.value)];
};

@(Show, ShowErrors);
