
Bool@ = /Std/Bool%.Bool@;
True = /Std/Bool%.True;
False = /Std/Bool%.False;

AssertEquals = /Std/Eq/Assert%.AssertEquals;

List = /Std/List%.List;

Maybe@ = /Std/Maybe%.Maybe@;
Just = /Std/Maybe%.Just;
Nothing = /Std/Maybe%.Nothing;

Show@ = /Std/Show%.Show@;

Str = /Std/Char/Ascii%.Str;
String = /Std/Char/Ascii/Output%.String;

Test@ = /Std/Test%.Test@;
Test = /Std/Test%.Test;
TestSuite = /Std/Test%.TestSuite;

Unit@ = /Std/Unit%.Unit@;
Unit = /Std/Unit%.Unit;

Fifo@ = /Core/Fifo%.Fifo@;
Empty = /Core/Fifo%.Empty;
First = /Core/Fifo%.First;
Put = /Core/Fifo%.Put;
Next = /Core/Fifo%.Next;

Elem@ = +(Unit@ A, Unit@ B, Unit@ C);
Elem@ A = Elem@(A: Unit);
Elem@ B = Elem@(A: Unit);
Elem@ C = Elem@(A: Unit);

Show@<Elem@> ElemShow = (Elem@ e) {
  e.?(A: String|A, B: String|B, C: String|C);
};

(Elem@, Elem@) { Bool@; } ElemEq = (Elem@ a, Elem@ b) {
  a.?(A: b.?(A: True, : False),
      B: b.?(B: True, : False),
      C: b.?(C: True, : False));
};

Test@ Tests = TestSuite(Str|Fifo, List[
  Test(Str|'EmptyFirst', (Unit@ _) {
    Maybe@<Elem@> wnt = Nothing<Elem@>;
    Maybe@<Elem@> got = First(Empty<Elem@>);
    AssertEquals(
      /Std/Maybe/Eq%.Eq(ElemEq),
      /Std/Maybe/Show%.Show(ElemShow),
      wnt, got);
  }),

  Test(Str|'PutFirst', (Unit@ _) {
    Fifo@<Elem@> fifo = Put(B, Empty<Elem@>);
    Maybe@<Elem@> wnt = Just(B);
    Maybe@<Elem@> got = First(fifo);
    AssertEquals(
      /Std/Maybe/Eq%.Eq(ElemEq),
      /Std/Maybe/Show%.Show(ElemShow),
      wnt, got);
  }),

  Test(Str|'MultiPutFirst', (Unit@ _) {
    Fifo@<Elem@> fifo = Put(A, Put(B, Empty<Elem@>));
    Maybe@<Elem@> wnt = Just(B);
    Maybe@<Elem@> got = First(fifo);
    AssertEquals(
      /Std/Maybe/Eq%.Eq(ElemEq),
      /Std/Maybe/Show%.Show(ElemShow),
      wnt, got);
  }),

  Test(Str|'Second', (Unit@ _) {
    Fifo@<Elem@> fifo = Put(A, Put(B, Empty<Elem@>));
    Maybe@<Elem@> wnt = Just(A);
    Maybe@<Elem@> got = First(Next(fifo));
    AssertEquals(
      /Std/Maybe/Eq%.Eq(ElemEq),
      /Std/Maybe/Show%.Show(ElemShow),
      wnt, got);
  }),

  Test(Str|'Flushed', (Unit@ _) {
    Fifo@<Elem@> abc = Put(C, Put(B, Put(A, Empty<Elem@>)));
    Fifo@<Elem@> empty = Next(Next(Next(abc)));
    Fifo@<Elem@> bac = Put(C, Put(A, Put(B, empty)));

    Maybe@<Elem@> wnt = Just(B);
    Maybe@<Elem@> got = First(bac);
    AssertEquals(
      /Std/Maybe/Eq%.Eq(ElemEq),
      /Std/Maybe/Show%.Show(ElemShow),
      wnt, got);
  })
]);

@(Tests);
