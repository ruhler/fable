
@ Bool@ = /Std/Bool%.Bool@;
% True = /Std/Bool%.True;

@ Ascii@ = /Std/Char/Ascii%.Ascii@;
% ToChar = /Std/Char/Ascii%.ToChar;

<<@>@,@>@ Put@ = /Core/Char/Stream%.Put@;
<<@>@>% OStream = /Core/Stream/Char%.OStream;
<@>@ Output@ = /Std/Char/Output%.Output@;
% String = /Std/Char/Ascii/Output%.String;

<@>% AssertEquals = /Std/Eq/Assert%.AssertEquals;

@ Int@ = /Std/Int%.Int@;

<@>@ List@ = /Std/List%.List@;
<@>% List = /Std/List%.List;
<@>% Empty = /Std/List%.Empty;

<@>@ Pure@ = /Core/Stdio/Pure%.Pure@;
<@>@ PureResult@ = /Core/Stdio/Pure%.PureResult@;
@ PureState@ = /Core/Stdio/Pure%.PureState@;
% Monad = /Core/Stdio/Pure%.Monad;
% Stdio = /Core/Stdio/Pure%.Stdio;
<@>% Run = /Core/Stdio/Pure%.Run;
<@>% PureResultEq = /Core/Stdio/Pure/Eq%.PureResult;
<@>% PureResultShow = /Core/Stdio/Pure/Show%.PureResult;

@ String@ = /Std/String%.String@;
% Str = /Std/Char/Ascii%.Str;

@ Test@ = /Std/Test%.Test@;
% Test = /Std/Test%.Test;
% TestSuite = /Std/Test%.TestSuite;

@ Unit@ = /Std/Unit%.Unit@;
% Unit = /Std/Unit%.Unit;

# Import to test compilation.
<<@>@>% _ = /Core/Stdio/Cat%;
<<@>@>% _ = /Core/Stdio/HelloWorld%;

% IStream = /Core/Stream/IStream%<Pure@>(Monad);
% GetLine = IStream.GetLine;

Put@<Pure@, Output@> Stdout = OStream<Pure@>(Stdio.out, Monad).put;
Put@<Pure@, Output@> Stderr = OStream<Pure@>(Stdio.err, Monad).put;

(List@<Ascii@>) { List@<Int@>; } Bytes = (List@<Ascii@> str) {
  /Std/List%.Map(str, (Ascii@ a) { /Std/Char%.Pos(ToChar(a)); });
};

List@<Int@> HelloWorld = Bytes|'Hello
World';

# Tests --
#  A test suite to test the /Stdio% module and friends.
Test@ Tests = TestSuite(Str|Stdio, List[
  Test(Str|Return, (Unit@ _) {
    List@<Int@> inputs = HelloWorld;
    PureResult@<Bool@> wnt = PureResult@(
      PureState@(inputs, Empty<Int@>, Empty<Int@>), True);
    PureResult@<Bool@> got = Run(Monad.return(True), inputs);
    AssertEquals(
      PureResultEq(/Std/Bool/Eq%.Eq),
      PureResultShow(/Std/Bool/Show%.Show),
      wnt, got);
  }),

  Test(Str|GetLine, (Unit@ _) {
    List@<Int@> inputs = HelloWorld;
    PureResult@<String@> wnt = PureResult@<String@>(
      PureState@(Bytes|World, Empty<Int@>, Empty<Int@>), Str|'Hello
');
    PureResult@<String@> got = Run(GetLine(Stdio.in), inputs);
    AssertEquals(
      PureResultEq(/Std/String/Eq%.Eq),
      PureResultShow(/Std/String/Show%.Show),
      wnt, got);
  }),

  Test(Str|GetLineEnd, (Unit@ _) {
    List@<Int@> inputs = Empty<Int@>;
    PureResult@<String@> wnt = PureResult@<String@>(
      PureState@(Empty<Int@>, Empty<Int@>, Empty<Int@>), Str|'');
    PureResult@<String@> got = Run(GetLine(Stdio.in), inputs);
    AssertEquals(
      PureResultEq(/Std/String/Eq%.Eq),
      PureResultShow(/Std/String/Show%.Show),
      wnt, got);
  }),

  Test(Str|Stdout, (Unit@ _) {
    List@<Int@> inputs = HelloWorld;
    PureResult@<Unit@> wnt = PureResult@<Unit@>(
      PureState@(inputs, Bytes|There, Empty<Int@>), Unit);
    PureResult@<Unit@> got = Run(Stdout $ String|There, inputs);
    AssertEquals(
      PureResultEq(/Std/Unit/Eq%.Eq),
      PureResultShow(/Std/Unit/Show%.Show),
      wnt, got);
  }),

  Test(Str|Stderr, (Unit@ _) {
    List@<Int@> inputs = HelloWorld;
    PureResult@<Unit@> wnt = PureResult@<Unit@>(
      PureState@(inputs, Empty<Int@>, Bytes|There), Unit);
    PureResult@<Unit@> got = Run(Stderr $ String|There, inputs);
    AssertEquals(
      PureResultEq(/Std/Unit/Eq%.Eq),
      PureResultShow(/Std/Unit/Show%.Show),
      wnt, got);
  }),

  Test(Str|DoOuts, (Unit@ _) {
    List@<Int@> inputs = HelloWorld;

    PureResult@<Unit@> wnt = PureResult@<Unit@>(
      PureState@(inputs, Bytes|AB, Empty<Int@>), Unit);

    PureResult@<Unit@> got = Run({
      Unit@ _ := Monad.do(Stdout $ String|A);
      Unit@ _ := Monad.do(Stdout $ String|B);
      Monad.return(Unit);
    }, inputs);

    AssertEquals(
      PureResultEq(/Std/Unit/Eq%.Eq),
      PureResultShow(/Std/Unit/Show%.Show),
      wnt, got);
  }),

  Test(Str|DoErrs, (Unit@ _) {
    List@<Int@> inputs = HelloWorld;

    PureResult@<Unit@> wnt = PureResult@<Unit@>(
      PureState@(inputs, Empty<Int@>, Bytes|AB), Unit);

    PureResult@<Unit@> got = Run({
      Unit@ _ := Monad.do(Stderr $ String|A);
      Unit@ _ := Monad.do(Stderr $ String|B);
      Monad.return(Unit);
    }, inputs);

    AssertEquals(
      PureResultEq(/Std/Unit/Eq%.Eq),
      PureResultShow(/Std/Unit/Show%.Show),
      wnt, got);
  })
]);

@(Tests);
