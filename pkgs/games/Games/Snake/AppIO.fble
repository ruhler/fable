
% Success = /Core/Cli%.Success;

@ Int@ = /Std/Int%.Int@;

<@>@ List@ = /Std/List%.List@;

<<@>@>@ IoM@ = /Core/Io%.IoM@;

@ String@ = /Std/String%.String@;

@ Unit@ = /Std/Unit%.Unit@;

<<@>@>@ App@ = /App/App%.App@;
<<@>@>@ Main@ = /App/Native%.Main@;

Main@
Main = <<@>@ M@>(IoM@<M@> io, App@<M@> app, Int@ width, Int@ height, List@<String@> _args)
{
  Unit@ _ := io.m.do $ /Games/Snake%.Main<M@>(io.m, app, width, height);
  io.m.return(Success);
};

Main;
