
OnAscii .= /Std/Char/Ascii%;
Test@ .= /Std/Test%;
TestSuite = OnAscii(/Std/Test%.TestSuite);

# @value[Tests] Test suite for /Std%
#  @type[Test@]
Test@ Tests = TestSuite|Std[
  /Std/Bool/Tests%.Tests,
  /Std/Char/Tests%.Tests,
  /Std/Int/Tests%.Tests,
  /Std/List/Tests%.Tests,
  /Std/Maybe/Tests%.Tests,
  /Std/Random/Tests%.Tests,
  /Std/Stream/Tests%.Tests,
  /Std/Unit/Tests%.Tests
];

/Std/Test/Cli%.Run(Tests);
