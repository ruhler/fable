
@ String@ = /Std/String%.String@;
% Str = /Std/Char/Ascii%.Str;

<@>% List = /Std/List%.List;

@ Test@ = /Std/Test%.Test@;

% Test = /Games/BenchmarkGame/Game%.Test;

String@ input = Str|
'>ONE
CTTGAACCCG
GATTC
>TWO
attBgtataR
>THREE
ccaacattac
';

String@ output = Str|
'>ONE
GAATCCGGGTTCAAG
>TWO
YTATACVAAT
>THREE
GTAATGTTGG
';

Test@ Tests = Test(
  Str|ReverseComplement,
  /Games/BenchmarkGame/ReverseComplement%.Main,
  input, List[Str|0], output);

@(Tests);
