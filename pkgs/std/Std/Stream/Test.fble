# @module[/Std/Stream/Test%]
#  An output channel for testing.

Monad@ .= /Std/Monad%;
Stream@ .= /Std/Stream%;
Out@ .= /Std/Stream/Out%;
Unit@, Unit .= /Std/Unit%;

# @func[ToTest] Stream values to a Unit@.
#  This goes through the output value by value, ignoring the value seen.
#  Useful for test cases and benchmarks. If you don't care about the output in
#  normal execution, use /Std/Stream/Null% instead, which ignores the entire
#  Stream@ in the first place.
#
#  @arg[A@] The type of value to output.
#  @arg[Stream@<A@>] The output to perform.
#  @returns[Unit@] Nothing interesting.
<@ A@>(Stream@<A@>) { Unit@; }
ToTest = <@ A@>(Stream@<A@> output) {
  A@ _, Unit@ u := output(Unit);
  u;
};

# @func[TestOut] An Out@ for use in testing.
#  This exercises the output stream computations but ignores the actual values
#  output. Useful for test cases and benchmarks. If you don't care about the
#  output in normal execution, use /Std/Stream/Null% instead, which ignores
#  the entire Stream@ output in the first place.
#
#  @arg[A@] The type of value to output.
#  @arg[<@>@][M@] Monadic type to work with.
#  @arg[Monad@<M@>][m] The monadic interface.
#  @returns[Out@<M@>] The test output port.
<@ A@, <@>@ M@>(Monad@<M@>) { Out@<A@, M@>; }
TestOut = <@ A@, <@>@ M@>(Monad@<M@> m, Stream@<A@> s) {
  m.return(ToTest(s));
};

@(ToTest, TestOut);
