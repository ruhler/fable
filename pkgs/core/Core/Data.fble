
Int@ .= /Std/Int%;
Stream@ .= /Std/Stream%;

# We say a type can be treated as data if it can be represented as a stream of
# integers satisfying a prefix invariant: there must not exist two values X, Y
# such that stream packed value of X is a prefix of the stream packed value of
# Y.
Data@ = <@ A@>(A@) { Stream@<Int@>; };

@(Data@);
