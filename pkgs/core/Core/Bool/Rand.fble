
Bool@ = /Std/Bool%.Bool@;
Not = /Std/Bool%.Not;

Int@ = /Std/Int%.Int@;
IsZero = /Std/Int/Sign%.IsZero;
Int = /Std/Int/Lit%.Int;

Rng@ = /Core/Random/Rng%.Rng@;

# Generates a random boolean.
<<@>@ M@>(Rng@<M@>) { M@<Bool@>; }
Rand = <<@>@ M@>(Rng@<M@> m) {
  Int@ x := m.do(m.rand(Int|1));
  m.return $ Not(IsZero(x));
};

@(Rand);
