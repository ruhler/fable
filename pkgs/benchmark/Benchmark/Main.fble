
OnAscii .= /Std/Char/Ascii%;
Test@ .= /Std/Test%;
TestSuite = OnAscii(/Std/Test%.TestSuite);


Test@ Benchmarks = TestSuite|Benchmarks[
  /Fbld/Bench%.Bench,
  /Games/Sudoku/Tests%.Bench,
  /Games/Snake/Bench%.Bench,
  /Games/GameOfLife/Bench%.Bench,
  /Games/TicTacToe/Tests%.Bench,
  /Games/BenchmarkGame/Bench%.Bench,
  /Graphics/Bench%.Bench,
  /Invaders/Bench%.Bench,
  /Pinball/Bench%.Bench,
  /Md5/Bench%.Bench,
  /Sat/Bench%.Bench
];

/Std/Test/Cli%.Run(Benchmarks);
