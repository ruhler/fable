# @module[/Std/Maybe/Eq/Tests%]
#  Tests for /Std/Maybe/Eq%.

Bool@, True, False .= /Std/Bool%;
OnAscii, Str .= /Std/Char/Ascii%;
Eq@ .= /Std/Eq%;
AssertEquals .= /Std/Eq/Assert%;
Lazy .= /Std/Lazy%;
Maybe@, Just, Nothing .= /Std/Maybe%;
IsJust, IsNothing .= /Std/Maybe/Eq%;
String@ .= /Std/String%;
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

Eq@<Maybe@<String@>> Eq = /Std/Maybe/Eq%.Eq(/Std/String/Eq%.Eq);

# @value[Tests] Test suite for /Std/Maybe/Eq%
#  @type[Test@]
Test@ Tests = TestSuite|Eq[
  TestSuite|IsJust[
    Test|Just({
      Unit@ _ := Lazy;
      Bool@ wnt = True;
      Bool@ got = IsJust(Just(Str|ABCD));
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|Nothing({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = IsJust(Nothing<String@>);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    })
  ],

  TestSuite|IsNothing[
    Test|Just({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = IsNothing(Just(Str|ABCD));
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|Nothing({
      Unit@ _ := Lazy;
      Bool@ wnt = True;
      Bool@ got = IsNothing(Nothing<String@>);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    })
  ],

  TestSuite|Eq[
    Test|NN({
      Unit@ _ := Lazy;
      Bool@ wnt = True;
      Bool@ got = Eq(Nothing<String@>, Nothing<String@>);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|JN({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = Eq(Just(Str|ABCD), Nothing<String@>);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|NJ({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = Eq(Nothing<String@>, Just(Str|ABCD));
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|JJ({
      Unit@ _ := Lazy;
      Bool@ wnt = True;
      Bool@ got = Eq(Just(Str|ABCD), Just(Str|ABCD));
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|Jj({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = Eq(Just(Str|ABCD), Just(Str|DCBA));
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    })
  ]
];

@(Tests);
