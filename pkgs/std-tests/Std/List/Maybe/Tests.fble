
OnAscii .= /Std/Char/Ascii%;
AssertEquals .= /Std/Eq/Assert%;
Lazy .= /Std/Lazy%;
List@ .= /Std/List%;
Head, Last, Concat .= /Std/List/Maybe%;
Maybe@, Just, Nothing .= /Std/Maybe%;
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

Elem@, Elem, Elems, Eq, Show, Eqs, Shows .= /Std/List/Tests/Elem%;

Test@ Tests = TestSuite|Maybe[
  TestSuite|List[
    Test|J({
      Unit@ _ := Lazy;
      List@<Elem@> wnt = Elems|A;
      List@<Elem@> got = /Std/List/Maybe%.List(Just(Elem.A));
      AssertEquals(Eqs, Shows, wnt, got);
    }),

    Test|N({
      Unit@ _ := Lazy;
      List@<Elem@> wnt = Elems|'';
      List@<Elem@> got = /Std/List/Maybe%.List(Nothing<Elem@>);
      AssertEquals(Eqs, Shows, wnt, got);
    })
  ],

  TestSuite|Head[
    Test|J({
      Unit@ _ := Lazy;
      Maybe@<Elem@> wnt = Just(Elem.A);
      Maybe@<Elem@> got = Head(Elems|ABCDE);
      AssertEquals(
        /Std/Maybe/Eq%.Eq(Eq),
        /Std/Maybe/Show%.Show(Show),
        wnt, got);
    }),

    Test|N({
      Unit@ _ := Lazy;
      Maybe@<Elem@> wnt = Nothing<Elem@>;
      Maybe@<Elem@> got = Head(Elems|'');
      AssertEquals(
        /Std/Maybe/Eq%.Eq(Eq),
        /Std/Maybe/Show%.Show(Show),
        wnt, got);
    })
  ],

  TestSuite|Last[
    Test|J({
      Unit@ _ := Lazy;
      Maybe@<Elem@> wnt = Just(Elem.E);
      Maybe@<Elem@> got = Last(Elems|ABCDE);
      AssertEquals(
        /Std/Maybe/Eq%.Eq(Eq),
        /Std/Maybe/Show%.Show(Show),
        wnt, got);
    }),

    Test|N({
      Unit@ _ := Lazy;
      Maybe@<Elem@> wnt = Nothing<Elem@>;
      Maybe@<Elem@> got = Last(Elems|'');
      AssertEquals(
        /Std/Maybe/Eq%.Eq(Eq),
        /Std/Maybe/Show%.Show(Show),
        wnt, got);
    })
  ],

  Test|Concat({
    Unit@ _ := Lazy;
    List@<Elem@> wnt = Elems|ABC;
    List@<Elem@> got = Concat[
      Just(Elem.A),
      Nothing<Elem@>,
      Just(Elem.B),
      Just(Elem.C),
      Nothing<Elem@>
    ];
    AssertEquals(Eqs, Shows, wnt, got);
  })
];

@(Tests);
