
Bool@ = /Std/Bool%.Bool@;
True = /Std/Bool%.True;
False = /Std/Bool%.False;

Stream@, Out@ .= /Std/Stream/Text%;

AssertEquals = /Std/Eq/Assert%.AssertEquals;

List = /Std/List%.List;

Pure@ = /Core/Monad/Pure%.Pure@;

Str = /Std/Char/Ascii%.Str;

String = /Std/Char/Ascii/Stream%.String;

Test@ = /Std/Test%.Test@;
Test = /Std/Test%.Test;
TestSuite = /Std/Test%.TestSuite;
Pass = /Std/Test%.Pass;
Fail = /Std/Test%.Fail;
ExpectFails = /Std/Test%.ExpectFails;

Unit@ = /Std/Unit%.Unit@;
Unit = /Std/Unit%.Unit;

# Run a test with the test runner, for testing purposes.
# Returns whether the test passed or failed.
(Test@) { Bool@; }
Run = (Test@ test) {
  Out@<Pure@> out = (Stream@ _) { Unit; };
  /Core/Test/Run%.Run(/Core/Monad/Pure%.Monad, out, Str|TestTest, test);
};

Test@ pass = Test(Str|pass, (Unit@ _) { Pass; });
Test@ fail = Test(Str|fail, (Unit@ _) { Fail(String|Failed); });

Test@ xfail = Test(Str|xfail, (Unit@ _) {
  ExpectFails(Str|Failed, Fail(String|Failed));
});

Test@ Tests = TestSuite(Str|'Test', List[
  Test(Str|'RunTest.pass_passes', (Unit@ _) {
    Bool@ wnt = True;
    Bool@ got = Run(pass);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|'RunTest.fail_fails', (Unit@ _) {
    Bool@ wnt = False;
    Bool@ got = Run(fail);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|'RunTest.xfail_passes', (Unit@ _) {
    Bool@ wnt = True;
    Bool@ got = Run(xfail);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|'RunTest.SuitePass', (Unit@ _) {
    Test@ suite = TestSuite(Str|'Suite', List[
      Test(Str|a, (Unit@ _) { Pass; }),
      Test(Str|b, (Unit@ _) { Pass; }),
      Test(Str|c, (Unit@ _) { ExpectFails(Str|Failed, Fail(String|Failed)); }),
      Test(Str|d, (Unit@ _) { Pass; })]);

    Bool@ wnt = True;
    Bool@ got = Run(suite);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|'RunTest.SuiteFail', (Unit@ _) {
    Test@ suite = TestSuite(Str|'Suite', List[
      Test(Str|a, (Unit@ _) { Pass; }),
      Test(Str|b, (Unit@ _) { Fail(String|Oops); }),
      Test(Str|c, (Unit@ _) { ExpectFails(Str|Failed, Fail(String|Failed)); }),
      Test(Str|d, (Unit@ _) { Pass; })]);

    Bool@ wnt = False;
    Bool@ got = Run(suite);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  })
]);

@(Tests);
