
Int@ = /Std/Int%.Int@;
Incr = /Std/Int%.Incr;
Add = /Std/Int%.Add;
Sub = /Std/Int%.Sub;
Shr = /Std/Int%.Shr;
IsZero = /Std/Int/Sign%.IsZero;
Lt = /Std/Int/Ord%.Lt;
Int = /Std/Int/Lit%.Int;

Rng@ = /Core/Random/Rng%.Rng@;

# Generates a random integer uniformly in the range [0, n).
<<@>@ M@>(Rng@<M@>, Int@) { M@<Int@>; }
Of = <<@>@ M@>(Rng@<M@> m, Int@ n) {
  # Find the smallest k such that n < 2^k
  (Int@) { Int@; }
  FindK = (Int@ n) {
    IsZero(n).?(true: Int|1);
    Incr(FindK(Shr(n, Int|1)));
  };
  Int@ k = FindK(n);

  M@<Int@> Try = {
    Int@ x := m.do(m.rand(k));
    Lt(x, n).?(true: m.return(x));
    Try;
  };

  Try;
};

# Generates a random integer uniformly in the range [lo, hi]
<<@>@ M@>(Rng@<M@>, Int@, Int@) { M@<Int@>; }
Range = <<@>@ M@>(Rng@<M@> m, Int@ lo, Int@ hi) {
  Int@ x := m.do $ Of(m, Incr(Sub(hi, lo)));
  m.return $ Add(lo, x);
};

@(Of, Range);
