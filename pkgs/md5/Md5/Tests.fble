
@ Bit8@ = /Md5/Bits/Bit8%.Bit8@;
% H8 = /Md5/Bits/Bit8%.H8;

@ Hex@ = /Core/Digits%.Hex@;
% HexStr = /Core/Digits/String%.HexStr;

<@>% AssertEquals = /Core/Eq/Assert%.AssertEquals;

<@>@ List@ = /Std/List%.List@;
<@>% Items = /Std/List%.Items;
<@>% Empty = /Std/List%.Empty;
<@>% List = /Std/List%.List;

<@>@ Maybe@ = /Core/Maybe%.Maybe@;
<@>% Just = /Core/Maybe%.Just;
<@>% Nothing = /Core/Maybe%.Nothing;

<<@>@>@ Monad@ = /Core/Monad%.Monad@;

@ Hash@ = /Md5/Hash%.Hash@;
% Eq = /Md5/Hash%.Eq;
% Show = /Md5/Hash%.Show;

<<@>@>% Md5 = /Md5/Md5%.Md5;

@ String@ = /Std/String%.String@;
% Str = /Core/Char/Ascii%.Str;

@ Test@ = /Core/Test%.Test@;
% Test = /Core/Test%.Test;
% TestSuite = /Core/Test%.TestSuite;

@ Unit@ = /Std/Unit%.Unit@;

# Import to test compilation.
% _ = /Md5/Bench%;
% _ = /Md5/Main%;

# A Hash literal. It should consist of 32 hex digits.
(List@<Hex@>) { Hash@; } Hash = (List@<Hex@> s00) {
  Hex@ h00 = s00.items.head; List@<Hex@> s01 = s00.items.tail;
  Hex@ h01 = s01.items.head; List@<Hex@> s02 = s01.items.tail;
  Hex@ h02 = s02.items.head; List@<Hex@> s03 = s02.items.tail;
  Hex@ h03 = s03.items.head; List@<Hex@> s04 = s03.items.tail;
  Hex@ h04 = s04.items.head; List@<Hex@> s05 = s04.items.tail;
  Hex@ h05 = s05.items.head; List@<Hex@> s06 = s05.items.tail;
  Hex@ h06 = s06.items.head; List@<Hex@> s07 = s06.items.tail;
  Hex@ h07 = s07.items.head; List@<Hex@> s08 = s07.items.tail;
  Hex@ h08 = s08.items.head; List@<Hex@> s09 = s08.items.tail;
  Hex@ h09 = s09.items.head; List@<Hex@> s10 = s09.items.tail;
  Hex@ h10 = s10.items.head; List@<Hex@> s11 = s10.items.tail;
  Hex@ h11 = s11.items.head; List@<Hex@> s12 = s11.items.tail;
  Hex@ h12 = s12.items.head; List@<Hex@> s13 = s12.items.tail;
  Hex@ h13 = s13.items.head; List@<Hex@> s14 = s13.items.tail;
  Hex@ h14 = s14.items.head; List@<Hex@> s15 = s14.items.tail;
  Hex@ h15 = s15.items.head; List@<Hex@> s16 = s15.items.tail;
  Hex@ h16 = s16.items.head; List@<Hex@> s17 = s16.items.tail;
  Hex@ h17 = s17.items.head; List@<Hex@> s18 = s17.items.tail;
  Hex@ h18 = s18.items.head; List@<Hex@> s19 = s18.items.tail;
  Hex@ h19 = s19.items.head; List@<Hex@> s20 = s19.items.tail;
  Hex@ h20 = s20.items.head; List@<Hex@> s21 = s20.items.tail;
  Hex@ h21 = s21.items.head; List@<Hex@> s22 = s21.items.tail;
  Hex@ h22 = s22.items.head; List@<Hex@> s23 = s22.items.tail;
  Hex@ h23 = s23.items.head; List@<Hex@> s24 = s23.items.tail;
  Hex@ h24 = s24.items.head; List@<Hex@> s25 = s24.items.tail;
  Hex@ h25 = s25.items.head; List@<Hex@> s26 = s25.items.tail;
  Hex@ h26 = s26.items.head; List@<Hex@> s27 = s26.items.tail;
  Hex@ h27 = s27.items.head; List@<Hex@> s28 = s27.items.tail;
  Hex@ h28 = s28.items.head; List@<Hex@> s29 = s28.items.tail;
  Hex@ h29 = s29.items.head; List@<Hex@> s30 = s29.items.tail;
  Hex@ h30 = s30.items.head; List@<Hex@> s31 = s30.items.tail;
  Hex@ h31 = s31.items.head;
  Hash@(
    h00, h01, h02, h03, h04, h05, h06, h07,
    h08, h09, h10, h11, h12, h13, h14, h15,
    h16, h17, h18, h19, h20, h21, h22, h23,
    h24, h25, h26, h27, h28, h29, h30, h31);
};

% State = /Core/Monad/State%<List@<Bit8@>>;

<@>@ M@ = State.State@;
Monad@<M@> Monad = State.Monad;

M@<Maybe@<Bit8@>> Get = {
  List@<Bit8@> bytes <- Monad.do(State.Get);
  bytes.?(empty: Monad.return(Nothing<Bit8@>));
  Unit@ _ <- Monad.do(State.Set(bytes.items.tail));
  Monad.return(Just(bytes.items.head));
};

# Compute the md5 hash for a string of bytes.
(List@<Bit8@>) { Hash@; } Md5Str = (List@<Bit8@> bytes) {
  Md5<M@>(Monad, Get, bytes).x;
};

(List@<Hex@>) { List@<Bit8@>; } Hex2Bytes = (List@<Hex@> hex) {
  hex.?(
    items: Items(
      H8[hex.items.head, hex.items.tail.items.head],
      Hex2Bytes(hex.items.tail.items.tail)),
    empty: Empty<Bit8@>);
};
      
(String@, Hash@, List@<Hex@>) { Test@; } TestStr = (String@ name, Hash@ wnt, List@<Hex@> bytes) {
  Test(name, (Unit@ _) {
    Hash@ got = Md5Str(Hex2Bytes(bytes));
    AssertEquals(Eq, Show, wnt, got);
  });
};

Test@ Tests = TestSuite(Str|Md5, List[
  # ""
  TestStr(
    Str|empty,
    Hash|D41D8CD98F00B204E9800998ECF8427E,
    HexStr|''),

  # "a"
  TestStr(
    Str|a,
    Hash|0CC175B9C0F1B6A831C399E269772661,
    HexStr|61),

  # "abc"
  TestStr(
    Str|abc,
    Hash|900150983CD24FB0D6963F7D28E17F72,
    HexStr|616263),

  # "message digest"
  TestStr(
    Str|message,
    Hash|F96B697D7CB7938D525A2F31AAF161D0,
    HexStr|6D65737361676520646967657374),

  # "abcdefghijklmnopqrstuvwxyz"
  TestStr(
    Str|a_to_z,
    Hash|C3FCD3D76192E4007DFB496CCA67E13B,
    HexStr|6162636465666768696A6B6C6D6E6F707172737475767778797A),

  # "ABCDEFGHIJKLMNOPQRS0TUVWXYZabcdefghijklmnopqrstuvwxyz012345678@9"
  TestStr(
    Str|A_to_9,
    Hash|D174AB98D277D9F5A5611C2C9F419D9F,
    HexStr|4142434445464748494A4B4C4D4E4F505152535455565758595A6162636465666768696A6B6C6D6E6F707172737475767778797A30313233343536373839),

  # "12345678901234567890123456789012345678901234567890123456789012345678901234567890"
  TestStr(
    Str|1_to_0,
    Hash|57EDF4A22BE3C955AC49DA2E2107B67A,
    HexStr|3132333435363738393031323334353637383930313233343536373839303132333435363738393031323334353637383930313233343536373839303132333435363738393031323334353637383930)
]);

/Core/Stdio/IO%.Run(/Core/Test/Stdio%.Run(Tests));
