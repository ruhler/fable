
Bool@, True, False .= /Std/Bool%;
OnAscii .= /Std/Char/Ascii%;
Int .= /Std/Int/Lit%;
Lazy .= /Std/Lazy%;
AssertStream = OnAscii(/Std/Stream/String/Assert%.AssertStream);
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

Map@, Entry@, Entries .= /Std/Map%.Of(/Std/Int/Data%.Data)<Bool@>;
Show = /Std/Map/Show%.Show(/Std/Int/Show%.Show);

Test@ Tests = TestSuite|Show[
  Test|Empty({
    Unit@ _ := Lazy;
    Map@ map = Entries[];
    AssertStream|'{ }'(Show(/Std/Bool/Show%.Show, map));
  }),

  Test|Single({
    Unit@ _ := Lazy;
    Map@ map = Entries[Entry@(Int|2, False)];
    AssertStream|'{ 2 => False; }'(Show(/Std/Bool/Show%.Show, map));
  }),

  Test|Multi({
    Unit@ _ := Lazy;
    Map@ map = Entries[Entry@(Int|2, False), Entry@(Int|3, True)];
    AssertStream|'{ 2 => False; 3 => True; }'(Show(/Std/Bool/Show%.Show, map));
  })
];

@(Tests);
