
AssertEquals = /Std/Eq/Assert%.AssertEquals;

Int@ = /Std/Int%.Int@;
Decr = /Std/Int%.Decr;
Int = /Std/Int/Lit%.Int;
IsZero = /Std/Int/Sign%.IsZero;

Coeffs@ = /Core/Random/Lfsr%.Coeffs@;
State@ = /Core/Random/Lfsr%.State@;
Next = /Core/Random/Lfsr%.Next;
Bits = /Core/Random/Lfsr%.Bits;

List@ = /Std/List%.List@;
List = /Std/List%.List;
Items = /Std/List%.Items;
Empty = /Std/List%.Empty;

Str = /Std/Char/Ascii%.Str;

Test@ = /Std/Test%.Test@;
TestSuite = /Std/Test%.TestSuite;
Test = /Std/Test%.Test;

Unit@ = /Std/Unit%.Unit@;

(Coeffs@, Int@, State@) { List@<State@>; }
NextN = (Coeffs@ c, Int@ n, State@ s) {
  IsZero(n).?(true: Empty<State@>);
  State@ next = Next(c, s);
  Items(next, NextN(c, Decr(n), next));
};

Test@ Tests = TestSuite(Str|Lfsr, List[
  Test(Str|Basic, (Unit@ _) {
    # A 3 bit LFSR.
    Coeffs@ coeffs = Bits|110;
    State@ state = Bits|000;
    List@<State@> got = NextN(coeffs, Int|8, state);
    List@<State@> wnt = List[
      Bits|001, Bits|011, Bits|110, Bits|101,
      Bits|010, Bits|100, Bits|000, Bits|001];

    AssertEquals(
      /Std/List/Eq%.Eq(/Std/List/Eq%.Eq(/Std/Bool/Eq%.Eq)),
      /Std/List/Show%.Show(/Std/List/Show%.Show(/Std/Bool/Show%.Show)),
      wnt, got);
  })
]);

@(Tests);
