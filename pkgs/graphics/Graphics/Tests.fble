
<@>% List = /Std/List%.List;

% Str = /Std/Char/Ascii%.Str;

@ Test@ = /Std/Test%.Test@;
% TestSuite = /Std/Test%.TestSuite;

# Import to test compilation.
% _ = /Graphics/AppIO%;
% _ = /Graphics/Bench%;

Test@ Tests = TestSuite(Str|Graphics, List[
  /Graphics/2D/Tests%.Tests,
  /Graphics/Triangle/Tests%.Tests
]);

/Core/Stdio/Native/Cli%.Run(/Core/Test/Stdio%.Run(Tests));
