
<@>% Concat = /Std/List%.Concat;

@ String@ = /Std/String%.String@;
% Str = /Std/Char/Ascii%.Str;

String@ Menu = Concat[
  Str|'<table><tr>',
  Str|'<td><a href="/">Overview</a></td>',
  Str|'<td><a href="/overall">Overall</a></td>',
  Str|'<td><a href="/self">Self</a></td>',
  Str|'<td><a href="/seqs">Sequences</a></td>',
  Str|'<tr></table><br />'
];

@(Menu);

