
<@>% AssertEquals = /Core/Eq/Assert%.AssertEquals;

@ Int@ = /Std/Int%.Int@;
% Decr = /Std/Int%.Decr;
% IsZero = /Std/Int/Sign%.IsZero;
% Int = /Std/Int/Lit%.Int;

<@>% List = /Std/List%.List;

% Str = /Std/Char/Ascii%.Str;

@ Test@ = /Core/Test%.Test@;
% Test = /Core/Test%.Test;
% TestSuite = /Core/Test%.TestSuite;

@ Unit@ = /Std/Unit%.Unit@;

<@>% Entries = /Computrainer/Grid%.Entries;

@ Gate@ = /Computrainer/Model%.Gate@;
@ Gates@ = /Computrainer/Model%.Gates@;
@ Cars@ = /Computrainer/Model%.Cars@;
@ Model@ = /Computrainer/Model%.Model@;
% Model = /Computrainer/Model%.Model;
% Tick = /Computrainer/Model%.Tick;
% C = /Computrainer/Model%.C;
% 0 = /Computrainer/Model%.0;
% 1 = /Computrainer/Model%.1;
% Rail = /Computrainer/Model%.Rail;
% Sink = /Computrainer/Model%.Sink;
% Source = /Computrainer/Model%.Source;
% Zero = /Computrainer/Model%.Zero;
% Select = /Computrainer/Model%.Select;
% Switch = /Computrainer/Model%.Switch;
% Dup = /Computrainer/Model%.Dup;
% Up = /Computrainer/Model%.Up;
% Down = /Computrainer/Model%.Down;
% Right = /Computrainer/Model%.Right;

(Int@, Model@) { Model@; }
TickN = (Int@ n, Model@ m) {
    IsZero(n).?(true: m);
    TickN(Decr(n), Tick(m));
};

Test@ Tests = TestSuite(Str|Computrainer, List[
  Test(Str|'Noop', (Unit@ _) {
    Gates@ gates = Entries<Gate@>[];
    Cars@ cars = Entries[@(x: Int|3, y: Int|4, v: C)];
    Model@ model = Model(gates, cars);
    Model@ wnt = model;
    Model@ got = Tick(model);
    AssertEquals(/Computrainer/Model/Eq%.Model, /Computrainer/Model/Show%.Model, wnt, got);
  }),

  Test(Str|'Rail', (Unit@ _) {
    Gates@ gates = Entries[
        @(x: Int|3, y: Int|4, v: Rail.Right)
    ];
    Cars@ cars = Entries[
        @(x: Int|3, y: Int|4, v: C)
    ];
    Model@ model = Model(gates, cars);
    Model@ wnt = Model(gates, Entries[@(x: Int|4, y: Int|4, v: C)]);
    Model@ got = Tick(model);
    AssertEquals(/Computrainer/Model/Eq%.Model, /Computrainer/Model/Show%.Model, wnt, got);
  }),

  Test(Str|'Sink', (Unit@ _) {
    Gates@ gates = Entries[
        @(x: Int|3, y: Int|4, v: Sink)
    ];
    Cars@ cars = Entries[
        @(x: Int|3, y: Int|4, v: C),
        @(x: Int|4, y: Int|4, v: 0)
    ];
    Model@ model = Model(gates, cars);
    Model@ wnt = Model(gates, Entries[
        @(x: Int|4, y: Int|4, v: 0)
    ]);
    Model@ got = Tick(model);
    AssertEquals(/Computrainer/Model/Eq%.Model, /Computrainer/Model/Show%.Model, wnt, got);
  }),

 Test(Str|'Source', (Unit@ _) {
   Gates@ gates = Entries[
       @(x: Int|3, y: Int|4, v: Source.Right)
   ];
   Cars@ cars = Entries[
       @(x: Int|3, y: Int|4, v: C)
   ];
   Model@ model = Model(gates, cars);
   Model@ wnt = Model(gates, Entries[
       @(x: Int|4, y: Int|4, v: C),
       @(x: Int|3, y: Int|4, v: C)
   ]);
   Model@ got = Tick(model);
   AssertEquals(/Computrainer/Model/Eq%.Model, /Computrainer/Model/Show%.Model, wnt, got);
 }),

  Test(Str|'Zero', (Unit@ _) {
    Gates@ gates = Entries[
        @(x: Int|3, y: Int|4, v: Rail.Right),
        @(x: Int|4, y: Int|4, v: Rail.Right),
        @(x: Int|5, y: Int|4, v: Zero.Right),
        @(x: Int|6, y: Int|4, v: Rail.Right),
        @(x: Int|7, y: Int|4, v: Rail.Right)
    ];

    Cars@ cars = Entries[
        @(x: Int|3, y: Int|4, v: C)
    ];
    Model@ model = Model(gates, cars);
    Cars@ wnt = Entries[
        @(x: Int|8, y: Int|4, v: 0),
        @(x: Int|7, y: Int|4, v: C)
    ];
    Cars@ got = TickN(Int|4, model).s.cars;
    AssertEquals(/Computrainer/Model/Eq%.Cars, /Computrainer/Model/Show%.Cars, wnt, got);
  }),

  Test(Str|'Select_0', (Unit@ _) {
    # >>>S
    # >>>W0>
    #    1>
    Gates@ gates = Entries[
        @(x: Int|3, y: Int|4, v: Rail.Right),
        @(x: Int|4, y: Int|4, v: Rail.Right),
        @(x: Int|5, y: Int|4, v: Rail.Right),
        @(x: Int|6, y: Int|4, v: Select),

        @(x: Int|3, y: Int|3, v: Rail.Right),
        @(x: Int|4, y: Int|3, v: Rail.Right),
        @(x: Int|5, y: Int|3, v: Rail.Right),
        @(x: Int|6, y: Int|3, v: Switch(Up, Right, Down)),
        @(x: Int|7, y: Int|3, v: Rail.Right),
        @(x: Int|8, y: Int|3, v: Rail.Right),

        @(x: Int|6, y: Int|2, v: Rail.Right),
        @(x: Int|7, y: Int|2, v: Rail.Right)
    ];

    Cars@ cars = Entries[
        @(x: Int|4, y: Int|4, v: 0),
        @(x: Int|3, y: Int|4, v: C),
        @(x: Int|3, y: Int|3, v: C)
    ];
    Model@ model = Model(gates, cars);
    Cars@ wnt = Entries[
        @(x: Int|9, y: Int|3, v: C)
    ];
    Cars@ got = TickN(Int|10, model).s.cars;
    AssertEquals(/Computrainer/Model/Eq%.Cars, /Computrainer/Model/Show%.Cars, wnt, got);
  }),

  Test(Str|'Select_1', (Unit@ _) {
    # >>>S
    # >>>W0>
    #    1>
    Gates@ gates = Entries[
        @(x: Int|3, y: Int|4, v: Rail.Right),
        @(x: Int|4, y: Int|4, v: Rail.Right),
        @(x: Int|5, y: Int|4, v: Rail.Right),
        @(x: Int|6, y: Int|4, v: Select),

        @(x: Int|3, y: Int|3, v: Rail.Right),
        @(x: Int|4, y: Int|3, v: Rail.Right),
        @(x: Int|5, y: Int|3, v: Rail.Right),
        @(x: Int|6, y: Int|3, v: Switch(Up, Right, Down)),
        @(x: Int|7, y: Int|3, v: Rail.Right),
        @(x: Int|8, y: Int|3, v: Rail.Right),

        @(x: Int|6, y: Int|2, v: Rail.Right),
        @(x: Int|7, y: Int|2, v: Rail.Right)
    ];

    Cars@ cars = Entries[
        @(x: Int|4, y: Int|4, v: 1),
        @(x: Int|3, y: Int|4, v: C),
        @(x: Int|3, y: Int|3, v: C)
    ];
    Model@ model = Model(gates, cars);
    Cars@ wnt = Entries[
        @(x: Int|8, y: Int|2, v: C)
    ];
    Cars@ got = TickN(Int|10, model).s.cars;
    AssertEquals(/Computrainer/Model/Eq%.Cars, /Computrainer/Model/Show%.Cars, wnt, got);
  }),

  Test(Str|'Dup', (Unit@ _) {
    Gates@ gates = Entries[
        @(x: Int|3, y: Int|4, v: Dup(Right, Up))
    ];
    Cars@ cars = Entries[
        @(x: Int|3, y: Int|4, v: C)
    ];
    Model@ model = Model(gates, cars);
    Model@ wnt = Model(gates, Entries[
        @(x: Int|4, y: Int|4, v: C),
        @(x: Int|3, y: Int|5, v: C)
    ]);
    Model@ got = Tick(model);
    AssertEquals(/Computrainer/Model/Eq%.Model, /Computrainer/Model/Show%.Model, wnt, got);
  })
]);

/Core/Stdio/IO%.Run(/Core/Test/Stdio%.Run(Tests));
