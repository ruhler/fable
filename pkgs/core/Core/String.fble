
@ Char@ = /Std/Char%.Char@;
<@>@ ToChar@ = /Std/Char/Lit%.ToChar@;

<@>@ List@ = /Std/List%.List@;

# String@ --
#   A character string.
@ String@ = List@<Char@>;

# Str --
#   A string literal.
#
# Example Use:
#   String@ s = Str|'hello, world'
<@ T@>(ToChar@<T@>, List@<T@>) { String@; }
Str = <@ T@>(ToChar@<T@> toChar, List@<T@> str) {
  /Std/List%.Map(str, toChar);
};

@(String@, Str);
