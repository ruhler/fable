
<<@>@,@>@ Map@ = /Core/Map%.Map@;

<@>@ Show@ = /Core/Show%.Show@;
<@>@ ShowM@ = /Core/Show%.ShowM@;
% Do = /Core/Show%.Do;

% Format = /Core/Char/Ascii/Show%.Format;
% String = /Core/Char/Ascii/Show%.String;

@ Unit@ = /Std/Unit%.Unit@;

<<@>@ M@, @ K@>(Map@<M@, K@>, Show@<K@>)<@ V@>(Show@<V@>) { Show@<M@<V@>>; }
Show = <<@>@ M@, @ K@>(Map@<M@, K@> m, Show@<K@> show_key)<@ V@>(Show@<V@> show_value, M@<V@> map) {
  Unit@ _ <- Do(m.ForEach(map, String|'{ ',
    (K@ k, V@ v, ShowM@ shown) {
      Unit@ _ <- Do(shown);
      Format|'%s => %s; '[show_key(k), show_value(v)];
    }));
  String|'}';
};

@(Show);
