
OnAscii .= /Std/Char/Ascii%;
AssertEquals .= /Std/Eq/Assert%;
Int@ .= /Std/Int%;
Int .= /Std/Int/Lit%;
Lazy .= /Std/Lazy%;
List@ .= /Std/List%;
Length, Get, Set, Take, Drop, Range, Span .= /Std/List/Index%;
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

Elem@, Elem, Elems, Eq, Show, Eqs, Shows .= /Std/List/Tests/Elem%;

Test@ Tests = TestSuite|Index[
  Test|Length({
    Unit@ _ := Lazy;
    Int@ wnt = Int|5;
    Int@ got = Length(Elems|ABCDE);
    AssertEquals(/Std/Int/Eq%.Eq, /Std/Int/Show%.Show, wnt, got);
  }),

  Test|Get({
    Unit@ _ := Lazy;
    Elem@ got = Get(Elems|ABCDE, Int|2);
    Elem@ wnt = Elem.C;
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test|Set({
    Unit@ _ := Lazy;
    List@<Elem@> got = Set(Elems|ABCDE, Int|2, Elem.A);
    List@<Elem@> wnt = Elems|ABADE;
    AssertEquals(Eqs, Shows, wnt, got);
  }),

  Test|Take({
    Unit@ _ := Lazy;
    List@<Elem@> got = Take(Elems|ABCDE, Int|2);
    List@<Elem@> wnt = Elems|AB;
    AssertEquals(Eqs, Shows, wnt, got);
  }),

  Test|Drop({
    Unit@ _ := Lazy;
    List@<Elem@> got = Drop(Elems|ABCDE, Int|2);
    List@<Elem@> wnt = Elems|CDE;
    AssertEquals(Eqs, Shows, wnt, got);
  }),

  Test|Range({
    Unit@ _ := Lazy;
    List@<Elem@> got = Range(Elems|ABCDE, Int|1, Int|2);
    List@<Elem@> wnt = Elems|BC;
    AssertEquals(Eqs, Shows, wnt, got);
  }),

  TestSuite|Span[
    Test|span({
      Unit@ _ := Lazy;
      List@<Elem@> got = Span(Elems|ABCDE, Int|2).span;
      List@<Elem@> wnt = Elems|AB;
      AssertEquals(Eqs, Shows, wnt, got);
    }),

    Test|tail({
      Unit@ _ := Lazy;
      List@<Elem@> got = Span(Elems|ABCDE, Int|2).tail;
      List@<Elem@> wnt = Elems|CDE;
      AssertEquals(Eqs, Shows, wnt, got);
    })
  ]
];

@(Tests);
