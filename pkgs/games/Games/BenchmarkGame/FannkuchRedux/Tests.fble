
AssertEquals .= /Std/Eq/Assert%;
OnAscii, Str, StrE .= /Std/Char/Ascii%;
Int@ .= /Std/Int%;
Int .= /Std/Int/Lit%;
Lazy .= /Std/Lazy%;
List@, List, Empty, Append .= /Std/List%;
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

Fannkuch@, FannkuchRedux, Flip, Flips,
RotateRight, Permutes .= /Games/BenchmarkGame/FannkuchRedux%;

Test@ Tests = TestSuite|FannkuchRedux[
  Test|Flip({
    Unit@ _ := Lazy;
    List@<Int@> input = List[Int|4, Int|2, Int|1, Int|5, Int|3];
    List@<Int@> wnt = List[Int|5, Int|1, Int|2, Int|4, Int|3];
    List@<Int@> got = Flip(Int|4, Empty<Int@>, input);
    AssertEquals(
      /Std/List/Eq%.Eq(/Std/Int/Eq%.Eq),
      /Std/List/Show%.Show(/Std/Int/Show%.Show),
      wnt, got);
  }),

  Test|Flips({
    Unit@ _ := Lazy;
    List@<Int@> input = List[Int|4, Int|2, Int|1, Int|5, Int|3];
    Int@ wnt = Int|5;
    Int@ got = Flips(Int|0, input);
    AssertEquals(/Std/Int/Eq%.Eq, /Std/Int/Show%.Show, wnt, got);
  }),

  Test|RotateRight({
    Unit@ _ := Lazy;
    List@<Int@> input = List[Int|1, Int|2, Int|3, Int|4, Int|5];
    List@<Int@> wnt = List[Int|5, Int|1, Int|2, Int|3, Int|4];
    List@<Int@> got = RotateRight(input);
    AssertEquals(
      /Std/List/Eq%.Eq(/Std/Int/Eq%.Eq),
      /Std/List/Show%.Show(/Std/Int/Show%.Show),
      wnt, got);
  }),

  Test|Permutes({
    Unit@ _ := Lazy;
    List@<Int@> input = List[Int|3, Int|2, Int|1];
    List@<List@<Int@>> wnt = List[
      List[Int|1, Int|2, Int|3],
      List[Int|2, Int|1, Int|3],
      List[Int|2, Int|3, Int|1],
      List[Int|3, Int|2, Int|1],
      List[Int|3, Int|1, Int|2],
      List[Int|1, Int|3, Int|2]];

    S@ = List@<List@<Int@>>;
    M@, M(.Monad), S(.State), Exec .= /Std/State/Pure%.Pure<S@>;

    (List@<Int@>) { M@<Unit@>; } F = (List@<Int@> l) {
      S@ s := M.do(S.get);
      S.put(Append(s, List[l]));
    };

    M@<Unit@> permutes = Permutes(M, input, F);
    List@<List@<Int@>> got = Exec(permutes, Empty<List@<Int@>>);
    AssertEquals(
      /Std/List/Eq%.Eq(/Std/List/Eq%.Eq(/Std/Int/Eq%.Eq)),
      /Std/List/Show%.Show(/Std/List/Show%.Show(/Std/Int/Show%.Show)),
      wnt, got);
  }),

  Test|FannkuchRedux({
    Unit@ _ := Lazy;
    Fannkuch@ result = FannkuchRedux(Int|6);
    List@<Int@> got = List[result.checksum, result.max_flips];
    List@<Int@> wnt = List[Int|49, Int|10];
    AssertEquals(
      /Std/List/Eq%.Eq(/Std/Int/Eq%.Eq),
      /Std/List/Show%.Show(/Std/Int/Show%.Show),
      wnt, got);
  }),

  /Games/BenchmarkGame/Game%.Test(
    Str|IO,
    /Games/BenchmarkGame/FannkuchRedux/Main%.Main,
    Str|'', List[Str|6],
    StrE|'49\nPfannkuchen(6) = 10\n')
];

@(Tests);
