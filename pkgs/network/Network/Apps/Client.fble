
Bool@ = /Std/Bool%.Bool@;
True = /Std/Bool%.True;
False = /Std/Bool%.False;

Put@ .= /Std/Stream%;
OStream = /Core/Stream/Char%.OStream;
Output@ = /Std/Stream/Text%.Output@;
String = /Std/Stream/Text%.String;
StringE = /Std/Char/Ascii/Output%.StringE;
Binary = /Std/Stream/Binary%;

Int@ = /Std/Int%.Int@;
Neg = /Std/Int%.Neg;
Decr = /Std/Int%.Decr;
Int = /Std/Int/Lit%.Int;
IsZero = /Std/Int/Sign%.IsZero;

List@ = /Std/List%.List@;
Concat = /Std/List%.Concat;

Maybe@ = /Std/Maybe%.Maybe@;

Monad@ = /Std/Monad%.Monad@;
Io@ = /Std/Io%.Io@;

Out@ .= /Std/Stream/Text%;
In@ = /Core/Stream%.In@;
IOut@ = /Core/Stream%.IOut@;

Success = /Std/Io/Cli%.Success;
Failure = /Std/Io/Cli%.Failure;

String@ = /Std/String%.String@;
Str = /Std/Char/Ascii%.Str;

Unit@ = /Std/Unit%.Unit@;
Unit = /Std/Unit%.Unit;

Main@ = /Std/Io/Cli%.Main@;
Sockets@ = /Network/Sockets%.Sockets@;

Args@ = *(
  Bool@ help,
  String@ error,
  String@ hostname,
  Int@ port,
  String@ message,
  Int@ num_bytes
);

Args@ DefaultArgs = @(
  help: False,
  error: Str|'',
  hostname: Str|'localhost',
  port: Int|7,
  message: Str|'hello',
  num_bytes: Neg(Int|1)
);

(List@<String@>, Args@) { Args@; }
GetArgs = (List@<String@> args, Args@ default) {
  args.?(empty: default);

  String@ arg = args.items.head;

  (List@<String@>) { Bool@; } ArgAnyOf = (List@<String@> option) {
    /Std/List/Search%.Any(option, /Std/String/Eq%.Eq(arg));
  };

  ArgAnyOf[Str|'-h', Str|'--help'].?(true: {
    default.@(help: True);
  });

  args.items.tail.?(empty: {
    default.@(error: Concat[Str|'missing arg to option ', arg]);
  });

  String@ value = args.items.tail.items.head;
  List@<String@> nargv = args.items.tail.items.tail;

  Args@ nargs = {
    ArgAnyOf[Str|'--host'].?(true: {
      default.@(hostname: value);
    });

    ArgAnyOf[Str|'-p', Str|'--port'].?(true: {
      default.@(port: /Core/Int/Read%.Read(value));
    });

    ArgAnyOf[Str|'-m', Str|'--message'].?(true: {
      default.@(message: value);
    });

    ArgAnyOf[Str|'-n', Str|'--num-bytes'].?(true: {
      default.@(num_bytes: /Core/Int/Read%.Read(value));
    });

    default.@(error: Concat[Str|'unrecognized option ', arg]);
  };

  nargs.error.?(items: nargs);
  GetArgs(nargv, nargs);
};

Main@ Main = <<@>@ M@>(Monad@<M@> m, Io@<M@> io, List@<String@> argv) {
  Out@<M@> err := m.do(/Std/Io/File/Text%.Stderr(m, io));

  Sockets@<M@> sockets := m.do(/Network/Sockets/Native%.Sockets<M@>(io, m));

  (Int@, In@<M@>, Put@<M@, Binary.Output@>) { M@<Unit@>; }
  ForwardN = (Int@ n, In@<M@> in, Put@<M@, Binary.Output@> out) {
    IsZero(n).?(true: m.return(Unit));
    Int@ nn = /Std/Int/Cmp%.Gt(n, Int|0).?(true: Decr(n), false: n);

    Maybe@<Int@> mb := m.do(in);
    mb.?(nothing: m.return(Unit));
    Unit@ _ := m.do(out(Binary.Put(mb.just)));
    ForwardN(nn, in, out);
  };

  Args@ args = GetArgs(argv, DefaultArgs);
  args.help.?(true: {
    Out@<M@> out := m.do(/Std/Io/File/Text%.Stdout(m, io));
    Unit@ _ := m.do(out.put $ String $ /Network/Apps/Echo/Usage%);
    m.return(Success);
  });

  args.error.?(items: {
    Unit@ _ := m.do(err.put $ String $ args.error);
    Unit@ _ := m.do(err.put $ StringE|'\ntry --help for help\n');
    m.return(Failure);
  });

  Maybe@<IOut@<M@>> mios := m.do(sockets.client(args.hostname, args.port));
  mios.?(nothing: {
    Unit@ _ := m.do(err.put $ StringE|'unable to connect\n');
    m.return(Failure);
  });

  IOut@<M@> ios = mios.just;
  Put@<M@, Output@> os = OStream(m, ios.out).put;
  Binary.Out@<M@> out := m.do(/Std/Io/File/Binary%.Stdout(m, io));

  Unit@ _ := m.do(os $ String $ args.message);
  Unit@ _ := m.do(ForwardN(args.num_bytes, ios.in, out.put));
  m.return(Success);
};

Main;
