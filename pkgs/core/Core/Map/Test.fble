
@ Bool@ = /Std/Bool%.Bool@;
% True = /Std/Bool%.True;
% False = /Std/Bool%.False;
% And = /Std/Bool%.And;

<@>@ Eq@ = /Std/Eq%.Eq@;
<@>% AssertEquals = /Std/Eq/Assert%.AssertEquals;

<@>@ List@ = /Std/List%.List@;
<@>% List = /Std/List%.List;
<@>% Empty = /Std/List%.Empty;
<@>% Items = /Std/List%.Items;

<@>@ Maybe@ = /Std/Maybe%.Maybe@;
<@>% Just = /Std/Maybe%.Just;
<@>% Nothing = /Std/Maybe%.Nothing;

<@>@ Show@ = /Std/Show%.Show@;
% Format = /Std/Char/Ascii/Output%.Format;

% Str = /Std/Char/Ascii%.Str;

@ Test@ = /Std/Test%.Test@;
% TestSuite = /Std/Test%.TestSuite;

@ Unit@ = /Std/Unit%.Unit@;
% Unit = /Std/Unit%.Unit;

# A test suite for a Map@ implementation.
# You provide:
#   - An implementation of Map@ to test.
#   - Implementations of Eq and Show for keys of the map.
#   - Three distinct keys in iteration order.
# It gives you back a test suite.
<<@>@ M@, @ K@>(/Core/Map%.Map@<M@, K@>, Eq@<K@>, Show@<K@>, K@, K@, K@) { Test@; }
Test = <<@>@ M@, @ K@>(/Core/Map%.Map@<M@, K@> m, Eq@<K@> eq, Show@<K@> show, K@ a, K@ b, K@ c) {
  TestSuite(Str|'Map', List[
    /Std/Test%.Test(Str|'empty', (Unit@ _) {
      Maybe@<Unit@> wnt = Nothing<Unit@>;
      Maybe@<Unit@> got = m.Lookup(m.Empty<Unit@>, b);
      AssertEquals(
        /Std/Maybe/Eq%.Eq(/Std/Unit/Eq%.Eq),
        /Std/Maybe/Show%.Show(/Std/Unit/Show%.Show),
        wnt, got);
    }),

    /Std/Test%.Test(Str|'not found', (Unit@ _) {
      m.Map@<Unit@> map = m.Insert<Unit@>(m.Empty<Unit@>, c, Unit);
      Maybe@<Unit@> wnt = Nothing<Unit@>;
      Maybe@<Unit@> got = m.Lookup(map, b);
      AssertEquals(
        /Std/Maybe/Eq%.Eq(/Std/Unit/Eq%.Eq),
        /Std/Maybe/Show%.Show(/Std/Unit/Show%.Show),
        wnt, got);
    }),

    /Std/Test%.Test(Str|'found', (Unit@ _) {
      m.Map@<Bool@> map = m.Insert(m.Insert(m.Insert(m.Empty<Bool@>,
        a, False),
        b, True),
        c, False);
      Maybe@<Bool@> wnt = Just(True);
      Maybe@<Bool@> got = m.Lookup(map, b);
      AssertEquals(
        /Std/Maybe/Eq%.Eq(/Std/Bool/Eq%.Eq),
        /Std/Maybe/Show%.Show(/Std/Bool/Show%.Show),
        wnt, got);
    }),

    /Std/Test%.Test(Str|'replace', (Unit@ _) {
      m.Map@<Bool@> map = m.Insert(m.Insert(m.Empty<Bool@>,
        b, False),
        b, True);
      Maybe@<Bool@> wnt = Just(True);
      Maybe@<Bool@> got = m.Lookup(map, b);
      AssertEquals(
        /Std/Maybe/Eq%.Eq(/Std/Bool/Eq%.Eq),
        /Std/Maybe/Show%.Show(/Std/Bool/Show%.Show),
        wnt, got);
    }),

    /Std/Test%.Test(Str|'delete', (Unit@ _) {
      m.Map@<Bool@> map = m.Delete(m.Insert(m.Empty<Bool@>, b, False), b);
      Maybe@<Bool@> wnt = Nothing<Bool@>;
      Maybe@<Bool@> got = m.Lookup(map, b);
      AssertEquals(
        /Std/Maybe/Eq%.Eq(/Std/Bool/Eq%.Eq),
        /Std/Maybe/Show%.Show(/Std/Bool/Show%.Show),
        wnt, got);
    }),

    /Std/Test%.Test(Str|'delete nothing', (Unit@ _) {
      m.Map@<Bool@> map = m.Delete(m.Insert(m.Empty<Bool@>, b, False), a);
      Maybe@<Bool@> wnt = Just(False);
      Maybe@<Bool@> got = m.Lookup(map, b);
      AssertEquals(
        /Std/Maybe/Eq%.Eq(/Std/Bool/Eq%.Eq),
        /Std/Maybe/Show%.Show(/Std/Bool/Show%.Show),
        wnt, got);
    }),

    /Std/Test%.Test(Str|'foreach', (Unit@ _) {
      m.Map@<Bool@> map = m.Insert(m.Insert(m.Insert(m.Empty<Bool@>,
        b, True),
        a, True),
        b, False);

      # Note: A < B, we expect the ForEach to iterate in the order A, B. Because
      # we add A to the end of the list before B, we expect the resulting list
      # to be in the order B, A.
      @ Entry@ = *(K@ key, Bool@ value);
      List@<Entry@> wnt = List[Entry@(b, False), Entry@(a, True)];
      List@<Entry@> got = m.ForEach(map, Empty<Entry@>,
        (K@ k, Bool@ v, List@<Entry@> l) {
          Items(Entry@(k, v), l);
        });
      AssertEquals(
        /Std/List/Eq%.Eq((Entry@ a, Entry@ b) {
          And(eq(a.key, b.key), /Std/Bool/Eq%.Eq(a.value, b.value));
        }),
        /Std/List/Show%.Show((Entry@ e) {
          Format|'%s: %s'[show(e.key), /Std/Bool/Show%.Show(e.value)];
        }),
        wnt, got);
    })
  ]);
};

@(Test);
