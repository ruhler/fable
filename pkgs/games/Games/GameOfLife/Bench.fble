
OnAscii .= /Std/Char/Ascii%;
Int .= /Std/Int/Lit%;
Test@ .= /Std/Test%;
Unit .= /Std/Unit%;

Key@, Event@ .= /App/App%;
Test = OnAscii(/App/Bench%.Bench);

Event@ Quit = Event@(key_down: Key@(q: Unit));

# Speed is set at 200ms per tick. For 60 seconds, we expect 300 ticks.
Test@ Bench = Test|GameOfLife(/Games/GameOfLife/App%.Main, Quit, Int|300);

@(Bench);
