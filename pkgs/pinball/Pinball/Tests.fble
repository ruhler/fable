
Ascii@, OnAscii, Str .= /Std/Char/Ascii%;
AssertEquals .= /Std/Eq/Assert%;
Lazy@, Lazy .= /Std/Lazy%;
List@, List, Empty .= /Std/List%;
Test@, TestResult@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@, Unit .= /Std/Unit%;

Ball@ .= /Pinball/Ball%;
Edge@, Edge .= /Pinball/Edge%;
Num@, Neg, Int, Sub, Div .= /Pinball/Num%;
Paddle@, Paddle .= /Pinball/Paddle%;
Vec@ .= /Pinball/Vec%;
World@, Tick .= /Pinball/World%;


(List@<Ascii@>, Lazy@<TestResult@>) { TestResult@; }
ExpectFails = (List@<Ascii@> msg, Lazy@<TestResult@> result) {
  /Std/Test%.ExpectFails(Str(msg), result(Unit));
};

Test@ Tests = TestSuite|Pinball[
  /Pinball/Rotate/Tests%.Tests,
  /Pinball/Quadratic/Tests%.Tests,

  Test|'Move Ball No Collision'({
    # The ball moves freely to the right 10 units per tick.
    Unit@ _ := Lazy;
    World@ start = @(
      gravity: Vec@(Int|0, Int|0),
      ball: Ball@(Vec@(Int|0, Int|0), Vec@(Int|10, Int|0), Int|1),
      edges: Empty<Edge@>,
      paddles: Empty<Paddle@>);
    World@ end = Tick(start);
    Ball@ want = @(
      pos: Vec@(Int|10, Int|0),
      vel: Vec@(Int|10, Int|0),
      radius: Int|1);
    Ball@ got = end.ball;
    AssertEquals(/Pinball/Ball%.Eq, /Pinball/Ball%.Show, want, got);
  }),
  
  Test|'Move Ball Collision'({
    # The ball moves to the right, hits a wall, then bounces back.
    Unit@ _ := Lazy;
    World@ start = @(
      gravity: Vec@(Int|0, Int|0),
      ball: Ball@(Vec@(Int|0, Int|0), Vec@(Int|10, Int|0), Int|1),
      edges: List<Edge@>[
        Edge(Vec@(Int|6, Neg(Int|4)), Vec@(Int|6, Int|4), Int|1)
      ],
      paddles: Empty<Paddle@>);
    World@ end = Tick(start);

    Ball@ want = @(
      pos: Vec@(Int|0, Int|0),
      vel: Vec@(Neg(Int|10), Int|0),
      radius: Int|1);
    Ball@ got = end.ball;
    AssertEquals(/Pinball/Ball%.Eq, /Pinball/Ball%.Show, want, got);
  }),

  Test|'Move Ball Avoid Collision'({
    # The ball moves to the right, passing beneath a wall.
    # Regression test for when we failed to check collision happens within the
    # bounds of a wall.
    Unit@ _ := Lazy;
    World@ start = @(
      gravity: Vec@(Int|0, Int|0),
      ball: Ball@(Vec@(Int|0, Int|0), Vec@(Int|10, Int|0), Int|1),
      edges: List<Edge@>[
        Edge(Vec@(Int|5, Int|3), Vec@(Int|5, Int|11), Int|1)
      ],
      paddles: Empty<Paddle@>);
    World@ end = Tick(start);
    Ball@ want = @(
      pos: Vec@(Int|10, Int|0),
      vel: Vec@(Int|10, Int|0),
      radius: Int|1);
    Ball@ got = end.ball;
    AssertEquals(/Pinball/Ball%.Eq, /Pinball/Ball%.Show, want, got);
  }),

  Test|'Stationary Paddle Collision'({
    # The ball moves down at constant velocity onto a stationary paddle.
    Unit@ _ := Lazy;
    World@ start = @(
      gravity: Vec@(Int|0, Int|0),
      ball: @(
        pos: Vec@(Int|2, Int|2),
        vel: Vec@(Int|0, Neg(Int|2)),
        radius: Int|1),
      edges: Empty<Edge@>,
      paddles: List[
        Paddle(
          Vec@(Int|0, Int|0),
          Vec@(Int|0, Int|0),
          Vec@(Int|4, Int|0),
          Int|0, Int|0,
          Neg(Int|1), Int|1, Int|1)
      ]);
    World@ end = Tick(start);
    Ball@ want = @(
      pos: Vec@(Int|2, Int|2),
      vel: Vec@(Int|0, Int|2),
      radius: Int|1);
    Ball@ got = end.ball;
    AssertEquals(/Pinball/Ball%.Eq, /Pinball/Ball%.Show, want, got);
  }),

  Test|'Stationary Paddle Collision Restitution'({
    # Test that restitution of the paddle is taken into account during
    # collision.
    Unit@ _ := Lazy;
    World@ start = @(
      gravity: Vec@(Int|0, Int|0),
      ball: @(
        pos: Vec@(Int|2, Int|2),
        vel: Vec@(Int|0, Neg(Int|2)),
        radius: Int|1),
      edges: Empty<Edge@>,
      paddles: List[
        Paddle(
          Vec@(Int|0, Int|0),
          Vec@(Int|0, Int|0),
          Vec@(Int|4, Int|0), Int|0, Int|0,
          Neg(Int|1), Int|1, Div(Int|1, Int|2))
      ]);
    World@ end = Tick(start);
    Ball@ want = @(
      pos: Vec@(Int|2, Div(Int|3, Int|2)),
      vel: Vec@(Int|0, Int|1),
      radius: Int|1);
    Ball@ got = end.ball;
    AssertEquals(/Pinball/Ball%.Eq, /Pinball/Ball%.Show, want, got);
  }),

  Test|'Stationary Ball With Paddle'({
    # Regression test for a divide by zero that happens if the ball is
    # stationary relative to the paddle.
    Unit@ _ := Lazy;
    World@ start = @(
      gravity: Vec@(Int|0, Int|0),
      ball: @(
        pos: Vec@(Int|2, Int|2),
        vel: Vec@(Int|0, Int|0),
        radius: Int|1),
      edges: Empty<Edge@>,
      paddles: List[
        Paddle(
          Vec@(Int|0, Int|0),
          Vec@(Int|0, Int|0),
          Vec@(Int|4, Int|0), Int|0, Int|0,
          Neg(Int|1), Int|1, Int|1)
      ]);
    World@ end = Tick(start);
    Ball@ want = start.ball;
    Ball@ got = end.ball;
    AssertEquals(/Pinball/Ball%.Eq, /Pinball/Ball%.Show, want, got);
  }),

  Test|'End-Stationary Paddle Collision'({
    # The ball moves down at constant velocity onto a paddle that becomes
    # stationary before the ball hits it.
    # This is a regression test for a case where velocity of the paddle was
    # being treated as non-zero in this case.
    Unit@ _ := Lazy;
    World@ start = @(
      gravity: Vec@(Int|0, Int|0),
      ball: @(
        pos: Vec@(Int|2, Int|2),
        vel: Vec@(Int|0, Neg(Int|2)),
        radius: Int|1),
      edges: Empty<Edge@>,
      paddles: List[
        Paddle(
          Vec@(Int|0, Int|0),
          Vec@(Int|0, Int|0),
          Vec@(Int|4, Int|0), Int|1,
          Neg(Div(Int|1, Int|4)),
          Neg(Int|1), Int|0, Int|1)
      ]);
    World@ end = Tick(start);
    Ball@ want = @(
      pos: Vec@(Int|2, Int|2),
      vel: Vec@(Int|0, Int|2),
      radius: Int|1);
    Ball@ got = end.ball;
    AssertEquals(/Pinball/Ball%.Eq, /Pinball/Ball%.Show, want, got);
  }),

  Test|'Stationary Paddle Non-Collision'({
    # The ball moves up at constant velocity away from a stationary paddle.
    # The ball starts just within range of the paddle, but that should not be
    # considered a collision because the ball is moving away from the
    # paddle.
    Unit@ _ := Lazy;
    Num@ e = Div(Int|1, Int|64);
    World@ start = @(
      gravity: Vec@(Int|0, Int|0),
      ball: @(
        pos: Vec@(Int|2, Sub(Int|1, e)),
        vel: Vec@(Int|0, Int|2),
        radius: Int|1),
      edges: Empty<Edge@>,
      paddles: List[
        Paddle(
          Vec@(Int|0, Int|0),
          Vec@(Int|0, Int|0),
          Vec@(Int|4, Int|0), Int|0, Int|0,
          Neg(Int|1), Int|1, Int|1)
      ]);
    World@ end = Tick(start);
    Ball@ want = @(
      pos: Vec@(Int|2, Sub(Int|3, e)),
      vel: Vec@(Int|0, Int|2),
      radius: Int|1);
    Ball@ got = end.ball;
    AssertEquals(/Pinball/Ball%.Eq, /Pinball/Ball%.Show, want, got);
  }),

  Test|'Moving Paddle Stationary Ball Collision'({
    # The paddle moves into a stationary ball.
    Unit@ _ := Lazy;
    World@ start = @(
      gravity: Vec@(Int|0, Int|0),
      ball: @(
        pos: Vec@(Int|2, Int|1),
        vel: Vec@(Int|0, Int|0),
        radius: Int|1),
      edges: Empty<Edge@>,
      paddles: List[
        Paddle(
          Vec@(Int|0, Int|0),
          Vec@(Int|0, Int|0),
          Vec@(Int|4, Int|0),
          Div(Int|1, Int|2),      # w = 1/2, v = 2w = 1
          Neg(Div(Int|1, Int|4)), # pos = -1/4, so it gets to 0 at time t=1/2
          Neg(Int|1), Int|1, Int|1)
      ]);
    World@ end = Tick(start);
    Ball@ want = @(
      pos: Vec@(Int|2, Int|2),
      vel: Vec@(Int|0, Int|2),
      radius: Int|1);
    Ball@ got = end.ball;

    # TODO: Test fails due to loss of precision. How should we handle this?
    Unit@ _ := ExpectFails|', but got Ball@(pos=(257/128, 262/128), vel=(2/128, 254/128)';
    AssertEquals(/Pinball/Ball%.Eq, /Pinball/Ball%.Show, want, got);
  }),

  Test|'Non-centered Paddle Ball Collision'({
    # The paddle moves into a moving ball. The start of the paddle
    # position is different from the center.
    # In this case the center of the paddle is directly below the point of
    # collision, so it's as if the ball bounced against a stationary edge in
    # terms of effects on the ball.
    Unit@ _ := Lazy;
    World@ start = @(
      gravity: Vec@(Int|0, Int|0),
      ball: @(
        pos: Vec@(Int|2, Int|2),
        vel: Vec@(Int|0, Neg(Int|2)),
        radius: Int|1),
      edges: Empty<Edge@>,
      paddles: List[
        Paddle(
          Vec@(Int|2, Neg(Int|2)),
          Vec@(Int|0, Int|0),
          Vec@(Int|4, Int|0),
          Div(Int|1, Int|2),      # w = 1/2
          Neg(Div(Int|1, Int|4)), # pos = -1/4, so it gets to 0 at time t=1/2
          Neg(Int|1), Int|1, Int|1)
      ]);
    World@ end = Tick(start);
    Ball@ want = @(
      pos: Vec@(Int|2, Int|2),
      vel: Vec@(Int|0, Int|2),
      radius: Int|1);
    Ball@ got = end.ball;

    AssertEquals(/Pinball/Ball%.Eq, /Pinball/Ball%.Show, want, got);
  }),

  Test|'Non-centered Paddle Ball Collision Away From Origin'({
    # This is the same as the previous test case, except with everything moved
    # away from the origin. Regression test for a case where we were doing
    # things relative to the origin instead of relative to the edge of
    # collision.
    Unit@ _ := Lazy;
    World@ start = @(
      gravity: Vec@(Int|0, Int|0),
      ball: @(
        pos: Vec@(Int|2, Int|22),
        vel: Vec@(Int|0, Neg(Int|2)),
        radius: Int|1),
      edges: Empty<Edge@>,
      paddles: List[
        Paddle(
          Vec@(Int|2, Int|18),
          Vec@(Int|0, Int|20),
          Vec@(Int|4, Int|20),
          Div(Int|1, Int|2),      # w = 1/2
          Neg(Div(Int|1, Int|4)), # pos = -1/4, so it gets to 0 at time t=1/2
          Neg(Int|1), Int|1, Int|1)
      ]);
    World@ end = Tick(start);
    Ball@ want = @(
      pos: Vec@(Int|2, Int|22),
      vel: Vec@(Int|0, Int|2),
      radius: Int|1);
    Ball@ got = end.ball;

    AssertEquals(/Pinball/Ball%.Eq, /Pinball/Ball%.Show, want, got);
  })
];

/Std/Test/Cli%.Run(Tests);
