
OnAscii, Str, StrE .= /Std/Char/Ascii%;
AssertEquals .= /Std/Eq/Assert%;
Lazy .= /Std/Lazy%;
List@, List .= /Std/List%;
String@ .= /Std/String%;
Lines, SplitLines .= /Std/String/Lines%;
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

Test@ Tests = TestSuite|Lines[
  Test|Lines({
    Unit@ _ := Lazy;
    String@ wnt = StrE|'hello\nthere\n';
    String@ got = Lines[Str|hello, Str|there];
    AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
  }),

  TestSuite|SplitLines[
    Test|Basic({
      Unit@ _ := Lazy;
      List@<String@> wnt = List[Str|hello, Str|there];
      List@<String@> got = SplitLines(StrE|'hello\nthere\n');
      AssertEquals(
        /Std/List/Eq%.Eq(/Std/String/Eq%.Eq),
        /Std/List/Show%.Show(/Std/String/Show%.Show),
        wnt, got);
    }),

    Test|Empty({
      Unit@ _ := Lazy;
      List@<String@> wnt = List<String@>[];
      List@<String@> got = SplitLines(Str|'');
      AssertEquals(
        /Std/List/Eq%.Eq(/Std/String/Eq%.Eq),
        /Std/List/Show%.Show(/Std/String/Show%.Show),
        wnt, got);
    }),

    Test|NoNewline({
      Unit@ _ := Lazy;
      List@<String@> wnt = List[Str|hello];
      List@<String@> got = SplitLines(Str|hello);
      AssertEquals(
        /Std/List/Eq%.Eq(/Std/String/Eq%.Eq),
        /Std/List/Show%.Show(/Std/String/Show%.Show),
        wnt, got);
    }),

    Test|Newline({
      Unit@ _ := Lazy;
      List@<String@> wnt = List[Str|''];
      List@<String@> got = SplitLines(StrE|'\n');
      AssertEquals(
        /Std/List/Eq%.Eq(/Std/String/Eq%.Eq),
        /Std/List/Show%.Show(/Std/String/Show%.Show),
        wnt, got);
    })
  ]
];

@(Tests);
