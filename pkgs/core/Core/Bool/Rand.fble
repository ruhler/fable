
@ Bool@ = /Std/Bool%.Bool@;
% Not = /Std/Bool%.Not;

@ Int@ = /Std/Int%.Int@;
% IsZero = /Std/Int/Sign%.IsZero;
% Int = /Std/Int/Lit%.Int;

<<@>@>@ RngM@ = /Core/Random/Rng%.RngM@;

# Generates a random boolean.
<<@>@ M@>(RngM@<M@>) { M@<Bool@>; }
Rand = <<@>@ M@>(RngM@<M@> rng) {
  Int@ x := rng.m.do(rng.r.rand(Int|1));
  rng.m.return $ Not(IsZero(x));
};

@(Rand);
