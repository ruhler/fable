
Concat = /Std/List%.Concat;

String@ = /Std/String%.String@;
Str = /Std/Char/Ascii%.Str;

0 = /Bit%.0;
1 = /Bit%.1;

Bit4@ = /Bit4%.Bit4@;
And = /Bit4%.And;
Show = /Bit4/Show%.Show;

Bit4@ X = Bit4@(0, 0, 1, 1);
Bit4@ Y = Bit4@(1, 0, 1, 0);
Bit4@ Z = And(X, Y);

String@ output = Concat[Show(X), Str|' AND ', Show(Y), Str|' = ', Show(Z)];

/Core/Stdio/StringO%.Run(output);
