
<@>@ Maybe@ = /Core/Maybe%.Maybe@;
<@>@ Show@ = /Core/Show%.Show@;
% Format = /Core/Char/Ascii/Output%.Format;
% String = /Core/Char/Ascii/Output%.String;


# Show --
#   Implementation of Show@ for Maybe@<T@>. See documentation of /Show%.Show@.
<@ T@>(Show@<T@>) { Show@<Maybe@<T@>>; }
Show = <@ T@>(Show@<T@> show, Maybe@<T@> m) {
  m.?(nothing: String|'Nothing');
  Format|'Just:%s'[show(m.just)];
};

@(Show);
