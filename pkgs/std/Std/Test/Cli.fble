# @module[/Std/Test/Cli%]
#  Test runner using a command line interface.

Bool@ .= /Std/Bool%;
Char@ .= /Std/Char%;
Str .= /Std/Char/Ascii%;
Io@ .= /Std/Io%;
Main@, Success, Failure .= /Std/Io/Cli%;
List@ .= /Std/List%;
Monad@ .= /Std/Monad%;
Out@ .= /Std/Stream/Io%;
String@ .= /Std/String%;
Test@ .= /Std/Test%;

# @func[Run] A cli program to run a set of tests.
#  @arg[Test@][test] The test or test suite to run.
#  @returns[Main@] A cli program that runs the test.
(Test@) { Main@; }
Run = (Test@ tests) {
  <<@>@ M@>(Monad@<M@> m, Io@<M@> io, List@<String@> args) {
    String@ prefix = {
      args.?(empty: Str|'');
      /Std/String/Eq%.Eq(Str|'--prefix', args.items.head).?(false: Str|'');
      args.items.tail.items.head;
    };

    Out@<Char@, M@> out := m.do(/Std/Io/File/Utf8%.Text.Stdout(m, io));
    Bool@ passed := m.do(/Std/Test/Run%.Run(m, out, prefix, tests));
    m.return(passed.?(true: Success, false: Failure));
  };
};

@(Run);
