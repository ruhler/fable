
<@>% AssertEquals = /Core/Eq/Assert%.AssertEquals;

@ Int@ = /Std/Int%.Int@;
% Int = /Core/Int/Lit%.Int;

% Str = /Core/Char/Ascii%.Str;

@ Test@ = /Core/Test%.Test@;
% Test = /Core/Test%.Test;
% TestSuite = /Core/Test%.TestSuite;

@ Unit@ = /Std/Unit%.Unit@;

<@>@ List@ = /Std/List%.List@;
<@>% List = /Std/List%.List;

<@>% Length = /Std/List/Index%.Length;
<@>% Get = /Std/List/Index%.Get;
<@>% Set = /Std/List/Index%.Set;
<@>% Take = /Std/List/Index%.Take;
<@>% Drop = /Std/List/Index%.Drop;
<@>% Range = /Std/List/Index%.Range;
<@>% Span = /Std/List/Index%.Span;

@ Elem@ = /Core/List/Tests/Elem%.Elem@;
% Elems = /Core/List/Tests/Elem%.Elems;
% Eq = /Core/List/Tests/Elem%.Eq;
% Show = /Core/List/Tests/Elem%.Show;
% EL = /Core/List/Tests/Elem%.EL;
% ElemEq = /Core/List/Tests/Elem%.ElemEq;
% ElemShow = /Core/List/Tests/Elem%.ElemShow;

Test@ Tests = TestSuite(Str|List, List[
  Test(Str|'Length', (Unit@ _) {
    Int@ wnt = Int|5;
    Int@ got = Length(EL|ABCDE);
    AssertEquals(/Std/Int/Eq%.Eq, /Core/Int/Show%.Show, wnt, got);
  }),

  Test(Str|Get, (Unit@ _) {
    List@<Elem@> list = EL|'ABCDE';
    Elem@ got = Get(list, Int|2);
    Elem@ wnt = Elems.C;
    AssertEquals(ElemEq, ElemShow, wnt, got);
  }),

  Test(Str|Set, (Unit@ _) {
    List@<Elem@> list = EL|'ABCDE';
    List@<Elem@> got = Set(list, Int|2, Elems.A);
    List@<Elem@> wnt = EL|'ABADE';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Take, (Unit@ _) {
    List@<Elem@> list = EL|'ABCDE';
    List@<Elem@> got = Take(list, Int|2);
    List@<Elem@> wnt = EL|'AB';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Drop, (Unit@ _) {
    List@<Elem@> list = EL|'ABCDE';
    List@<Elem@> got = Drop(list, Int|2);
    List@<Elem@> wnt = EL|'CDE';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Range, (Unit@ _) {
    List@<Elem@> list = EL|'ABCDE';
    List@<Elem@> got = Range(list, Int|1, Int|2);
    List@<Elem@> wnt = EL|'BC';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Span_span, (Unit@ _) {
    List@<Elem@> list = EL|'ABCDE';
    List@<Elem@> got = Span(list, Int|2).span;
    List@<Elem@> wnt = EL|'AB';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Span_tail, (Unit@ _) {
    List@<Elem@> list = EL|'ABCDE';
    List@<Elem@> got = Span(list, Int|2).tail;
    List@<Elem@> wnt = EL|'CDE';
    AssertEquals(Eq, Show, wnt, got);
  })
]);

@(Tests);
