
Bool@, True, False, And .= /Std/Bool%;
Str .= /Std/Char/Ascii%;
FormatE, StringE .= /Std/Char/Ascii/Output%;
Concat, ForEach .= /Std/List%;
Monad@ .= /Std/Monad%;
Out@, String .= /Std/Stream/Text%;
String@ .= /Std/String%;
Test@, TestResult@ .= /Std/Test%;
Unit@, Unit .= /Std/Unit%;

# Runs a test or test suite, outputting summary information along the way.
# Returns True if the all the tests pass, false otherwise.
<<@>@ M@>(Monad@<M@>, Out@<M@>, String@, Test@) { M@<Bool@>; }
Run = <<@>@ M@>(Monad@<M@> m, Out@<M@> out, String@ prefix, Test@ test) {
  test.?(
    case: {
      String@ name = Concat[prefix, test.case.name];
      Unit@ _ := m.do(out.put $ FormatE|'@[%s]: '[String(name)]);
      TestResult@ tr = test.case.test(Unit);
      tr.?(
        pass: {
          Unit@ _ := m.do(out.put $ StringE|'@PASS\n');
          m.return(True);
        },
        fail: {
          Unit@ _ := m.do(out.put $ FormatE|'@FAIL: %s\n'[tr.fail]);
          m.return(False);
        },
        expected_fail: {
          Unit@ _ := m.do(out.put $ StringE|'@EXPECTED_FAIL\n');
          m.return(True);
        },
        skip: {
          Unit@ _ := m.do(out.put $ FormatE|'@SKIP: %s\n'[tr.skip]);
          m.return(True);
        });
    },
    suite: {
      String@ nprefix = Concat[prefix, test.suite.name, Str|'.'];
      ForEach(test.suite.tests, m.return(True),
        (Test@ test, M@<Bool@> mp) {
          Bool@ passing := m.do(mp);
          Bool@ pass := m.do(Run(m, out, nprefix, test));
          m.return(And(passing, pass));
        });
    });
};

@(Run);
