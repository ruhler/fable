# @@fble-test@@ compile-error 12:16
Unit@ = *();

Bool@ = +(Unit@ true, Unit@ false);
Bool@ True = Bool@(true: Unit@());
Bool@ False = Bool@(false: Unit@());

Triple@ = *(Bool@ x, Bool@ y, Bool@ z);
Triple@ a = @(x: True, y: False, z: False);

# Whitespace is not allowed between '.' and '@'.
Triple@ b = a. @(y: True);

Unit@ _ = b.x.true;
Unit@ _ = b.y.true;
Unit@ _ = b.z.false;
Unit@();
