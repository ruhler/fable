
@ Bool@ = /Std/Bool%.Bool@;
% True = /Std/Bool%.True;
% False = /Std/Bool%.False;

<@>% AssertEquals = /Core/Eq/Assert%.AssertEquals;

@ Int@ = /Std/Int%.Int@;
% Int = /Std/Int/Lit%.Int;

<@>% List = /Std/List%.List;

% ToString = /Std/Char/Output%.ToString;

@ String@ = /Std/String%.String@;
% Str = /Std/Char/Ascii%.Str;

@ Test@ = /Std/Test%.Test@;
% Test = /Std/Test%.Test;
% TestSuite = /Std/Test%.TestSuite;

@ Unit@ = /Std/Unit%.Unit@;

Int@ B = Int|2;
Int@ C = Int|3;

% Map = /Core/Int/Map%.Map;
<@>@ Map@ = Map.Map@;
<@>% Empty = Map.Empty;
<@>% Insert = Map.Insert;

<@>% Show = /Core/Map/Show%.Show(Map, /Std/Int/Show%.Show);

Test@ Tests = TestSuite(Str|Show, List[
  Test(Str|'empty', (Unit@ _) {
    Map@<Bool@> map = Empty<Bool@>;
    String@ wnt = Str|'{ }';
    String@ got = ToString(Show(/Std/Bool/Show%.Show, map));
    AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
  }),

  Test(Str|'single', (Unit@ _) {
    Map@<Bool@> map = Insert(Empty<Bool@>, B, False);
    String@ wnt = Str|'{ 2 => False; }';
    String@ got = ToString(Show(/Std/Bool/Show%.Show, map));
    AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
  }),

  Test(Str|'multi', (Unit@ _) {
    Map@<Bool@> map = Insert(Insert(Empty<Bool@>, B, False), C, True);
    String@ wnt = Str|'{ 2 => False; 3 => True; }';
    String@ got = ToString(Show(/Std/Bool/Show%.Show, map));
    AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
  })
]);

@(Tests);
