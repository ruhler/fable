
Bool@ = /Std/Bool%.Bool@;
True = /Std/Bool%.True;
False = /Std/Bool%.False;

Lfsr3 = /Std/Random/Lfsr%.Lfsr3;

List@ = /Std/List%.List@;
List = /Std/List%.List;

Prng@ = /Std/Random/Prng%.Prng@;

Str = /Std/Char/Ascii%.Str;

Test@ = /Std/Test%.Test@;
TestSuite = /Std/Test%.TestSuite;
Test = /Std/Test%.Test;

AssertSequence = /Std/Random/Prng/Assert%.AssertSequence;

Unit@ = /Std/Unit%.Unit@;

Bit@ = +(Unit@ 0, Unit@ 1);

(List@<Bit@>) { List@<Bool@>; }
S = (List@<Bit@> xs) {
  Bit@ bit := /Std/List%.Map(xs);
  bit.?(0: False, 1: True);
};

Test@ Tests = TestSuite(Str|Lfsr, List[
  Test(Str|Basic, (Unit@ _) {
    # Validate the full sequence of a 3 bit LFSR.
    Prng@<List@<Bool@>> prng = Lfsr3;
    AssertSequence(
      /Std/List/Eq%.Eq(/Std/Bool/Eq%.Eq),
      /Std/List/Show%.Show(/Std/Bool/Show%.Show), prng)[
        S|010, S|101, S|011, S|111,
        S|110, S|100, S|001, S|010];
  })
]);

@(Tests);
