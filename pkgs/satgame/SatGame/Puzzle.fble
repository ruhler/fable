
Bool@ .= /Std/Bool%;
Int@ .= /Std/Int%;
List@ .= /Std/List%;

Var@ .= /SatGame/Var%;

Literal@ = *(Var@ var, Bool@ pos);
Clause@ = List@<Literal@>;
Puzzle@ = List@<Clause@>;

# Parameters describing the shape and size of a puzzle.
Params@ = *(
  Int@ num_vars,
  Int@ num_clauses,
  Int@ num_literals_per_clause
);

@(Literal@, Clause@, Puzzle@, Params@);
