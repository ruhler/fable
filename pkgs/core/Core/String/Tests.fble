
@ Bool@ = /Std/Bool%.Bool@;
% True = /Std/Bool%.True;
% False = /Std/Bool%.False;

@ Char@ = /Std/Char%.Char@;
<@>% Compose = /Std/Char/Lit%.Compose;

% Char = /Std/Char/Ascii%.Char;
% Ascii = /Std/Char/Ascii%.Ascii;

<@>% AssertEquals = /Core/Eq/Assert%.AssertEquals;

<@>@ List@ = /Std/List%.List@;
<@>% List = /Std/List%.List;

% ToString = /Std/Char/Output%.ToString;

@ String@ = /Std/String%.String@;
% Str = /Std/Char/Ascii%.Str;
% StrE = /Std/Char/Ascii%.StrE;
% Lines = /Std/String/Lines%.Lines;
% SplitLines = /Std/String/Lines%.SplitLines;

% Split = /Std/String/Eq%.Split;

@ Test@ = /Core/Test%.Test@;
% Test = /Core/Test%.Test;
% TestSuite = /Core/Test%.TestSuite;

@ Unit@ = /Std/Unit%.Unit@;

# Tests --
#  A test suite to test the /Std/String% module and friends.
Test@ Tests = TestSuite(Str|String, List[
  Test(Str|StrE, (Unit@ _) {
    String@ wnt = List[
      Char|a, Ascii.nl,
      Char|b, Ascii.tab,
      Char|c, Char|'\',
      Char|d];
    String@ got = StrE|'a\nb\tc\\d';
    AssertEquals(/Std/String/Eq%.Eq, /Core/String/Show%.Show, wnt, got);
  }),

  Test(Str|StrE_u, (Unit@ _) {
    String@ wnt = Str|'abc';
    String@ got = StrE|'a\u62;c';
    AssertEquals(/Std/String/Eq%.Eq, /Core/String/Show%.Show, wnt, got);
  }),

  Test(Str|Lines, (Unit@ _) {
    String@ wnt = StrE|'hello\nthere\n';
    String@ got = Lines[Str|'hello', Str|'there'];
    AssertEquals(/Std/String/Eq%.Eq, /Core/String/Show%.Show, wnt, got);
  }),

  Test(Str|SplitLines, (Unit@ _) {
    List@<String@> wnt = List[Str|'hello', Str|'there'];
    List@<String@> got = SplitLines(StrE|'hello\nthere\n');
    AssertEquals(
      /Std/List/Eq%.Eq(/Std/String/Eq%.Eq),
      /Std/List/Show%.Show(/Core/String/Show%.Show),
      wnt, got);
  }),

  Test(Str|SplitLines_empty, (Unit@ _) {
    List@<String@> wnt = List<String@>[];
    List@<String@> got = SplitLines(Str|'');
    AssertEquals(
      /Std/List/Eq%.Eq(/Std/String/Eq%.Eq),
      /Std/List/Show%.Show(/Core/String/Show%.Show),
      wnt, got);
  }),

  Test(Str|SplitLines_nonewline, (Unit@ _) {
    List@<String@> wnt = List[Str|'hello'];
    List@<String@> got = SplitLines(Str|'hello');
    AssertEquals(
      /Std/List/Eq%.Eq(/Std/String/Eq%.Eq),
      /Std/List/Show%.Show(/Core/String/Show%.Show),
      wnt, got);
  }),

  Test(Str|SplitLines_newline, (Unit@ _) {
    List@<String@> wnt = List[Str|''];
    List@<String@> got = SplitLines(StrE|'\n');
    AssertEquals(
      /Std/List/Eq%.Eq(/Std/String/Eq%.Eq),
      /Std/List/Show%.Show(/Core/String/Show%.Show),
      wnt, got);
  }),

  Test(Str|Eq, (Unit@ _) {
    Bool@ wnt = True;
    Bool@ got = /Std/String/Eq%.Eq(Str|'A string!', Str|'A string!');
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|Ne, (Unit@ _) {
    Bool@ wnt = False;
    Bool@ got = /Std/String/Eq%.Eq(Str|'A string!', Str|'nope');
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  TestSuite(Str|StartsWith, List[
    Test(Str|NulNul, (Unit@ _) {
      Bool@ wnt = True;
      Bool@ got = /Std/String/Eq%.StartsWith(Str|'', Str|'');
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test(Str|NulNonNul, (Unit@ _) {
      Bool@ wnt = False;
      Bool@ got = /Std/String/Eq%.StartsWith(Str|'', Str|'hello');
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test(Str|NonNulNul, (Unit@ _) {
      Bool@ wnt = True;
      Bool@ got = /Std/String/Eq%.StartsWith(Str|'hello', Str|'');
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test(Str|No, (Unit@ _) {
      Bool@ wnt = False;
      Bool@ got = /Std/String/Eq%.StartsWith(Str|'hello', Str|'there');
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test(Str|Yes, (Unit@ _) {
      Bool@ wnt = True;
      Bool@ got = /Std/String/Eq%.StartsWith(Str|'hello', Str|'hel');
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test(Str|Contains, (Unit@ _) {
      Bool@ wnt = False;
      Bool@ got = /Std/String/Eq%.StartsWith(Str|'xhello', Str|'hello');
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    })
  ]),

  TestSuite(Str|Contains, List<Test@>[
    Test(Str|NulNul, (Unit@ _) {
      Bool@ wnt = True;
      Bool@ got = /Std/String/Eq%.Contains(Str|'', Str|'');
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test(Str|NulNonNul, (Unit@ _) {
      Bool@ wnt = False;
      Bool@ got = /Std/String/Eq%.Contains(Str|'', Str|'hello');
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test(Str|NonNulNul, (Unit@ _) {
      Bool@ wnt = True;
      Bool@ got = /Std/String/Eq%.Contains(Str|'hello', Str|'');
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test(Str|No, (Unit@ _) {
      Bool@ wnt = False;
      Bool@ got = /Std/String/Eq%.Contains(Str|'hello', Str|'there');
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test(Str|Yes, (Unit@ _) {
      Bool@ wnt = True;
      Bool@ got = /Std/String/Eq%.Contains(Str|'xhello', Str|'hello');
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    })
  ]),

  Test(Str|Show, (Unit@ _) {
    String@ wnt = Str|'''hello''';
    String@ got = ToString(/Core/String/Show%.Show(Str|hello));
    AssertEquals(/Std/String/Eq%.Eq, /Core/String/Show%.Show, wnt, got);
  }),

  Test(Str|Show_quote, (Unit@ _) {
    String@ wnt = StrE|'\qdon\q\qt\q';
    String@ got = ToString(/Core/String/Show%.Show(StrE|'don\qt'));
    AssertEquals(/Std/String/Eq%.Eq, /Core/String/Show%.Show, wnt, got);
  }),

  Test(Str|Split, (Unit@ _) {
    List@<String@> wnt = List[Str|'hello', Str|'there', Str|'how', Str|'are', Str|'you?'];
    List@<String@> got = Split(Str|'hello there how are you?', Str|' ');
    AssertEquals(
      /Std/List/Eq%.Eq(/Std/String/Eq%.Eq),
      /Std/List/Show%.Show(/Core/String/Show%.Show),
      wnt, got);
  }),

  Test(Str|Compose, (Unit@ _) {
    @ Alpha@ = +(Unit@ a, Unit@ b, Unit@ c);
    (Alpha@) { Char@; } AlphaToChar = (Alpha@ a) {
      a.?(a: Char|a, b: Char|b, c: Char|c);
    };

    @ Digit@ = +(Unit@ 0, Unit@ 1, Unit@ 2);
    (Digit@) { Char@; } DigitToChar = (Digit@ a) {
      a.?(0: Char|0, 1: Char|1, 2: Char|2);
    };

    % S = /Std/Char/Lit%.Str(Compose(AlphaToChar, DigitToChar));

    String@ wnt = Str|'ab01c2';
    String@ got = S|'ab01c2';
    AssertEquals(/Std/String/Eq%.Eq, /Core/String/Show%.Show, wnt, got);
  }),

  /Core/String/Map/Tests%.Tests

]);

@(Tests);
