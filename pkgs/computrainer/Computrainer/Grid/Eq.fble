
% True = /Std/Bool%.True;
% False = /Std/Bool%.False;

<@>@ Eq@ = /Std/Eq%.Eq@;

@ Coord@ = /Computrainer/Grid%.Coord@;
<@>@ Grid@ = /Computrainer/Grid%.Grid@;
% Grid = /Computrainer/Grid%.Grid;

Eq@<Coord@> Coord = (Coord@ a, Coord@ b) {
    /Std/Int/Eq%.Eq(a.x, b.x).?(false: False);
    /Std/Int/Eq%.Eq(a.y, b.y).?(false: False);
    True;
};

<@ T@> (Eq@<T@>) { Eq@<Grid@<T@>>; } Eq = /Core/Map/Eq%.Eq<Grid@, Coord@>(Grid, Coord);

@(Eq);
