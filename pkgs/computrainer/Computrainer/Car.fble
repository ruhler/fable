
Unit@ = /Std/Unit%.Unit@;
Unit = /Std/Unit%.Unit;

Grid@ = /Computrainer/Grid%.Grid@;

Car@ = +(Unit@ C, Unit@ 0, Unit@ 1);
Car@ C = Car@(C: Unit);
Car@ 0 = Car@(0: Unit);
Car@ 1 = Car@(1: Unit);

Cars@ = Grid@<Car@>;

(Car@) { Car@; }
Rotate = (Car@ c) {
    c.?(C: 0, 0: 1, 1: C);
};

@(Car@, Cars@, 0, 1, C, Rotate);
