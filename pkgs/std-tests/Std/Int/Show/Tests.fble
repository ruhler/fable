
Ascii@ = /Std/Char/Ascii%.Ascii@;
OnAscii = /Std/Char/Ascii%.OnAscii;

AssertOutput = OnAscii $ /Std/Stream/Text/Assert%.AssertOutput;

Int@ = /Std/Int%.Int@;
Neg = /Std/Int%.Neg;
Int = /Std/Int/Lit%.Int;

List@ = /Std/List%.List@;
List = /Std/List%.List;

Test@ = /Std/Test%.Test@;
Test = OnAscii $ /Std/Test%.Test;
TestSuite = OnAscii $ /Std/Test%.TestSuite;

Unit@ = /Std/Unit%.Unit@;

(List@<Ascii@>, List@<Ascii@>, Int@) { Test@; }
TestShow = (List@<Ascii@> name, List@<Ascii@> expected, Int@ value) {
  Test(name, (Unit@ _) { AssertOutput(expected, /Std/Int/Show%.Show(value)); });
};

Test@ Tests = TestSuite|'Show' $ List[
  TestShow|P|1029384756(Int|1029384756),
  TestShow|N|'-1029384756'(Neg(Int|1029384756)),
  TestShow|0|0(Int|0)
];

@(Tests);
