
@ Bool@ = /Std/Bool%.Bool@;
% True = /Std/Bool%.True;
% False = /Std/Bool%.False;

@ Compared@ = /Std/Cmp%.Compared@;
% Less = /Std/Cmp%.Less;
% Equal = /Std/Cmp%.Equal;
% Greater = /Std/Cmp%.Greater;

<@>@ Eq@ = /Std/Eq%.Eq@;

<@>@ List@ = /Std/List%.List@;
<@>% List = /Std/List%.List;

<@>@ Show@ = /Core/Show%.Show@;

@ String@ = /Core/String%.String@;
% Str = /Core/String%.Str;

@ Unit@ = /Std/Unit%.Unit@;
% Unit = /Std/Unit%.Unit;


@ Elem@ = +(Unit@ A, Unit@ B, Unit@ C, Unit@ D, Unit@ E);

% Elems = @(
  A: Elem@(A: Unit),
  B: Elem@(B: Unit),
  C: Elem@(C: Unit),
  D: Elem@(D: Unit),
  E: Elem@(E: Unit));

(List@<Elem@>) { List@<Elem@>; } EL = List<Elem@>;

(Elem@) { String@; } ElemShow = (Elem@ e) {
  e.?(A: Str|A, B: Str|B, C: Str|C, D: Str|D, E: Str|E);
};

(Elem@, Elem@) { Compared@; } ElemCmp = (Elem@ a, Elem@ b) {
  a.?(A: b.?(A: Equal, : Less),
      B: b.?(A: Greater, B: Equal, : Less),
      C: b.?(A: Greater, B: Greater, C: Equal, : Less),
      D: b.?(A: Greater, B: Greater, C: Greater, D: Equal, E: Less),
      E: b.?(A: Greater, B: Greater, C: Greater, D: Greater, E: Equal));
};

(Elem@, Elem@) { Bool@; } ElemLe = (Elem@ a, Elem@ b) {
  a.?(A: True,
      B: b.?(A: False, : True),
      C: b.?(A: False, B: False, : True),
      D: b.?(A: False, B: False, C: False, : True),
      E: b.?(A: False, B: False, C: False, D: False, E: True));
};

(Elem@, Elem@) { Bool@; } ElemGe = (Elem@ a, Elem@ b) {
  ElemLe(b, a);
};

(Elem@, Elem@) { Bool@; } ElemEq = (Elem@ a, Elem@ b) {
  a.?(A: b.?(A: True, : False),
      B: b.?(B: True, : False),
      C: b.?(C: True, : False),
      D: b.?(D: True, : False),
      E: b.?(E: True, : False));
};

Eq@<List@<Elem@>> Eq = /Std/List/Eq%.Eq<Elem@>(ElemEq);
Show@<List@<Elem@>> Show = /Core/List/Show%.Show<Elem@>(ElemShow);

@(Elem@, EL, Eq, Show, Elems, ElemCmp, ElemEq, ElemGe, ElemShow);
