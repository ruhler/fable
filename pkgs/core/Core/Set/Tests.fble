
Bool@ = /Std/Bool%.Bool@;
True = /Std/Bool%.True;
False = /Std/Bool%.False;
And = /Std/Bool%.And;

Data@, Enum, Struct .= /Core/Data%;

Eq@ = /Std/Eq%.Eq@;
AssertEquals = /Std/Eq/Assert%.AssertEquals;
AssertNotEquals = /Std/Eq/Assert%.AssertNotEquals;

List@ = /Std/List%.List@;
List = /Std/List%.List;
Items = /Std/List%.Items;

Show@ = /Std/Show%.Show@;
ToString = /Std/Stream/String%.ToString;

Do .= /Std/Stream%;

String@ = /Std/String%.String@;
Str = /Std/Char/Ascii%.Str;
String = /Std/Char/Ascii/Stream%.String;

Test@ = /Std/Test%.Test@;
Test = /Std/Test%.Test;
TestSuite = /Std/Test%.TestSuite;

Unit@ = /Std/Unit%.Unit@;
Unit = /Std/Unit%.Unit;

Bit1@ = +(Unit@ 0, Unit@ 1);
Bit2@ = *(Bit1@ h, Bit1@ l);

Bit2@ A = Bit2@(Bit1@(0: Unit), Bit1@(0: Unit));
Bit2@ B = Bit2@(Bit1@(0: Unit), Bit1@(1: Unit));
Bit2@ C = Bit2@(Bit1@(1: Unit), Bit1@(0: Unit));

Eq@<Bit1@> EqBit1 = (Bit1@ a, Bit1@ b) {
  a.?(
    0: b.?(0: True, 1: False),
    1: b.?(0: False, 1: True));
};

Data@<Bit1@> DataBit1 = (Bit1@ x) {
  x.?(0: Enum|0, 1: Enum|1);
};

Show@<Bit1@> ShowBit1 = (Bit1@ x) {
  x.?(0: String|0, 1: String|1);
};

Eq@<Bit2@> EqBit2 = (Bit2@ a, Bit2@ b) {
  And(EqBit1(a.h, b.h), EqBit1(a.l, b.l));
};

Data@<Bit2@> DataBit2 = (Bit2@ x) {
  Struct[DataBit1(x.h), DataBit1(x.l)];
};

Show@<Bit2@> ShowBit2 = (Bit2@ x) {
  Unit@ _ := Do(ShowBit1(x.h));
  ShowBit1(x.l);
};

Set = /Core/Set%.Set(DataBit2);

Set@ = Set.Set@;
Empty = Set.Empty;
Contains = Set.Contains;
Insert = Set.Insert;
Delete = Set.Delete;
ForEach = Set.ForEach;

Eq = /Core/Set/Eq%.Eq(EqBit2);
Show = /Core/Set/Show%.Show(ShowBit2);

Test@ Tests = TestSuite(Str|Set, List[
  Test(Str|'empty', (Unit@ _) {
    Bool@ wnt = False;
    Bool@ got = Contains(Empty, B);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|'not found', (Unit@ _) {
    Set@ set = Insert(Empty, C);
    Bool@ wnt = False;
    Bool@ got = Contains(set, B);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|'found', (Unit@ _) {
    Set@ set = Insert(Insert(Insert(Empty, A), B), C);
    Bool@ wnt = True;
    Bool@ got = Contains(set, B);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|'replace', (Unit@ _) {
    Set@ set = Insert(Insert(Empty, B), B);
    Bool@ wnt = True;
    Bool@ got = Contains(set, B);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|'delete', (Unit@ _) {
    Set@ set = Delete(Insert(Empty, B), B);
    Bool@ wnt = False;
    Bool@ got = Contains(set, B);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|'foreach', (Unit@ _) {
    Set@ set = Insert(Insert(Insert(Empty, B), A), B);

    # Note: A < B, we expect the ForEach to iterate in the order A, B. Because
    # we add A to the end of the list before B, we expect the resulting list
    # to be in the order B, A.
    List@<Bit2@> wnt = List[B, A];
    List@<Bit2@> got = ForEach(set, /Std/List%.Empty<Bit2@>, Items<Bit2@>);
    AssertEquals<List@<Bit2@>>(
      /Std/List/Eq%.Eq(EqBit2),
      /Std/List/Show%.Show(ShowBit2),
      wnt, got);
  }),

  Test(Str|'Show empty', (Unit@ _) {
    Set@ set = Empty;
    String@ wnt = Str|'{ }';
    String@ got = ToString(Show(set));
    AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
  }),

  Test(Str|'Show single', (Unit@ _) {
    Set@ set = Insert(Empty, B);
    String@ wnt = Str|'{ 01; }';
    String@ got = ToString(Show(set));
    AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
  }),

  Test(Str|'Show multi', (Unit@ _) {
    Set@ set = Insert(Insert(Empty, B), C);
    String@ wnt = Str|'{ 01; 10; }';
    String@ got = ToString(Show(set));
    AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
  }),

  Test(Str|'Equals', (Unit@ _) {
    Set@ a = Insert(Insert(Empty, B), C);
    Set@ b = Insert(Insert(Empty, B), C);
    AssertEquals(Eq, Show, a, b);
  }),

  Test(Str|'Not equals', (Unit@ _) {
    Set@ a = Insert(Insert(Empty, B), C);
    Set@ b = Insert(Insert(Insert(Empty, A), B), C);
    AssertNotEquals(Eq, Show, a, b);
  })
]);

@(Tests);
