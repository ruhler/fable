

<@>% AssertEquals = /Std/Eq/Assert%.AssertEquals;

<@>% List = /Std/List%.List;

<@>@ Maybe@ = /Std/Maybe%.Maybe@;
<@>% Just = /Std/Maybe%.Just;
<@>% Nothing = /Std/Maybe%.Nothing;

<@>@ Show@ = /Std/Show%.Show@;
% ToString = /Std/Char/Output%.ToString;

@ String@ = /Std/String%.String@;
% Str = /Std/Char/Ascii%.Str;
% String = /Std/Char/Ascii/Output%.String;

@ Test@ = /Std/Test%.Test@;
% Test = /Std/Test%.Test;
% TestSuite = /Std/Test%.TestSuite;

@ Unit@ = /Std/Unit%.Unit@;
% Unit = /Std/Unit%.Unit;

# AB@ --
#   Helper type to test eq and show of Maybe@.
@ AB@ = +(Unit@ a, Unit@ b);
AB@ B = AB@(b: Unit);

# ShowAB --
#   An instance of Show@ for AB@.
Show@<AB@> ShowAB = (AB@ x) {
  x.?(a: String|a, b: String|b);
};

Show@<Maybe@<AB@>> Show = /Std/Maybe/Show%.Show(ShowAB);

# Tests --
#  A test suite to test the /Maybe% module and friends.
Test@ Tests = TestSuite(Str|Maybe, List[
  Test(Str|Show_Just, (Unit@ _) {
    String@ wnt = Str|'Just:b';
    String@ got = ToString(Show(Just(B)));
    AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
  }),

  Test(Str|Show_Nothing, (Unit@ _) {
    String@ wnt = Str|'Nothing';
    String@ got = ToString(Show(Nothing<AB@>));
    AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
  })
]);

@(Tests);
