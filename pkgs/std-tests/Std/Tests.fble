
% Str = /Std/Char/Ascii%.Str;

<@>% List = /Std/List%.List;

@ Test@ = /Std/Test%.Test@;
% TestSuite = /Std/Test%.TestSuite;

# @value[Tests] Test suite for /Std%
#  @type[Test@]
Test@ Tests = TestSuite(Str|Std, List[
  /Std/Bool/Tests%.Tests,
  /Std/List/Tests%.Tests,
  /Std/Maybe/Tests%.Tests,
  /Std/Int/Tests%.Tests,
  /Std/Unit/Tests%.Tests
]);

/Core/Test/Cli%.Run(Tests);
