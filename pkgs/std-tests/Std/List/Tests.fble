# @module[/Std/List/Tests%]
#  Tests for /Std/List%.

<@>% OnAscii = /Std/Char/Ascii%.OnAscii;

<@>@ Eq@ = /Std/Eq%.Eq@;
<@>% AssertEquals = /Std/Eq/Assert%.AssertEquals;

<@>@ List@ = /Std/List%.List@;
<@>% List = /Std/List%.List;
<@>% Items = /Std/List%.Items;
<@>% Empty = /Std/List%.Empty;
<@>% Append = /Std/List%.Append;

<@>@ Show@ = /Std/Show%.Show@;

% String = /Std/Char/Ascii/Output%.String;

@ Test@ = /Std/Test%.Test@;
% Test = OnAscii $ /Std/Test%.Test;
% TestSuite = OnAscii $ /Std/Test%.TestSuite;
% Pass = /Std/Test%.Pass;
% Fail = /Std/Test%.Fail;

@ Unit@ = /Std/Unit%.Unit@;

@ Elem@ = /Std/List/Tests/Elem%.Elem@;
% Elem = /Std/List/Tests/Elem%.Elem;
% Elems = /Std/List/Tests/Elem%.Elems;

Eq@<List@<Elem@>> ElemsEq = /Std/List/Eq%.Eq(/Std/List/Tests/Elem%.Eq);
Show@<List@<Elem@>> ElemsShow = /Std/List/Show%.Show(/Std/List/Tests/Elem%.Show);

# @value[Tests] Test suite for /Std/List%
#  @type[Test@]
Test@ Tests = TestSuite|List $ List[
  Test|Empty $ (Unit@ _) {
    Empty<Elem@>.?(items: Fail(String|'Empty is items'), empty: Pass);
  },

  Test|Items $ (Unit@ _) {
    List@<Elem@> list = Items(Elem.A, Empty<Elem@>);
    list.?(items: Pass, empty: Fail(String|'Items is empty'));
  },

  Test|Append $ (Unit@ _) {
    List@<Elem@> wnt = Elems|ABCDE;
    List@<Elem@> got = Append(Elems|ABC, Elems|DE);
    AssertEquals(ElemsEq, ElemsShow, wnt, got);
  }
];

@(Tests);
