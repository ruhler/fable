
@ Exit@ = /Core/Cli%.Exit@;
@ Int@ = /Std/Int%.Int@;
<@>@ List@ = /Std/List%.List@;
<<@>@>@ Monad@ = /Std/Monad%.Monad@;
<<@>@>@ Native@ = /Core/Native%.Native@;
@ String@ = /Std/String%.String@;

<<@>@>@ App@ = /App/App%.App@;

<<@>@>@ Main@ = <<@>@ M@>(Native@<M@>, Monad@<M@>,
  App@<M@>, Int@, Int@, List@<String@>) { M@<Exit@>; };

@(Main@);
