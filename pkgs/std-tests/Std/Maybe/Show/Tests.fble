# @module[/Std/Maybe/Show/Tests%]
#  Tests for /Std/Maybe/Show%.

Bool@, True .= /Std/Bool%;
Str, OnAscii .= /Std/Char/Ascii%;
AssertEquals .= /Std/Eq/Assert%;
Lazy .= /Std/Lazy%;
Maybe@, Just, Nothing .= /Std/Maybe%;
Show@ .= /Std/Show%;
ToString .= /Std/Stream/String%;
String@ .= /Std/String%;
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

Show@<Maybe@<Bool@>> Show = /Std/Maybe/Show%.Show(/Std/Bool/Show%.Show);

# @value[Tests] Test suite for /Std/Maybe/Show%
#  @type[Test@]
Test@ Tests = TestSuite|Show[
  TestSuite|Show[
    Test|Just({
      Unit@ _ := Lazy;
      String@ wnt = Str|'Just:True';
      String@ got = ToString(Show(Just(True)));
      AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
    }),

    Test|Nothing({
      Unit@ _ := Lazy;
      String@ wnt = Str|Nothing;
      String@ got = ToString(Show(Nothing<Bool@>));
      AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
    })
  ]
];

@(Tests);
