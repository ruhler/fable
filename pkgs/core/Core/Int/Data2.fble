
Data@, Bit@, 0, 1 .= /Core/Data2%;
Int@ .= /Std/Int%;

Data@<Int@> Data = (Int@ x)<@ S@>(S@ s)<@ R@>((S@) { R@; } r, (Bit@, S@, (S@) { R@; }) { R@; } put) {
  x.?(
    n: {
      S@ s := put(0, s);
      S@ s := put(0, s);
      /Core/Int/IntP/Data%.Data(x.n, s, r, put);
    }, 
    0: {
      S@ s := put(0, s);
      put(1, s, r);
    },
    p: {
      S@ s := put(1, s);
      /Core/Int/IntP/Data%.Data(x.p, s, r, put);
    });
};

@(Data);

