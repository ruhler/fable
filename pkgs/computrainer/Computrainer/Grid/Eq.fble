
True, False .= /Std/Bool%;
Eq@ .= /Std/Eq%;
Coord@, Grid@ .= /Computrainer/Grid%;

Eq@<Coord@> Coord = (Coord@ a, Coord@ b) {
    /Std/Int/Eq%.Eq(a.x, b.x).?(false: False);
    /Std/Int/Eq%.Eq(a.y, b.y).?(false: False);
    True;
};

<@ T@> (Eq@<T@>) { Eq@<Grid@<T@>>; } Eq = /Std/Map/Eq%.Eq(Coord);

@(Eq);
