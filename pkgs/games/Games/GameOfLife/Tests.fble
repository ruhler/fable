
OnAscii .= /Std/Char/Ascii%;
AssertEquals .= /Std/Eq/Assert%;
Int@ .= /Std/Int%;
Int .= /Std/Int/Lit%;
Lazy .= /Std/Lazy%;
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

Coord@, World@, World, EqWorld, ShowWorld, Step .= /Games/GameOfLife%;

Int@ 0 = Int|0;
Int@ 1 = Int|1;
Int@ 2 = Int|2;
Int@ 3 = Int|3;
Int@ 4 = Int|4;
Int@ 5 = Int|5;
Int@ 6 = Int|6;

Test@ Tests = TestSuite|GameOfLife[
  Test|AcornStep({
    Unit@ _ := Lazy;

    # Do a sigle step of the acorn configuration.
    # Generation 0:      Generation 1:
    #   .O.....            .......
    #   ...O...            OOO.OO.
    #   OO..OOO            ....OO.
    #   .......            .....O.
    (Int@, Int@) { Coord@; } C = (Int@ x, Int@ y) { Coord@(x, y); };

    World@ g0 = World[
      C(0, 1),
      C(1, 3),
      C(2, 0), C(2, 1), C(2, 4), C(2, 5), C(2, 6)
    ];

    World@ g1 = World[
      C(1, 0), C(1, 1), C(1, 2), C(1, 4), C(1, 5),
      C(2, 4), C(2, 5),
      C(3, 5)
    ];

    AssertEquals(EqWorld, ShowWorld, g1, Step(g0));
  })
];

@(Tests);
