
Str .= /Std/Char/Ascii%;
List .= /Std/List%;
String@ .= /Std/String%;
Test@ .= /Std/Test%;

Test .= /Games/BenchmarkGame/Game%;

String@ input = Str|
'>ONE
CTTGAACCCG
GATTC
>TWO
attBgtataR
>THREE
ccaacattac
';

String@ output = Str|
'>ONE
GAATCCGGGTTCAAG
>TWO
YTATACVAAT
>THREE
GTAATGTTGG
';

Test@ Tests = Test(
  Str|ReverseComplement,
  /Games/BenchmarkGame/ReverseComplement%.Main,
  input, List[Str|0], output);

@(Tests);
