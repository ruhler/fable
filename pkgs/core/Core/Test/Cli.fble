
@ Bool@ = /Std/Bool%.Bool@;

<@>@ Output@ = /Std/Char/Output%.Output@;
<<@>@,@>@ Put@ = /Core/Char/Stream%.Put@;

<@>@ List@ = /Std/List%.List@;

<<@>@>@ IoM@ = /Core/Io%.IoM@;

<<@>@>@ Main@ = /Core/Cli%.Main@;
% Success = /Core/Cli%.Success;
% Failure = /Core/Cli%.Failure;

@ String@ = /Std/String%.String@;
% Str = /Std/Char/Ascii%.Str;

@ Test@ = /Std/Test%.Test@;

# Run --
#   A cli program to run a set of tests.
#
# Inputs:
#   tests - the tests to run.
#
# Result:
#   A cli Main@ program to run the tests.
(Test@) { Main@; } Run = (Test@ tests) {
  <<@>@ M@>(IoM@<M@> io, List@<String@> args) {
    String@ prefix = {
      args.?(empty: Str|'');
      /Std/String/Eq%.Eq(Str|'--prefix', args.items.head).?(false: Str|'');
      args.items.tail.items.head;
    };

    Put@<M@, Output@> out := io.m.do(/Core/Stdio/FFI%.Text.Stdout(io));
    Bool@ passed := io.m.do(/Core/Test/Run%.Run<M@>(io.m, out, prefix, tests));
    io.m.return(passed.?(true: Success, false: Failure));
  };
};

@(Run);
