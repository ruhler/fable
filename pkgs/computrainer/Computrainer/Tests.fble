
<@>% AssertEquals = /Std/Eq/Assert%.AssertEquals;

@ Int@ = /Std/Int%.Int@;
% Decr = /Std/Int%.Decr;
% IsZero = /Std/Int/Sign%.IsZero;
% Int = /Std/Int/Lit%.Int;

<@>% List = /Std/List%.List;

% Str = /Std/Char/Ascii%.Str;

<@>@ Output@ = /Std/Char/Output%.Output@;
% ToString = /Std/Char/Output%.ToString;

@ Test@ = /Std/Test%.Test@;
% Test = /Std/Test%.Test;
% TestSuite = /Std/Test%.TestSuite;

@ Unit@ = /Std/Unit%.Unit@;

<@>% Entries = /Computrainer/Grid%.Entries;

% Car = /Computrainer/Car%;
@ Car@ = Car.Car@;
@ Cars@ = Car.Cars@;

% Dir = /Computrainer/Dir%;
% Gate = /Computrainer/Gate%;

@ Model@ = /Computrainer/Model%.Model@;
@ Gates@ = /Computrainer/Model%.Gates@;
% Model = /Computrainer/Model%.Model;
% Tick = /Computrainer/Model%.Tick;

(Int@, Model@) { Model@; }
TickN = (Int@ n, Model@ m) {
    IsZero(n).?(true: m);
    TickN(Decr(n), Tick(m));
};

# Do a bunch ish of ticks.
(Model@) { Model@; } Ticks = TickN(Int|20);

Test@ Tests = TestSuite(Str|Computrainer, List<Test@>[
  Test(Str|'Stop', (Unit@ _) {
    # Cars don't move out of a stop gate.
    Gates@ gates = Entries[
        @(x: Int|3, y: Int|3, v: Gate.Stop)
    ];
    Cars@ cars = Entries[
        @(x: Int|3, y: Int|3, v: Car.C)
    ];
    Model@ model = Model(gates, cars);
    Model@ wnt = Model(gates, Entries[@(x: Int|3, y: Int|3, v: Car.C)]);
    Model@ got = Ticks(model);
    AssertEquals(/Computrainer/Model/Eq%.Model, /Computrainer/Model/Show%.Model, wnt, got);
  }),

  Test(Str|'Move_C', (Unit@ _) {
    # The caboose pushes through Move gates.
    Gates@ gates = Entries[
        @(x: Int|3, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|4, y: Int|3, v: Gate.Move(Dir.Down)),
        @(x: Int|4, y: Int|2, v: Gate.Stop)
    ];
    Cars@ cars = Entries[
        @(x: Int|3, y: Int|3, v: Car.C)
    ];
    Model@ model = Model(gates, cars);
    Model@ wnt = Model(gates, Entries[@(x: Int|4, y: Int|2, v: Car.C)]);
    Model@ got = Ticks(model);
    AssertEquals(/Computrainer/Model/Eq%.Model, /Computrainer/Model/Show%.Model, wnt, got);
  }),

  Test(Str|'Move_0', (Unit@ _) {
    # Non-caboose doesn't push through Move gates.
    Gates@ gates = Entries[
        @(x: Int|3, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|4, y: Int|3, v: Gate.Move(Dir.Down)),
        @(x: Int|4, y: Int|2, v: Gate.Stop)
    ];
    Cars@ cars = Entries[
        @(x: Int|3, y: Int|3, v: Car.0)
    ];
    Model@ model = Model(gates, cars);
    Model@ wnt = Model(gates, Entries[@(x: Int|3, y: Int|3, v: Car.0)]);
    Model@ got = Ticks(model);
    AssertEquals(/Computrainer/Model/Eq%.Model, /Computrainer/Model/Show%.Model, wnt, got);
  }),

  Test(Str|'Move_C0', (Unit@ _) {
    # Caboose pushes other cars through Move gates.
    Gates@ gates = Entries[
        @(x: Int|2, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|3, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|4, y: Int|3, v: Gate.Move(Dir.Down)),
        @(x: Int|4, y: Int|2, v: Gate.Stop)
    ];
    Cars@ cars = Entries[
        @(x: Int|2, y: Int|3, v: Car.C),
        @(x: Int|3, y: Int|3, v: Car.0)
    ];
    Model@ model = Model(gates, cars);
    Model@ wnt = Model(gates, Entries[
        @(x: Int|4, y: Int|3, v: Car.C),
        @(x: Int|4, y: Int|2, v: Car.0)
    ]);
    Model@ got = Ticks(model);
    AssertEquals(/Computrainer/Model/Eq%.Model, /Computrainer/Model/Show%.Model, wnt, got);
  }),

  Test(Str|'Source', (Unit@ _) {
    Gates@ gates = Entries[
        @(x: Int|2, y: Int|3, v: Gate.Source(Car.C, Dir.Right)),
        @(x: Int|3, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|4, y: Int|3, v: Gate.Move(Dir.Down)),
        @(x: Int|4, y: Int|2, v: Gate.Stop)
    ];
    Cars@ cars = Entries<Car@>[];
    Model@ model = Model(gates, cars);
    Model@ wnt = Model(gates, Entries[
        @(x: Int|2, y: Int|3, v: Car.C),
        @(x: Int|3, y: Int|3, v: Car.C),
        @(x: Int|4, y: Int|3, v: Car.C),
        @(x: Int|4, y: Int|2, v: Car.C)
    ]);
    Model@ got = Ticks(model);
    AssertEquals(/Computrainer/Model/Eq%.Model, /Computrainer/Model/Show%.Model, wnt, got);
  }),

  Test(Str|'Sink', (Unit@ _) {
    Gates@ gates = Entries[
        @(x: Int|2, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|3, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|4, y: Int|3, v: Gate.Move(Dir.Down)),
        @(x: Int|4, y: Int|2, v: Gate.Sink)
    ];
    Cars@ cars = Entries[
        @(x: Int|2, y: Int|3, v: Car.C),
        @(x: Int|3, y: Int|3, v: Car.0)
    ];
    Model@ model = Model(gates, cars);
    Model@ wnt = Model(gates, Entries<Car@>[]);
    Model@ got = Ticks(model);
    AssertEquals(/Computrainer/Model/Eq%.Model, /Computrainer/Model/Show%.Model, wnt, got);
  }),

  Test(Str|'Dup', (Unit@ _) {
    Gates@ gates = Entries[
        @(x: Int|2, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|3, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|4, y: Int|3, v: Gate.Dup(Dir.Up, Dir.Down)),
        @(x: Int|4, y: Int|2, v: Gate.Move(Dir.Down)),
        @(x: Int|4, y: Int|1, v: Gate.Stop),
        @(x: Int|4, y: Int|4, v: Gate.Move(Dir.Up)),
        @(x: Int|4, y: Int|5, v: Gate.Stop)
    ];
    Cars@ cars = Entries[
        @(x: Int|2, y: Int|3, v: Car.C),
        @(x: Int|3, y: Int|3, v: Car.0)
    ];
    Model@ model = Model(gates, cars);
    Model@ wnt = Model(gates, Entries[
        @(x: Int|4, y: Int|2, v: Car.C),
        @(x: Int|4, y: Int|1, v: Car.0),
        @(x: Int|4, y: Int|4, v: Car.C),
        @(x: Int|4, y: Int|5, v: Car.0)
    ]);
    Model@ got = Ticks(model);
    AssertEquals(/Computrainer/Model/Eq%.Model, /Computrainer/Model/Show%.Model, wnt, got);
  }),

  Test(Str|'Dup_output_blocked', (Unit@ _) {
    # If one of the outputs is blocked, that prevents the other output from advancing.
    Gates@ gates = Entries[
        @(x: Int|2, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|3, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|4, y: Int|3, v: Gate.Dup(Dir.Up, Dir.Down)),
        @(x: Int|4, y: Int|2, v: Gate.Stop),
        @(x: Int|4, y: Int|4, v: Gate.Move(Dir.Up)),
        @(x: Int|4, y: Int|5, v: Gate.Stop)
    ];
    Cars@ cars = Entries[
        @(x: Int|2, y: Int|3, v: Car.C),
        @(x: Int|3, y: Int|3, v: Car.0)
    ];
    Model@ model = Model(gates, cars);
    Model@ wnt = Model(gates, Entries[
        @(x: Int|4, y: Int|3, v: Car.C),
        @(x: Int|4, y: Int|2, v: Car.0),
        @(x: Int|4, y: Int|4, v: Car.0)
    ]);
    Model@ got = Ticks(model);
    AssertEquals(/Computrainer/Model/Eq%.Model, /Computrainer/Model/Show%.Model, wnt, got);
  }),

  Test(Str|'Wait_forever', (Unit@ _) {
    # Engine goes to the wait gait and waits forevery.
    Gates@ gates = Entries[
        @(x: Int|3, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|4, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|5, y: Int|3, v: Gate.Wait(Dir.Right)),
        @(x: Int|6, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|7, y: Int|3, v: Gate.Stop)
    ];
    Cars@ cars = Entries[
        @(x: Int|3, y: Int|3, v: Car.C)
    ];
    Model@ model = Model(gates, cars);
    Model@ wnt = Model(gates, Entries[@(x: Int|5, y: Int|3, v: Car.C)]);
    Model@ got = Ticks(model);
    AssertEquals(/Computrainer/Model/Eq%.Model, /Computrainer/Model/Show%.Model, wnt, got);
  }),

  Test(Str|'Wait_one', (Unit@ _) {
    Gates@ gates = Entries[
        @(x: Int|4, y: Int|3, v: Gate.Source(Car.C, Dir.Right)),
        @(x: Int|5, y: Int|3, v: Gate.Wait(Dir.Right)),
        @(x: Int|6, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|7, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|8, y: Int|3, v: Gate.Stop)
    ];
    Cars@ cars = Entries[
        @(x: Int|6, y: Int|3, v: Car.0)
    ];
    Model@ model = Model(gates, cars);
    Model@ wnt = Model(gates, Entries[
        @(x: Int|4, y: Int|3, v: Car.C),
        @(x: Int|5, y: Int|3, v: Car.C),
        @(x: Int|7, y: Int|3, v: Car.C),
        @(x: Int|8, y: Int|3, v: Car.0)
    ]);
    Model@ got = Ticks(model);
    AssertEquals(/Computrainer/Model/Eq%.Model, /Computrainer/Model/Show%.Model, wnt, got);
  }),

  Test(Str|'Split', (Unit@ _) {
    Gates@ gates = Entries[
        @(x: Int|1, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|2, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|3, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|4, y: Int|3, v: Gate.Split(Dir.Up, Dir.Down)),
        @(x: Int|4, y: Int|2, v: Gate.Move(Dir.Down)),
        @(x: Int|4, y: Int|1, v: Gate.Move(Dir.Down)),
        @(x: Int|4, y: Int|0, v: Gate.Stop),
        @(x: Int|4, y: Int|4, v: Gate.Move(Dir.Up)),
        @(x: Int|4, y: Int|5, v: Gate.Move(Dir.Up)),
        @(x: Int|4, y: Int|6, v: Gate.Stop)
    ];
    Cars@ cars = Entries[
        @(x: Int|1, y: Int|3, v: Car.C),
        @(x: Int|2, y: Int|3, v: Car.0),
        @(x: Int|3, y: Int|3, v: Car.1)
    ];
    Model@ model = Model(gates, cars);
    Model@ wnt = Model(gates, Entries[
        @(x: Int|4, y: Int|4, v: Car.1),
        @(x: Int|4, y: Int|1, v: Car.C),
        @(x: Int|4, y: Int|0, v: Car.0)
    ]);
    Model@ got = Ticks(model);
    AssertEquals(/Computrainer/Model/Eq%.Model, /Computrainer/Model/Show%.Model, wnt, got);
  }),

  Test(Str|'Switch 0', (Unit@ _) {
    Gates@ gates = Entries[
        @(x: Int|1, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|2, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|3, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|4, y: Int|3, v: Gate.Switch(Dir.Up, Dir.Down)),
        @(x: Int|4, y: Int|2, v: Gate.Move(Dir.Down)),
        @(x: Int|4, y: Int|1, v: Gate.Move(Dir.Down)),
        @(x: Int|4, y: Int|0, v: Gate.Stop),
        @(x: Int|4, y: Int|4, v: Gate.Move(Dir.Up)),
        @(x: Int|4, y: Int|5, v: Gate.Move(Dir.Up)),
        @(x: Int|4, y: Int|6, v: Gate.Stop)
    ];
    Cars@ cars = Entries[
        @(x: Int|1, y: Int|3, v: Car.C),
        @(x: Int|2, y: Int|3, v: Car.1),
        @(x: Int|3, y: Int|3, v: Car.0)
    ];
    Model@ model = Model(gates, cars);
    Model@ wnt = Model(gates, Entries[
        @(x: Int|4, y: Int|4, v: Car.C),
        @(x: Int|4, y: Int|5, v: Car.1),
        @(x: Int|4, y: Int|6, v: Car.0)
    ]);
    Model@ got = Ticks(model);
    AssertEquals(/Computrainer/Model/Eq%.Model, /Computrainer/Model/Show%.Model, wnt, got);
  }),

  Test(Str|'Switch 1', (Unit@ _) {
    Gates@ gates = Entries[
        @(x: Int|1, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|2, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|3, y: Int|3, v: Gate.Move(Dir.Right)),
        @(x: Int|4, y: Int|3, v: Gate.Switch(Dir.Up, Dir.Down)),
        @(x: Int|4, y: Int|2, v: Gate.Move(Dir.Down)),
        @(x: Int|4, y: Int|1, v: Gate.Move(Dir.Down)),
        @(x: Int|4, y: Int|0, v: Gate.Stop),
        @(x: Int|4, y: Int|4, v: Gate.Move(Dir.Up)),
        @(x: Int|4, y: Int|5, v: Gate.Move(Dir.Up)),
        @(x: Int|4, y: Int|6, v: Gate.Stop)
    ];
    Cars@ cars = Entries[
        @(x: Int|1, y: Int|3, v: Car.C),
        @(x: Int|2, y: Int|3, v: Car.0),
        @(x: Int|3, y: Int|3, v: Car.1)
    ];
    Model@ model = Model(gates, cars);
    Model@ wnt = Model(gates, Entries[
        @(x: Int|4, y: Int|2, v: Car.C),
        @(x: Int|4, y: Int|1, v: Car.0),
        @(x: Int|4, y: Int|0, v: Car.1)
    ]);
    Model@ got = Ticks(model);
    AssertEquals(/Computrainer/Model/Eq%.Model, /Computrainer/Model/Show%.Model, wnt, got);
  }),

  Test(Str|'Load Save', (Unit@ _) {
    Model@ model = Ticks(/Computrainer/Sample%.Sample);
    Output@ saved = /Computrainer/Model/Save%.Model(model);
    Model@ loaded = /Computrainer/Model/Load%.Model(ToString(saved));
    Model@ wnt = model;
    Model@ got = loaded;
    AssertEquals(/Computrainer/Model/Eq%.Model, /Computrainer/Model/Show%.Model, wnt, got);
  })
]);

/Core/Stdio/IO%.Run(/Core/Test/Stdio%.Run(Tests));
