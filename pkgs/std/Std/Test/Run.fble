# @module[/Std/Test/Run%]
#  Test runner for unit tests.

Bool@, True, False, And .= /Std/Bool%;
Str .= /Std/Char/Ascii%;
FormatE, StringE .= /Std/Char/Ascii/Stream%;
Concat, ForEach .= /Std/List%;
Monad@ .= /Std/Monad%;
String .= /Std/Stream/String%;
Stream@, Out@ .= /Std/Stream/Text%;
String@ .= /Std/String%;
Test@, TestResult@ .= /Std/Test%;
Unit@, Unit .= /Std/Unit%;

# @func[Run] Runs a test or test suite.
#  @arg[<@>@][M@] Monadic type to run the tests under.
#  @arg[Monad@<M@>][m] Monad implementation.
#  @arg[Out@<M@>][out] Stream to output progress information to.
#  @arg[String@][prefix] Prefix to use for reported test names.
#  @arg[Test@][test] The test or test suite to run.
#  @returns[M@<Bool@>] True if all tests pass, false otherwise.
<<@>@ M@>(Monad@<M@>, Out@<M@>, String@, Test@) { M@<Bool@>; }
Run = <<@>@ M@>(Monad@<M@> m, Out@<M@> out, String@ prefix, Test@ test) {
  test.?(
    case: {
      String@ name = Concat[prefix, test.case.name];
      Unit@ _ := m.do(out $ FormatE|'@[%s]: '[String(name)]);

      TestResult@ tr = test.case.test(Unit);

      (Bool@, Stream@) { M@<Bool@>; }
      Return = (Bool@ result, Stream@ output) { 
        Unit@ _ := m.do(out(output));
        m.return(result);
      };

      tr.?(
        pass: Return(True, StringE|'@PASS\n'),
        fail: Return(False, FormatE|'@FAIL: %s\n'[tr.fail]),
        expected_fail: Return(True, StringE|'@EXPECTED_FAIL\n'),
        skip: Return(True, FormatE|'@SKIP: %s\n'[tr.skip]));
    },
    suite: {
      String@ name = Concat[prefix, test.suite.name, Str|'.'];
      ForEach(test.suite.tests, m.return(True),
        (Test@ test, M@<Bool@> mp) {
          Bool@ passing := m.do(mp);
          Bool@ pass := m.do(Run(m, out, name, test));
          m.return(And(passing, pass));
        });
    });
};

@(Run);
