
False = /Std/Bool%.False;

Eq@ = /Std/Eq%.Eq@;

ToString = /Std/Stream/Text%.ToString;

Result@ = /Fbld/Result%.Result@;

<@ T@>(Eq@<T@>) { Eq@<Result@<T@>>; }
Eq = <@ T@>(Eq@<T@> eq, Result@<T@> a, Result@<T@> b) {
  /Std/String/Eq%.Eq(ToString(a.errors), ToString(b.errors)).?(false: False);
  /Std/Bool/Eq%.Eq(a.failed, b.failed).?(false: False);
  /Std/Maybe/Eq%.Eq(eq, a.value, b.value);
};

@(Eq);
