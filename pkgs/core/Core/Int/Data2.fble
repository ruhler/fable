
Data@, Bit@, 0, 1 .= /Core/Data2%;
Int@ .= /Std/Int%;

Data@<Int@> Data = (Int@ x)<@ S@>(S@ base, (Bit@, S@) { S@; } body) {
  x.?(
    n: /Core/Int/IntP/Data%.Data(x.n, body(0, body(0, base)), body),
    0: body(1, body(0, base)),
    p: /Core/Int/IntP/Data%.Data(x.p, body(0, body(1, base)), body));
};

@(Data);

