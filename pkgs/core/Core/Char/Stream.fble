
Char@ .= /Std/Char%;

# Character input stream.
#   Get's the next character in the input stream. Gets nothing if the end of
#   the stream has been reached.
# TODO: Reuse Get@ if/when the type inference issue is worked out.
# In@ = <<@>@ M@> { Get@<M@, Maybe@<Char@>>; };
In@ = /Std/Stream%.In@<Char@>;

# Character output stream.
Out@ = /Std/Stream%.Out@<Char@>;

@(In@, Out@);
