
<<@>@,@>@ Map@ = /Core/Map%.Map@;

<@>@ Show@ = /Core/Show%.Show@;
<@>@ ShowM@ = /Core/Show%.ShowM@;
% Do = /Core/Show%.Do;

% Format = /Core/Char/Ascii/Show%.Format;
% String = /Core/Char/Ascii/Show%.String;

@ Unit@ = /Std/Unit%.Unit@;

# Show --
#   Implementation of Show@ for Set@<T@>. See documentation of
#   /Core/Show%.Show@.
#
#   { }
#   { a; }
#   { a; b; }
#
<<@>@, @>% Show = <<@>@ M@, @ K@>(Map@<M@, K@> m, Show@<K@> show_key) {
  % S = /Core/Set%.Set(m);

  Show@<S.Set@> show = (S.Set@ s) {
    Unit@ _ <- Do(S.ForEach(s, String|'{ ',
      (K@ x, ShowM@ shown) {
        Unit@ _ <- Do(shown);
        Format|'%s; '[show_key(x)];
      }));
    String|'}';
  };

  show;
};

@(Show);
