
@ Bool@ = /Std/Bool%.Bool@;
% True = /Std/Bool%.True;
% False = /Std/Bool%.False;

@ Char@ = /Std/Char%.Char@;

<@>@ Eq@ = /Std/Eq%.Eq@;
<@>% AssertEquals = /Std/Eq/Assert%.AssertEquals;

<@>% List = /Std/List%.List;
<@>% Tail = /Std/List%.Tail;
<@>% Append = /Std/List%.Append;

<@>@ Maybe@ = /Std/Maybe%.Maybe@;
<@>% Just = /Std/Maybe%.Just;
<@>% Nothing = /Std/Maybe%.Nothing;
<@>% Get = /Std/Maybe%.Get;
<@>% JustGet = /Std/Maybe%.JustGet;
<@>% Default = /Std/Maybe%.Default;
<@>% ForEach = /Std/Maybe%.ForEach;
<@>% IsJust = /Core/Maybe/Eq%.IsJust;
<@>% IsNothing = /Core/Maybe/Eq%.IsNothing;

<@>@ Show@ = /Std/Show%.Show@;
% ToString = /Std/Char/Output%.ToString;

@ String@ = /Std/String%.String@;
% Str = /Std/Char/Ascii%.Str;
% String = /Std/Char/Ascii/Output%.String;

@ Test@ = /Std/Test%.Test@;
% Test = /Std/Test%.Test;
% TestSuite = /Std/Test%.TestSuite;

@ Unit@ = /Std/Unit%.Unit@;
% Unit = /Std/Unit%.Unit;

# AB@ --
#   Helper type to test eq and show of Maybe@.
@ AB@ = +(Unit@ a, Unit@ b);
AB@ A = AB@(a: Unit);
AB@ B = AB@(b: Unit);

# EqAB --
#   An instance of Eq@ for AB@.
Eq@<AB@> EqAB = (AB@ x, AB@ y) {
  x.?(a: y.?(a: True, b: False), b: y.?(a: False, b: True));
};

# ShowAB --
#   An instance of Show@ for AB@.
Show@<AB@> ShowAB = (AB@ x) {
  x.?(a: String|a, b: String|b);
};

Eq@<Maybe@<AB@>> Eq = /Core/Maybe/Eq%.Eq(EqAB);
Show@<Maybe@<AB@>> Show = /Core/Maybe/Show%.Show(ShowAB);

# Tests --
#  A test suite to test the /Maybe% module and friends.
Test@ Tests = TestSuite(Str|Maybe, List[
  Test(Str|'GetFromJust', (Unit@ _) {
    String@ wnt = Str|Just; 
    String@ got = Get(Str|Default, Just(Str|Just));
    AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
  }),

  Test(Str|'GetFromNothing', (Unit@ _) {
    String@ wnt = Str|Default; 
    String@ got = Get(Str|Default, Nothing<String@>);
    AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
  }),

  Test(Str|'JustGet', (Unit@ _) {
    String@ wnt = Str|Just; 
    String@ got = JustGet(Just(Str|Just));
    AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
  }),

  Test(Str|'DefaultFromJust', (Unit@ _) {
    String@ wnt = Str|BCD; 
    String@ got = Default(Str|Default, Just(Str|'ABCD'), Tail<Char@>);
    AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
  }),

  Test(Str|'DefaultFromNothing', (Unit@ _) {
    String@ wnt = Str|Default; 
    String@ got = Default(Str|Default, Nothing<String@>, Tail<Char@>);
    AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
  }),

  Test(Str|'ForEachFromJust', (Unit@ _) {
    String@ wnt = Str|ABCD; 
    String@ got = ForEach(Just(Str|'AB'), Str|'CD',
      (String@ str, String@ base) { Append(str, base); });
    AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
  }),

  Test(Str|'ForEachFromNothing', (Unit@ _) {
    String@ wnt = Str|Default; 
    String@ got = ForEach(Nothing<String@>, Str|Default,
      (String@ str, String@ _) { str; });
    AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
  }),

  Test(Str|IsJust_Yes, (Unit@ _) {
    Bool@ wnt = True;
    Bool@ got = IsJust(Just(A));
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|IsJust_No, (Unit@ _) {
    Bool@ wnt = False;
    Bool@ got = IsJust(Nothing<AB@>);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|IsNothing_Yes, (Unit@ _) {
    Bool@ wnt = True;
    Bool@ got = IsNothing(Nothing<AB@>);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|IsNothing_No, (Unit@ _) {
    Bool@ wnt = False;
    Bool@ got = IsNothing(Just(A));
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|Eq_JustEq, (Unit@ _) {
    Bool@ wnt = True;
    Bool@ got = Eq(Just(A), Just(A));
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|Eq_JustNe, (Unit@ _) {
    Bool@ wnt = False;
    Bool@ got = Eq(Just(A), Just(B));
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|Eq_JustNothing, (Unit@ _) {
    Bool@ wnt = False;
    Bool@ got = Eq(Just(A), Nothing<AB@>);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|Eq_Nothing, (Unit@ _) {
    Bool@ wnt = True;
    Bool@ got = Eq(Nothing<AB@>, Nothing<AB@>);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|Show_Just, (Unit@ _) {
    String@ wnt = Str|'Just:b';
    String@ got = ToString(Show(Just(B)));
    AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
  }),

  Test(Str|Show_Nothing, (Unit@ _) {
    String@ wnt = Str|'Nothing';
    String@ got = ToString(Show(Nothing<AB@>));
    AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
  })
]);

@(Tests);
