
True, False .= /Std/Bool%;
OnAscii .= /Std/Char/Ascii%;
Format .= /Std/Char/Ascii/Stream%;
Eq@ .= /Std/Eq%;
AssertEquals .= /Std/Eq/Assert%;
Lazy .= /Std/Lazy%;
Maybe@, Just, Nothing .= /Std/Maybe%;
Show@ .= /Std/Show%;
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

Neg, Int .= /Pinball/Num%;
Quadratic@, Roots@, Roots .= /Pinball/Quadratic%;

Eq@<Roots@> EqRoots = (Roots@ a, Roots@ b) {
  /Pinball/Num%.Eq(a.first, b.first).?(false: False);
  /Pinball/Num%.Eq(a.second, b.second).?(false: False);
  True;
};

Show@<Roots@> ShowRoots = (Roots@ r) {
  Format|'(%s,%s)'[/Pinball/Num%.Show(r.first), /Pinball/Num%.Show(r.second)];
};

Test@ Tests = TestSuite|Quadratic[
  Test|'Roots Basic'({
    # Roots of (x - 4) * (x - 2) should be 2 and 4.
    # x^2 - 6x + 8
    Unit@ _ := Lazy;
    Quadratic@ q = Quadratic@(Int|1, Neg(Int|6), Int|8);
    Maybe@<Roots@> want = Just(Roots@(Int|2, Int|4));
    Maybe@<Roots@> got = Roots(q);
    AssertEquals(
      /Std/Maybe/Eq%.Eq(EqRoots), /Std/Maybe/Show%.Show(ShowRoots),
      want, got);
  }),

  Test|'Roots Same'({
    # Roots of (x - 2) * (x - 2) should be 2 and 2.
    # x^2 - 4x + 4
    Unit@ _ := Lazy;
    Quadratic@ q = Quadratic@(Int|1, Neg(Int|4), Int|4);
    Maybe@<Roots@> want = Just(Roots@(Int|2, Int|2));
    Maybe@<Roots@> got = Roots(q);
    AssertEquals(
      /Std/Maybe/Eq%.Eq(EqRoots), /Std/Maybe/Show%.Show(ShowRoots),
      want, got);
  }),

  Test|'Roots None'({
    # x^2 + 1 has no roots.
    Unit@ _ := Lazy;
    Quadratic@ q = Quadratic@(Int|1, Int|0, Int|1);
    Maybe@<Roots@> want = Nothing<Roots@>;
    Maybe@<Roots@> got = Roots(q);
    AssertEquals(
      /Std/Maybe/Eq%.Eq(EqRoots), /Std/Maybe/Show%.Show(ShowRoots),
      want, got);
  }),

  Test|'Roots Linear'({
    # (x-1), we'll have two roots, 1 and 1?
    Unit@ _ := Lazy;
    Quadratic@ q = Quadratic@(Int|0, Int|1, Neg(Int|1));
    Maybe@<Roots@> want = Just(Roots@(Int|1, Int|1));
    Maybe@<Roots@> got = Roots(q);
    AssertEquals(
      /Std/Maybe/Eq%.Eq(EqRoots), /Std/Maybe/Show%.Show(ShowRoots),
      want, got);
  }),

  Test|'Roots Constant'({
    # 1 has no roots.
    Unit@ _ := Lazy;
    Quadratic@ q = Quadratic@(Int|0, Int|0, Int|1);
    Maybe@<Roots@> want = Nothing<Roots@>;
    Maybe@<Roots@> got = Roots(q);
    AssertEquals(
      /Std/Maybe/Eq%.Eq(EqRoots), /Std/Maybe/Show%.Show(ShowRoots),
      want, got);
  })
];

@(Tests);
