
In@, Out@ .= /Std/Io/Stream/Text%;
String .= /Std/Stream/Text%;
GetText = /Core/Char/Stream/IStream%.GetText;

Int@ = /Std/Int%.Int@;

Int = /Std/Int/Lit%.Int;

List@ = /Std/List%.List@;
Append = /Std/List%.Append;
Any = /Std/List/Search%.Any;

Maybe@ = /Std/Maybe%.Maybe@;

Monad@ = /Std/Monad%.Monad@;
Io@ = /Std/Io%.Io@;

Success = /Std/Io/Cli%.Success;

String@ = /Std/String%.String@;
Str = /Std/Char/Ascii%.Str;

Unit@ = /Std/Unit%.Unit@;
Unit = /Std/Unit%.Unit;

App@ = /App/App%.App@;

Main@ = /App/Native%.Main@;

Put@ = /Invaders/App%.Put@;
Get@ = /Invaders/App%.Get@;
State@ = /Invaders/App%.State@;
Invaders = /Invaders/App%.Invaders;

Main@ Main = <<@>@ M@>(Monad@<M@> m, Io@<M@> io, App@<M@> app, Int@ width, Int@ height, List@<String@> args) {
	Maybe@<String@> home := m.do(/Std/Io/Env%.GetVar(m, io, Str|'HOME'));
  Out@<M@> out := m.do(/Std/Io/File/Text%.Stdout(m, io));
  (String@) { M@<Maybe@<In@<M@>>>; } read = /Std/Io/File/Text%.Read(m, io);
  (String@) { M@<Maybe@<Out@<M@>>>; } write = /Std/Io/File/Text%.Write(m, io);

  Any(args, /Std/String/Eq%.Eq(Str|'--help')).?(true: {
    Unit@ _ := m.do(out.put $ String $ /Invaders/Usage%);
    m.return(Success);
  });

  Get@<M@, Int@> get_high_score = {
    home.?(nothing: m.return(Int|0));

    String@ filename = Append(home.just, Str|'/.fble-invaders');
    Maybe@<In@<M@>> istream := m.do(read(filename));
    istream.?(nothing: m.return(Int|0));

    String@ text := m.do(GetText(istream.just, m));
    m.return(/Core/Int/Read%.Read(text));
  };

  Put@<M@, Int@> put_high_score = (Int@ score) {
    home.?(nothing: m.return(Unit));

    String@ filename = Append(home.just, Str|'/.fble-invaders');
    Maybe@<Out@<M@>> ostream := m.do(write(filename));
    ostream.?(nothing: m.return(Unit));

    Unit@ _ := m.do(ostream.just.put $ /Std/Int/Show%.Show(score));
    ostream.just.end;
  };

  State@<M@, Int@> high_score_s = State@<M@, Int@>(get_high_score, put_high_score);

  Unit@ _ := m.do(Invaders(m, high_score_s, app, width, height));
  m.return(Success);
};

Main;
