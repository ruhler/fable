
@ Bool@ = /Std/Bool%.Bool@;
% True = /Std/Bool%.True;
% False = /Std/Bool%.False;
% Not = /Std/Bool%.Not;
% And = /Std/Bool%.And;
% Or = /Std/Bool%.Or;

@ Ascii@ = /Std/Char/Ascii%.Ascii@;
<@>% OnAscii = /Std/Char/Ascii%.OnAscii;
% String = /Std/Char/Ascii/Output%.String;

<@>% AssertEquals = /Std/Eq/Assert%.AssertEquals;

<@>@ List@ = /Std/List%.List@;
<@>% List = /Std/List%.List;

@ Test@ = /Std/Test%.Test@;
% Test = OnAscii $ /Std/Test%.Test;
% TestSuite = OnAscii $ /Std/Test%.TestSuite;
% Pass = /Std/Test%.Pass;
% Fail = /Std/Test%.Fail;

@ Unit@ = /Std/Unit%.Unit@;

(List@<Ascii@>, (Bool@) { Bool@; }, Bool@, Bool@) { Test@; }
Unary = (List@<Ascii@> name, (Bool@) { Bool@; } f, Bool@ a, Bool@ z) {
  Test(name, (Unit@ _) {
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, z, f(a));
  });
};

(List@<Ascii@>, (Bool@, Bool@) { Bool@; }, Bool@, Bool@, Bool@) { Test@; }
Binary = (List@<Ascii@> name, (Bool@, Bool@) { Bool@; } f, Bool@ a, Bool@ b, Bool@ z) {
  Test(name, (Unit@ _) {
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, z, f(a, b));
  });
};

# @value[Tests] Test suite for /Std/Bool%
#  @type[Test@]
Test@ Tests = TestSuite|Bool $ List[
  Test|True $ (Unit@ _) {
    True.?(true: Pass, false: Fail(String|'True is false'));
  },

  Test|False $ (Unit@ _) {
    False.?(true: Fail(String|'False is true'), false: Pass);
  },

  TestSuite|Not $ List[
    Unary|T(Not, True, False),
    Unary|F(Not, False, True)
  ],

  TestSuite|And $ List[
    Binary|FF(And, False, False, False),
    Binary|FT(And, False, True, False),
    Binary|TF(And, True, False, False),
    Binary|TT(And, True, True, True)
  ],

  TestSuite|Or $ List[
    Binary|FF(Or, False, False, False),
    Binary|FT(Or, False, True, True),
    Binary|TF(Or, True, False, True),
    Binary|TT(Or, True, True, True)
  ],

  /Std/Bool/Eq/Tests%.Tests,
  /Std/Bool/Show/Tests%.Tests
];

@(Tests);
