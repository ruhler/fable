
Format .= /Std/Char/Ascii/Stream%;
Int@ .= /Std/Int%;
List@, Items .= /Std/List%;
Length .= /Std/List/Index%;
Maybe@ .= /Std/Maybe%;
Unit@, Unit .= /Std/Unit%;

Markup@, Command@, Impl@, Append, Empty .= /Fbld/Markup%;
Env@ = /Fbld/Env%.Env@<Impl@>;
Lookup = /Fbld/Env%.Lookup<Impl@>;
Result@, Error, Try, r(.Monad) .= /Fbld/Result%;

(Env@, Markup@) { Result@<Markup@>; }
Eval = (Env@ env, Markup@ markup) {
  markup.?(
    empty: r.return(markup),
    plain: r.return(markup),
    command: {
      Command@ cmd = markup.command;
      Maybe@<Impl@> impl = {
        cmd.impl.?(just: cmd.impl);
        Lookup(env, cmd.name.text);
      };
      impl.?(nothing: r.return(markup));
      impl.just(env, cmd);
    },
    sequence: {
      Markup@ a := r.do(Try(Eval(env, markup.sequence.a), Empty));
      Markup@ b := r.do(Try(Eval(env, markup.sequence.b), Empty));
      r.return(Append(a, b));
    });
};

(Env@, List@<Markup@>) { Result@<List@<Markup@>>; }
Evals = (Env@ env, List@<Markup@> markups) {
  markups.?(empty: r.return(markups));
  Markup@ head := r.do(Eval(env, markups.items.head));
  List@<Markup@> tail := r.do(Evals(env, markups.items.tail));
  r.return(Items(head, tail));
};

# Helper function to assert that a command has been provided with the given
# number of arguments.
(Int@, Command@) { Result@<Unit@>; }
AssertArgCount = (Int@ expected, Command@ cmd) {
  Int@ num_args = Length(cmd.args);
  /Std/Int/Eq%.Eq(num_args, expected).?(false: {
    Error<Unit@>(cmd.name.loc,
      Format|'Expected %s arguments to %s, but found %s'[
        /Std/Int/Show%.Show(expected),
        /Std/Stream/String%.String(cmd.name.text),
        /Std/Int/Show%.Show(num_args)]);
  });
  r.return(Unit);
}; 


@(Eval, Evals, AssertArgCount);
