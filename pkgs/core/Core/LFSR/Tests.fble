
@ Bit@ = /Core/Digits%.Bit@;
% BitStr = /Core/Digits/String%.BitStr;

<@>% AssertEquals = /Std/Eq/Assert%.AssertEquals;

@ Int@ = /Std/Int%.Int@;
% Sub = /Std/Int%.Sub;
% Int = /Std/Int/Lit%.Int;
% IsZero = /Std/Int/Sign%.IsZero;

@ LFSR@ = /Core/LFSR%.LFSR@;
<@>@ Shifted@ = /Core/LFSR%.Shifted@;
% Shift = /Core/LFSR%.Shift;

<@>@ List@ = /Std/List%.List@;
<@>% List = /Std/List%.List;
<@>% Items = /Std/List%.Items;
<@>% Empty = /Std/List%.Empty;

% Str = /Std/Char/Ascii%.Str;

@ Test@ = /Std/Test%.Test@;
% TestSuite = /Std/Test%.TestSuite;
% Test = /Std/Test%.Test;

@ Unit@ = /Std/Unit%.Unit@;

(LFSR@, Int@) { List@<Bit@>; }
ShiftN = (LFSR@ lfsr, Int@ n) {
  IsZero(n).?(true: Empty<Bit@>);
  Shifted@<Bit@> shifted = Shift(lfsr);
  Items(shifted.output, ShiftN(shifted.lfsr, Sub(n, Int|1)));
};

Test@ Tests = TestSuite(Str|LFSR, List[
  Test(Str|Basic, (Unit@ _) {
    # A 3 bit LFSR.
    LFSR@ lfsr = LFSR@(BitStr|110, BitStr|000);
    List@<Bit@> got = ShiftN(lfsr, Int|16);
    List@<Bit@> wnt = BitStr|0001101000110100;
    AssertEquals(
      /Std/List/Eq%.Eq(/Core/Digits/Eq%.EqBit),
      /Core/Digits/Show%.ShowBits, wnt, got);
  })
]);

@(Tests);
