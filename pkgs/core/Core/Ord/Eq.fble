
% True = /Std/Bool%.True;
% False = /Std/Bool%.False;

<@>@ Eq@ = /Std/Eq%.Eq@;

@ Ordering@ = /Core/Ord%.Ordering@;

Eq@<Ordering@> Eq = (Ordering@ a, Ordering@ b) {
  a.?(
    less: b.?(less: True, : False),
    equal: b.?(equal: True, : False),
    greater: b.?(greater: True, : False));
};

@(Eq);
