Unit@ = *();
Unit = Unit@();

# The type of True should be Bool@, not Unit@.
Bool@, Unit@ True, False .= {
  Bool@ = +(Unit@ true, Unit@ false);
  True = Bool@(true: Unit);
  False = Bool@(false: Unit);

  @(Bool@, True, False);
};

(Bool@) { Bool@; } Not = (Bool@ x) {
  x.?(true: False, false: True);
};

Not(False).true;
