
Data@, Bit@, 0, 1 .= /Core/Data2%;
IntP@ .= /Std/Int/IntP%;

Data@<IntP@> Data = (IntP@ x)<@ S@>(S@ s)<@ R@>((S@) { R@; } r, (Bit@, S@, (S@) { R@; }) { R@; } put) {
  x.?(1: {
      S@ s := put(0, s);
      put(0, s, r);
    },
    2p0: {
      S@ s := put(0, s);
      S@ s := put(1, s);
      Data(x.2p0, s, r, put);
    },
    2p1: {
      S@ s := put(1, s);
      Data(x.2p1, s, r, put);
    });
};

@(Data);
