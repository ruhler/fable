
Str, OnAscii .= /Std/Char/Ascii%;
AssertEquals .= /Std/Eq/Assert%;
Int@, Neg .= /Std/Int%;
Int .= /Std/Int/Lit%;
Parse = /Std/Int/Parse%;
Lazy .= /Std/Lazy%;
Maybe@, Just, Nothing .= /Std/Maybe%;
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

Test@ Tests = TestSuite|Parse[
  TestSuite|Int[
    Test|Positive({
      Unit@ _ := Lazy;
      Maybe@<Int@> wnt = Just(Int|49113);
      Maybe@<Int@> got = Parse.Int(Str|49113);
      AssertEquals(
        /Std/Maybe/Eq%.Eq(/Std/Int/Eq%.Eq),
        /Std/Maybe/Show%.Show(/Std/Int/Show%.Show),
        wnt, got);
    }),

    Test|PlusSign({
      Unit@ _ := Lazy;
      Maybe@<Int@> wnt = Just(Int|49113);
      Maybe@<Int@> got = Parse.Int(Str|'+49113');
      AssertEquals(
        /Std/Maybe/Eq%.Eq(/Std/Int/Eq%.Eq),
        /Std/Maybe/Show%.Show(/Std/Int/Show%.Show),
        wnt, got);
    }),

    Test|Negative({
      Unit@ _ := Lazy;
      Maybe@<Int@> wnt = Just(Neg(Int|49113));
      Maybe@<Int@> got = Parse.Int(Str|'-49113');
      AssertEquals(
        /Std/Maybe/Eq%.Eq(/Std/Int/Eq%.Eq),
        /Std/Maybe/Show%.Show(/Std/Int/Show%.Show),
        wnt, got);
    }),

    Test|AllDigits({
      Unit@ _ := Lazy;
      Maybe@<Int@> wnt = Just(Int|1234567890);
      Maybe@<Int@> got = Parse.Int(Str|1234567890);
      AssertEquals(
        /Std/Maybe/Eq%.Eq(/Std/Int/Eq%.Eq),
        /Std/Maybe/Show%.Show(/Std/Int/Show%.Show),
        wnt, got);
    }),

    Test|Empty({
      Unit@ _ := Lazy;
      Maybe@<Int@> wnt = Nothing<Int@>;
      Maybe@<Int@> got = Parse.Int(Str|'');
      AssertEquals(
        /Std/Maybe/Eq%.Eq(/Std/Int/Eq%.Eq),
        /Std/Maybe/Show%.Show(/Std/Int/Show%.Show),
        wnt, got);
    }),

    Test|NonDigits({
      Unit@ _ := Lazy;
      Maybe@<Int@> wnt = Nothing<Int@>;
      Maybe@<Int@> got = Parse.Int(Str|'1a4f');
      AssertEquals(
        /Std/Maybe/Eq%.Eq(/Std/Int/Eq%.Eq),
        /Std/Maybe/Show%.Show(/Std/Int/Show%.Show),
        wnt, got);
    })
  ],

  Test|Radix({
    Unit@ _ := Lazy;
    Maybe@<Int@> wnt = Just(Neg(Int|1587));
    Maybe@<Int@> got = Parse.Radix(Int|18, Str|'-4g3');
    AssertEquals(
      /Std/Maybe/Eq%.Eq(/Std/Int/Eq%.Eq),
      /Std/Maybe/Show%.Show(/Std/Int/Show%.Show),
      wnt, got);
  })
];

@(Tests);
