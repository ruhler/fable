
AssertEquals = /Std/Eq/Assert%.AssertEquals;

List = /Std/List%.List;

Str = /Std/Char/Ascii%.Str;

StringE .= /Std/Char/Ascii/Stream%;
ToDebug .= /Std/Stream/Debug%;
ToNull .= /Std/Stream/Null%;

Test@ = /Std/Test%.Test@;
Test = /Std/Test%.Test;
TestSuite = /Std/Test%.TestSuite;

Unit@ = /Std/Unit%.Unit@;
Unit = /Std/Unit%.Unit;

# Tests --
#  A test suite to test the /Core/Debug% module.
Test@ Tests = TestSuite(Str|Debug, List[
  Test(Str|'Debug', (Unit@ _) {
    # All we can really do is test that it doesn't crash. There's no way
    # to observe the traced output from within fble.
    Unit@ u = ToDebug(StringE|'hello trace!\n');
    AssertEquals(/Std/Unit/Eq%.Eq, /Std/Unit/Show%.Show, Unit, u);
  }),

  Test(Str|'Disabled', (Unit@ _) {
    # Assuming we run this in a testsuite that looks specially for @FAILED,
    # this should at least test we aren't printing that out.
    Unit@ u = ToNull(StringE|'@FAIL: no output expected\n');
    AssertEquals(/Std/Unit/Eq%.Eq, /Std/Unit/Show%.Show, Unit, u);
  })
]);

@(Tests);
