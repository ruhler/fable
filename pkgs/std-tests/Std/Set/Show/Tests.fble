
OnAscii .= /Std/Char/Ascii%;
Int .= /Std/Int/Lit%;
Lazy .= /Std/Lazy%;
AssertStream = OnAscii(/Std/Stream/String/Assert%.AssertStream);
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

Set@, Set .= /Std/Set%.Of(/Std/Int/Data%.Data);
Show = /Std/Set/Show%.Show(/Std/Int/Show%.Show);

Test@ Tests = TestSuite|Show[
  Test|Empty({
    Unit@ _ := Lazy;
    Set@ map = Set[];
    AssertStream|'{ }'(Show(map));
  }),

  Test|Single({
    Unit@ _ := Lazy;
    Set@ map = Set[Int|2];
    AssertStream|'{ 2; }'(Show(map));
  }),

  Test|Multi({
    Unit@ _ := Lazy;
    Set@ map = Set[Int|2, Int|3];
    AssertStream|'{ 2; 3; }'(Show(map));
  })
];

@(Tests);
