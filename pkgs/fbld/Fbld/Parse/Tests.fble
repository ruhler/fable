
Ascii@, OnAscii, Str, StrE .= /Std/Char/Ascii%;
String .= /Std/Char/Ascii/Stream%;
AssertEquals .= /Std/Eq/Assert%;
IntLit@ .= /Std/Int/Lit%;
Lazy .= /Std/Lazy%;
List@, Concat .= /Std/List%;
String@ .= /Std/String%;
Lines = /Std/String/Lines%.Lines;
Test@, TestResult@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

Loc@ .= /Fbld/Loc%;
Markup@, Command, Plain, M(.Markups) .= /Fbld/Markup%;
Parse .= /Fbld/Parse%;
Result@, Ok, Error .= /Fbld/Result%;
Text@ .= /Fbld/Text%;

(IntLit@, IntLit@) { Loc@; }
L = (IntLit@ line, IntLit@ col) {
  Loc@(Str|'foo.fbld', /Std/Int/Lit%.Int(line), /Std/Int/Lit%.Int(col));
};

(IntLit@, IntLit@, List@<Ascii@>, List@<Markup@>) { Markup@; }
C = (IntLit@ line, IntLit@ col, List@<Ascii@> name, List@<Markup@> args) {
  Command(L(line, col), Str(name), args);
};

(IntLit@, IntLit@, String@) { Text@; }
T = (IntLit@ line, IntLit@ col, String@ text) {
  Text@(L(line, col), text);
};

(IntLit@, IntLit@, List@<Ascii@>) { Markup@; }
P = (IntLit@ line, IntLit@ col, List@<Ascii@> text) {
  Plain(L(line, col), StrE(text));
};

(IntLit@, IntLit@, String@) { Markup@; }
PrS = (IntLit@ line, IntLit@ col, String@ text) {
  Plain(L(line, col), text);
};

(IntLit@, IntLit@, List@<Ascii@>) { Markup@; }
Pr = (IntLit@ line, IntLit@ col, List@<Ascii@> text) {
  Plain(L(line, col), Str(text));
};

(Result@<Markup@>, Result@<Markup@>) { TestResult@; }
AssertResultEquals = (Result@<Markup@> expected, Result@<Markup@> actual) {
  AssertEquals(
    /Fbld/Result/Eq%.Eq(/Fbld/Markup/Eq%.Markup),
    /Fbld/Result/Show%.Show(/Fbld/Markup/Show%.Markup),
    expected, actual);
};

Test@ Tests = TestSuite|Parse[
  Test|Unescape({
    Unit@ _ := Lazy;

    String@ text = Str|'a \\ a\[\]b\ncd\@';
    String@ want = StrE|'a \\ a[]b\ncd@';

    Result@<Markup@> got = Parse[T|1|1(text)];
    Result@<Markup@> wnt = Ok(M[C|1|1|'.block'[M[PrS|1|1(want)]]]);
    AssertResultEquals(wnt, got);
  }),

  Test|BasicInline({
    Unit@ _ := Lazy;

    String@ text = Str|'Inline @emph[text] with @SINGLE and @multi[abc][def] arg commands';

    Result@<Markup@> got = Parse[T|1|1(text)];
    Result@<Markup@> wnt = Ok(M[C|1|1|'.block'[M[
      P|1|1|'Inline ',
      C|1|9|'emph'[M[P|1|14|'text']],
      P|1|19|' with ',
      C|1|26|'SINGLE'[],
      P|1|32|' and ',
      C|1|38|'multi'[M[P|1|44|'abc'], M[P|1|49|'def']],
      P|1|53|' arg commands']]]);
    AssertResultEquals(wnt, got);
  }),

  Test|InlineUnescapedBrackets({
    Unit@ _ := Lazy;

    String@ text = Str|'Inline with [unescaped] brackets';

    Result@<Markup@> got = Parse[T|1|1(text)];
    Result@<Markup@> wnt = Ok(M[C|1|1|'.block'[M[
      P|1|1|'Inline with [unescaped] brackets']]]);
    AssertResultEquals(wnt, got);
  }),

  Test|NestedInline({
    Unit@ _ := Lazy;

    String@ text = Str|'Ab @c[de @f[gh] ij] kl';

    Result@<Markup@> got = Parse[T|1|1(text)];
    Result@<Markup@> wnt = Ok(M[C|1|1|'.block'[M[
      P|1|1|'Ab ',
      C|1|5|'c'[M[
        P|1|7|'de ',
        C|1|11|'f'[M[P|1|13|'gh']],
        P|1|16|' ij']],
      P|1|20|' kl']]]);
    AssertResultEquals(wnt, got);
  }),

  Test|BasicBlock({
    Unit@ _ := Lazy;

    String@ text = Lines[
      Str|'',
      Str|'@title A title',
      Str|'',
      Str|'Some intro text.',
      Str|'',
      Str|'@section[First Section]',
      Str|' With some text',
      Str|' spanning over lines.',
      Str|'',
      Str|' multiple lines actually.',
      Str|'',
      Str|'And some final text.'
    ];

    Result@<Markup@> got = Parse[T|1|1(text)];
    Result@<Markup@> wnt = Ok(M[
      C|2|2|'title'[M[P|2|8|'A title']],
      C|4|1|'.block'[M[P|4|1|'Some intro text.\n']],
      C|6|2|'section'[M[P|6|10|'First Section'], M[
        C|7|2|'.block'[M[P|7|2|'With some text\nspanning over lines.\n']],
        C|10|2|'.block'[M[P|10|2|'multiple lines actually.\n']]]],
      C|12|1|'.block'[M[P|12|1|'And some final text.\n']]]);
    AssertResultEquals(wnt, got);
  }),

  Test|NestedBlockLoc({
    Unit@ _ := Lazy;

    String@ text = Lines[
      Str|'@foo',
      Str|' @bar',
      Str|'  @sludge'
    ];

    Result@<Markup@> got = Parse[T|1|1(text)];
    Result@<Markup@> wnt = Ok(M[
      C|1|2|'foo'[M[
        C|2|3|'bar'[M[
          C|3|4|'sludge'[]]]]]]);
    AssertResultEquals(wnt, got);
  }),

  Test|IndentedSequentialPlainBlocks({
    Unit@ _ := Lazy;

    String@ text = Lines[
      Str|'@doc',
      Str|' @section',
      Str|'  With some text',
      Str|'  spanning over lines.',
      Str|' ',
      Str|'  multiple lines actually.'
    ];

    Result@<Markup@> got = Parse[T|1|1(text)];
    Result@<Markup@> wnt = Ok(M[
      C|1|2|'doc'[M[
        C|2|3|'section'[M[
          C|3|3|'.block'[M[P|3|3|'With some text\nspanning over lines.\n']],
          C|6|3|'.block'[M[P|6|3|'multiple lines actually.\n']]]]]]]);
    AssertResultEquals(wnt, got);
  }),

  Test|Continuation({
    Unit@ _ := Lazy;

    String@ text = Lines[
      Str|'@list[first][second]',
      Str|' third',
      Str|'@[fourth] fifth',
      Str|'@ sixth',
      Str|' seventh',
      Str|'@ eigth',
      Str|'@sludge'
    ];

    Result@<Markup@> got = Parse[T|1|1(text)];
    Result@<Markup@> wnt = Ok(M[
      C|1|2|'list'[
        M[P|1|7|'first'],
        M[P|1|14|'second'],
        M[C|2|2|'.block'[M[P|2|2|'third\n']]],
        M[P|3|3|'fourth'],
        M[P|3|11|'fifth'],
        M[P|4|3|'sixth'],
        M[C|5|2|'.block'[M[P|5|2|'seventh\n']]],
        M[P|6|3|'eigth']],
      C|7|2|'sludge'[]]);
    AssertResultEquals(wnt, got);
  }),

  Test|Final({
    Unit@ _ := Lazy;

    String@ text = Lines[
      Str|'@foo',
      Str|' here is some stuff.',
      Str|'@@',
      Str|'@bar here is the end.',
      Str|' Of all the rest.'
    ];

    Result@<Markup@> got = Parse[T|1|1(text)];
    Result@<Markup@> wnt = Ok(M[
      C|1|2|'foo'[
        M[C|2|2|'.block'[M[P|2|2|'here is some stuff.\n']]],
        M[C|4|2|'bar'[
          M[P|4|6|'here is the end.'],
          M[C|5|2|'.block'[M[P|5|2|'Of all the rest.\n']]]]]]]);
    AssertResultEquals(wnt, got);
  }),

  Test|SameLineFinal({
    Unit@ _ := Lazy;

    String@ text = Lines[
      Str|'@foo here is some stuff. @@',
      Str|'@bar here is the end.',
      Str|' Of all the rest.'
    ];

    Result@<Markup@> got = Parse[T|1|1(text)];
    Result@<Markup@> wnt = Ok(M[
      C|1|2|'foo'[
        M[P|1|6|'here is some stuff.'],
        M[C|2|2|'bar'[
          M[P|2|6|'here is the end.'],
          M[C|3|2|'.block'[M[P|3|2|'Of all the rest.\n']]]]]]]);
    AssertResultEquals(wnt, got);
  }),

  Test|NextLineLiteral({
    Unit@ _ := Lazy;

    String@ text = Lines[
      Str|'@foo @',
      Str|' foo@bar \ blah @@ @\@\\@.',
      Str|'@ done'
    ];

    Result@<Markup@> got = Parse[T|1|1(text)];
    Result@<Markup@> wnt = Ok(M[
      C|1|2|'foo'[
        M[PrS|2|2(Concat[Str|'foo@bar \ blah @@ @\@\\@.', StrE|'\n'])],
        M[P|3|3|'done']]]);
    AssertResultEquals(wnt, got);
  }),

  Test|InlineLiteral({
    Unit@ _ := Lazy;

    String@ text = Lines[
      Str|'@foo{foo@bar \ blah @@{ @\@}\\@.}',
      Str|'@ done'
    ];

    Result@<Markup@> got = Parse[T|1|1(text)];
    Result@<Markup@> wnt = Ok(M[
      C|1|2|'foo'[
        M[Pr|1|6|'foo@bar \ blah @@{ @\@}\\@.'],
        M[P|2|3|'done']]]);
    AssertResultEquals(wnt, got);
  }),

  Test|ExplicitImplicitBlock({
    Unit@ _ := Lazy;

    # The extra @ character indicates this should be parsed as implicit block
    # text without the @ character.
    String@ text = Str|'@@hello there!';

    Result@<Markup@> got = Parse[T|1|1(text)];
    Result@<Markup@> wnt = Ok(M[C|1|1|'.block'[M[
      C|1|3|'hello'[],
      P|1|8|' there!'
      ]]]);
    AssertResultEquals(wnt, got);
  }),

  Test|EmptyContinuation({
    Unit@ _ := Lazy;

    String@ text = Lines[
      Str|'@foo',
      Str|'@',
      Str|'@ bar'
    ];

    Result@<Markup@> got = Parse[T|1|1(text)];
    Result@<Markup@> wnt = Ok(M[
      C|1|2|'foo'[M[P|3|3|'bar']]]);
    AssertResultEquals(wnt, got);
  }),

  Test|BlankInlineInImplicitBlock({
    Unit@ _ := Lazy;

    String@ text = Lines[
      Str|'Here is @a[command with...',
      Str|'',
      Str|'a blank line in the argument.] What think you?'
    ];

    Result@<Markup@> got = Parse[T|1|1(text)];
    Result@<Markup@> wnt = Ok(M[
      C|1|1|'.block'[M[
        P|1|1|'Here is ',
        C|1|10|'a'[P|1|12|'command with...\n\na blank line in the argument.'],
        P|3|31|' What think you?\n'
      ]]]);
    AssertResultEquals(wnt, got);
  }),

  Test|EndOfInputError({
    Unit@ _ := Lazy;

    # Regression test for when end of input would be reported at file ???
    # instead of the end of the last file.
    String@ text = Str|'@a[hello';

    Result@<Markup@> got = Parse[T|1|1(text)];
    Result@<Markup@> wnt = Error<Markup@>(
      Loc@(Str|'foo.fbld', /Std/Int/Lit%.Int|1, /Std/Int/Lit%.Int|9),
      String|'unexpected end of input'
    );
    AssertResultEquals(wnt, got);
  })
];

@(Tests);
