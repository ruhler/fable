
Stream@, Return, Do, Put .= /Core/Stream%;

List@ .= /Std/List%;
Unit@, Unit .= /Std/Unit%;

Bit@ = +(Unit@ 0, Unit@ 1);

0 = Bit@(0: Unit);
1 = Bit@(1: Unit);

Data@ = <@ A@>(A@) { Stream@<Bit@>; };

(List@<Bit@>) { Stream@<Bit@>; }
Data = (List@<Bit@> xs) {
  xs.?(empty: Return<Bit@>);
  Unit@ _ := Do(Put(xs.items.head));
  Data(xs.items.tail);
};

@(Data@, Bit@, 0, 1, Data);
