
OnAscii .= /Std/Char/Ascii%;
AssertEquals .= /Std/Eq/Assert%;
Lazy .= /Std/Lazy%;
List@ .= /Std/List%;
Sort .= /Std/List/Sort%;
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

Elem@, Elems, Cmp, Eqs, Shows .= /Std/List/Tests/Elem%;

Test@ Tests = TestSuite|Sort[
  Test|Sort({
    Unit@ _ := Lazy;
    List@<Elem@> unsorted = Elems|DABEC;
    List@<Elem@> wnt = Elems|ABCDE;
    List@<Elem@> got = Sort(Cmp, unsorted);
    AssertEquals(Eqs, Shows, wnt, got);
  })
];

@(Tests);
