
Bool@, True, False .= /Std/Bool%;
Ascii@, OnAscii .= /Std/Char/Ascii%;
AssertEquals .= /Std/Eq/Assert%;
Int@, Neg .= /Std/Int%;
Eq, Ne .= /Std/Int/Eq%;
Int .= /Std/Int/Lit%;
List@ .= /Std/List%;
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

(List@<Ascii@>, (Int@, Int@) { Bool@; }, Int@, Int@, Bool@) { Test@; }
Binary = (List@<Ascii@> name, (Int@, Int@) { Bool@; } f, Int@ a, Int@ b, Bool@ z) {
  Test(name, (Unit@ _) {
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, z, f(a, b));
  });
};

Test@ Tests = TestSuite|Eq[
  TestSuite|Eq[
    Binary|PP(Eq, Int|1298, Int|1298, True),
    Binary|Pp(Eq, Int|1298, Int|1398, False),
    Binary|P0(Eq, Int|1298, Int|0, False),
    Binary|0P(Eq, Int|0, Int|1298, False),
    Binary|00(Eq, Int|0, Int|0, True),
    Binary|NN(Eq, Neg(Int|1298), Neg(Int|1298), True),
    Binary|Nn(Eq, Neg(Int|1298), Neg(Int|1398), False),
    Binary|N0(Eq, Neg(Int|1298), Int|0, False),
    Binary|0N(Eq, Int|0, Neg(Int|1298), False),
    Binary|NP(Eq, Int|1298, Neg(Int|1298), False)
  ],

  TestSuite|Ne[
    Binary|PP(Ne, Int|1298, Int|1298, False),
    Binary|Pp(Ne, Int|1298, Int|1398, True),
    Binary|P0(Ne, Int|1298, Int|0, True),
    Binary|0P(Ne, Int|0, Int|1298, True),
    Binary|00(Ne, Int|0, Int|0, False),
    Binary|NN(Ne, Neg(Int|1298), Neg(Int|1298), False),
    Binary|Nn(Ne, Neg(Int|1298), Neg(Int|1398), True),
    Binary|N0(Ne, Neg(Int|1298), Int|0, True),
    Binary|0N(Ne, Int|0, Neg(Int|1298), True),
    Binary|NP(Ne, Int|1298, Neg(Int|1298), True)
  ]
];

@(Tests);
