
% True = /Std/Bool%.True;
% False = /Std/Bool%.False;

<@>@ Eq@ = /Std/Eq%.Eq@;

@ Loc@ = /Fbld/Loc%.Loc@;

Eq@<Loc@> Eq = (Loc@ a, Loc@ b) {
  /Std/String/Eq%.Eq(a.file, b.file).?(false: False);
  /Std/Int/Eq%.Eq(a.line, b.line).?(false: False);
  /Std/Int/Eq%.Eq(a.col, b.col).?(false: False);
  True;
};

@(Eq);
