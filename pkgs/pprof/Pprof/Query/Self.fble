
List, Last .= /Std/List%;

Sequence@ .= /Pprof/Profile%;
Query@ .= /Pprof/Query%;

# @func[Query] Get blocks by self time.
#  @arg[Profile@][profile] The profile to query.
#  @returns[List@<Entry@>]
#   The self time of each block in descending order
Query@ Query = /Pprof/Query/ByFrame%.Query((Sequence@ seq) {
  List[Last(seq)];
});

@(Query);
