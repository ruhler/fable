
% False = /Std/Bool%.False;

<@>@ Eq@ = /Std/Eq%.Eq@;

<@>@ Show@ = /Core/Show%.Show@;
<@>@ ShowM@ = /Core/Show%.ShowM@;
% ToString = /Core/Show%.ToString;

% Format = /Core/Char/Ascii/Show%.Format;


<@>@ Result@ = <@ A@> {
  +(A@ ok, ShowM@ error);
};

<@ A@>(A@) { Result@<A@>; }
Okay = <@ A@>(A@ x) {
  Result@(ok: x);
};

<@ A@>(ShowM@) { Result@<A@>; }
Error = <@ A@>(ShowM@ msg) {
  Result@<A@>(error: msg);
};

<@ A@, @ B@>((A@) { B@; }, Result@<A@>) { Result@<B@>; }
Apply = <@ A@, @ B@>((A@) { B@; } f, Result@<A@> r) {
  r.?(error: Error<B@>(r.error));
  Okay(f(r.ok));
};

<@ A@>(Eq@<A@>) { Eq@<Result@<A@>>; }
Eq = <@ A@>(Eq@<A@> eq, Result@<A@> a, Result@<A@> b) {
  a.?(ok: b.?(ok: eq(a.ok, b.ok), : False));
  b.?(ok: False);
  /Std/String/Eq%.Eq(ToString(a.error), ToString(b.error));
};

<@ A@>(Show@<A@>) { Show@<Result@<A@>>; }
Show = <@ A@>(Show@<A@> show, Result@<A@> x) {
  x.?(ok: show(x.ok));
  Format|'error: %s'[x.error];
};

@(Result@, Okay, Error, Apply, Eq, Show);
