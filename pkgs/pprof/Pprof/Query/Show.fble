
Show@ = /Std/Show%.Show@;

Format = /Std/Char/Ascii/Output%.Format;

Entry@ = /Pprof/Query%.Entry@;
Table@ = /Pprof/Query%.Table@;

Show@<Entry@> Entry = (Entry@ x) {
  Format|'%s: %s'[
    /Pprof/Profile/Show%.Sequence(x.seq),
    /Std/Int/Show%.Show(x.value)
  ];
};

Show@<Table@> Table = /Std/List/Show%.Show(Entry);

@(Entry, Table);
