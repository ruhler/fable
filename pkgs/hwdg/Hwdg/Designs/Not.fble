
@ Addr@ = /Hwdg/Addr%.Addr@;
@ Design@ = /Hwdg/Design%.Design@;

<@>@ Build@ = /Hwdg/Build%.Build@;

(Addr@, Addr@, Addr@, Addr@, Addr@) { Build@<Design@>; }
Not = (Addr@ reset, Addr@ in, Addr@ in_ready, Addr@ out, Addr@ out_ready) {
    Return $ Rules[
        Rule[reset]|1[in_ready, out_ready]|00,
        Rule[in, in_ready, out_ready]|010[out, out_ready]|11, # 0 ==> 1
        Rule[in, in_ready, out_ready]|110[out, out_ready]|01  # 1 ==> 0
    ];
};

@(Not);
