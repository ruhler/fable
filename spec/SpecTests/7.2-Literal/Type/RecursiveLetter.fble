# @@fble-test@@ no-error
@ Unit@ = *();
Unit@ Unit = Unit@();

# The letter type can be recursive. The recursive field is ignored for the
# purposes of matching letters.
@ Letter@ = +(Letter@ recursive, Unit@ A, Unit@ B, Unit@ C);

@ L@ = +(*(Letter@ head, L@ tail) cons, Unit@ nil);

(L@) { Unit@; } f = (L@ l) {
  Unit@ _b = l.cons.head.B;
  Unit@ _a = l.cons.tail.cons.head.A;
  Unit@ _c = l.cons.tail.cons.tail.cons.head.C;
  Unit@ _e = l.cons.tail.cons.tail.cons.tail.nil;
  Unit;
};

f|BAC;
