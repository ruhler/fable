# @module[/Std/Maybe/Tests%]
#  Tests for /Std/Maybe%.

Bool@ = /Std/Bool%.Bool@;
True = /Std/Bool%.True;

Char@ = /Std/Char%.Char@;

OnAscii = /Std/Char/Ascii%.OnAscii;

AssertEquals = /Std/Eq/Assert%.AssertEquals;

Lazy .= /Std/Lazy%;
Tail, Append .= /Std/List%;

Maybe@ = /Std/Maybe%.Maybe@;
Just = /Std/Maybe%.Just;
Nothing = /Std/Maybe%.Nothing;
Get = /Std/Maybe%.Get;
JustGet = /Std/Maybe%.JustGet;
ForEach = /Std/Maybe%.ForEach;
Map = /Std/Maybe%.Map;
Do = /Std/Maybe%.Do;

String@ = /Std/String%.String@;
Str = /Std/Char/Ascii%.Str;
String = /Std/Char/Ascii/Stream%.String;

Test@ = /Std/Test%.Test@;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Pass = /Std/Test%.Pass;
Fail = /Std/Test%.Fail;

Unit@ = /Std/Unit%.Unit@;

# @value[Tests] Test suite for /Std/Maybe%
#  @type[Test@]
Test@ Tests = TestSuite|Maybe[
  Test|Just({
    Unit@ _ := Lazy;
    Just(Str|Just).?(just: Pass, nothing: Fail(String|'Just is nothing'));
  }),

  Test|Nothing({
    Unit@ _ := Lazy;
    Nothing<String@>.?(just: Fail(String|'Nothing is just'), nothing: Pass);
  }),

  TestSuite|Get[
    Test|Just({
      Unit@ _ := Lazy;
      String@ wnt = Str|Just; 
      String@ got = Get(Str|Default, Just(Str|Just));
      AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
    }),

    Test|Nothing({
      Unit@ _ := Lazy;
      String@ wnt = Str|Default; 
      String@ got = Get(Str|Default, Nothing<String@>);
      AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
    })
  ],

  Test|JustGet({
    Unit@ _ := Lazy;
    String@ wnt = Str|Just; 
    String@ got = JustGet(Just(Str|Just));
    AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
  }),

  TestSuite|ForEach[
    Test|Just({
      Unit@ _ := Lazy;
      String@ wnt = Str|ABCD; 
      String@ got = ForEach(Just(Str|AB), Str|CD,
        (String@ str, String@ base) { Append(str, base); });
      AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
    }),

    Test|Nothing({
      Unit@ _ := Lazy;
      String@ wnt = Str|Default; 
      String@ got = ForEach(Nothing<String@>, Str|Default,
        (String@ str, String@ _) { str; });
      AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
    })
  ],

  TestSuite|Map[
    Test|Just({
      Unit@ _ := Lazy;
      Maybe@<String@> wnt = Just(Str|BCD); 
      Maybe@<String@> got = Map(Just(Str|ABCD), Tail<Char@>);
      AssertEquals(
        /Std/Maybe/Eq%.Eq(/Std/String/Eq%.Eq),
        /Std/Maybe/Show%.Show(/Std/String/Show%.Show),
        wnt, got);
    }),

    Test|Nothing({
      Unit@ _ := Lazy;
      Maybe@<String@> wnt = Nothing<String@>;
      Maybe@<String@> got = Map(Nothing<String@>, Tail<Char@>);
      AssertEquals(
        /Std/Maybe/Eq%.Eq(/Std/String/Eq%.Eq),
        /Std/Maybe/Show%.Show(/Std/String/Show%.Show),
        wnt, got);
    })
  ],

  TestSuite|Do[
    Test|JustJust({
      Unit@ _ := Lazy;
      Maybe@<Bool@> wnt = Just(True);
      Maybe@<Bool@> got = {
        String@ a := Do(Just(Str|ABCD));
        a.?(items: Just(True), empty: Nothing<Bool@>);
      };

      AssertEquals(
        /Std/Maybe/Eq%.Eq(/Std/Bool/Eq%.Eq),
        /Std/Maybe/Show%.Show(/Std/Bool/Show%.Show),
        wnt, got);
    }),

    Test|JustNothing({
      Unit@ _ := Lazy;
      Maybe@<Bool@> wnt = Nothing<Bool@>;
      Maybe@<Bool@> got = {
        String@ a := Do(Just(Str|''));
        a.?(items: Just(True), empty: Nothing<Bool@>);
      };

      AssertEquals(
        /Std/Maybe/Eq%.Eq(/Std/Bool/Eq%.Eq),
        /Std/Maybe/Show%.Show(/Std/Bool/Show%.Show),
        wnt, got);
    }),

    Test|Nothing({
      Unit@ _ := Lazy;
      Maybe@<Bool@> wnt = Nothing<Bool@>;
      Maybe@<Bool@> got = {
        String@ a := Do(Nothing<String@>);
        a.?(items: Just(True), empty: Nothing<Bool@>);
      };

      AssertEquals(
        /Std/Maybe/Eq%.Eq(/Std/Bool/Eq%.Eq),
        /Std/Maybe/Show%.Show(/Std/Bool/Show%.Show),
        wnt, got);
    })
  ],

  /Std/Maybe/Eq/Tests%.Tests,
  /Std/Maybe/Show/Tests%.Tests
];

@(Tests);
