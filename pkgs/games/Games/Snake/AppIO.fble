
Io@ .= /Std/Io%;
Success .= /Std/Io/Cli%;
Int@ .= /Std/Int%;
List@ .= /Std/List%;
Monad@ .= /Std/Monad%;
String@ .= /Std/String%;
Unit@ .= /Std/Unit%;

App@ .= /App/App%;
Main@ .= /App/Native%;

Main@
Main = <<@>@ M@>(Monad@<M@> m, Io@<M@> _, App@<M@> app, Int@ width, Int@ height, List@<String@> _args)
{
  Unit@ _ := m.do(/Games/Snake%.Main(m, app, width, height));
  m.return(Success);
};

Main;
