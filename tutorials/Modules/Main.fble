
Char@ .= /Std/Char%;
FormatE .= /Std/Char/Ascii/Stream%;
Stream@ .= /Std/Stream%;

0, 1 .= /Bit%;
Bit4@, And .= /Bit4%;
Show .= /Bit4/Show%;

Bit4@ X = Bit4@(0, 0, 1, 1);
Bit4@ Y = Bit4@(1, 0, 1, 0);
Bit4@ Z = And(X, Y);

Stream@<Char@> output = FormatE|'%s AND %s = %s'[
  Show(X), Show(Y), Show(Z)
];

/Std/Io/Cli/Print%.Print(output);
