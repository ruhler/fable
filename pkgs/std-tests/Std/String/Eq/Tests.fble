
Bool@, True, False .= /Std/Bool%;
OnAscii, Str .= /Std/Char/Ascii%;
AssertEquals .= /Std/Eq/Assert%;
Lazy .= /Std/Lazy%;
List@, List .= /Std/List%;
String@ .= /Std/String%;
Eq, StartsWith, Contains, Split .= /Std/String/Eq%;
Test@ = /Std/Test%.Test@;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

# Tests --
#  A test suite to test the /Std/String% module and friends.
Test@ Tests = TestSuite|Eq[
  TestSuite|Eq[
    Test|T({
      Unit@ _ := Lazy;
      Bool@ wnt = True;
      Bool@ got = Eq(Str|'A string!', Str|'A string!');
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|F({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = Eq(Str|'A string!', Str|'nope');
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    })
  ],

  TestSuite|StartsWith[
    Test|EE({
      Unit@ _ := Lazy;
      Bool@ wnt = True;
      Bool@ got = StartsWith(Str|'', Str|'');
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|ES({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = StartsWith(Str|'', Str|hello);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|SE({
      Unit@ _ := Lazy;
      Bool@ wnt = True;
      Bool@ got = StartsWith(Str|hello, Str|'');
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|Ss({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = StartsWith(Str|'hello', Str|'there');
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|Prefix({
      Unit@ _ := Lazy;
      Bool@ wnt = True;
      Bool@ got = StartsWith(Str|hello, Str|hel);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|Suffix({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = StartsWith(Str|'xhello', Str|'hello');
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    })
  ],

  TestSuite|Contains[
    Test|EE({
      Unit@ _ := Lazy;
      Bool@ wnt = True;
      Bool@ got = Contains(Str|'', Str|'');
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|ES({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = Contains(Str|'', Str|hello);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|SE({
      Unit@ _ := Lazy;
      Bool@ wnt = True;
      Bool@ got = Contains(Str|hello, Str|'');
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|Ss({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = Contains(Str|hello, Str|there);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|Suffix({
      Unit@ _ := Lazy;
      Bool@ wnt = True;
      Bool@ got = Contains(Str|xhello, Str|hello);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    })
  ],

  Test|Split({
    Unit@ _ := Lazy;
    List@<String@> wnt = List[Str|hello, Str|there, Str|how, Str|are, Str|'you?'];
    List@<String@> got = Split(Str|'hello there how are you?', Str|' ');
    AssertEquals(
      /Std/List/Eq%.Eq(/Std/String/Eq%.Eq),
      /Std/List/Show%.Show(/Std/String/Show%.Show),
      wnt, got);
  })
];

@(Tests);
