# @module[/Std/Cmp/Data%]
#  The Data@ instance for Compared@.

Compared@ .= /Std/Cmp%;
Data@, Enum .= /Std/Data%;

# @value[Data] The Data@ instance for Compared@.
#  @type[Data@<Compared@>]
Data@<Compared@> Data = (Compared@ x) {
  # Pick order to match Cmp, which puts false < true.
  x.?(less: Enum|00, equal: Enum|01, greater: Enum|1);
};

@(Data);
