
Ascii, Char, OnAscii, StrE .= /Std/Char/Ascii%;
AssertEquals .= /Std/Eq/Assert%;
Lazy .= /Std/Lazy%;
List .= /Std/List%;
String@ .= /Std/String%;
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

Test@ Tests = TestSuite|Ascii[
  Test|StrE({
    Unit@ _ := Lazy;
    String@ wnt = List[
      Char|a, Ascii.nl,
      Char|b, Ascii.tab,
      Char|c, Char|'\',
      Char|d, Char|e, Char|f,
      Char|'''', Char|g
    ];
    String@ got = StrE|'a\nb\tc\\d\u65;f\qg';
    AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
  })
];

@(Tests);
