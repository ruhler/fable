
OnAscii .= /Std/Char/Ascii%;
Int .= /Std/Int/Lit%;
Test@ .= /Std/Test%;
Unit .= /Std/Unit%;

Key@, Event@ .= /App/App%;
Test = OnAscii(/App/Bench%.Bench);

Event@ Quit = Event@(key_down: Key@(q: Unit));

# Snake speed is set at about 40ms per tick. For 60 seconds of game play, we
# expect 1500 ticks.
Test@ Bench = Test|Snake(/Games/Snake%.Main, Quit, Int|1500);

@(Bench);
