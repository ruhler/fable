
@ Key@ = /App/App%.Key@;
@ Event@ = /App/App%.Event@;

% Int = /Std/Int/Lit%.Int;

% Str = /Std/Char/Ascii%.Str;

@ Test@ = /Std/Test%.Test@;
% Test = /Std/Test%.Test;

% Unit = /Std/Unit%.Unit;

# The number of iterations is chosen so that the benchmark takes on the
# order of 1 minute to run. The target goal is 60 frames a second.
Test@ Bench = Test(Str|Pinball, /App/Benchmark%.Benchmark(
  /Pinball/App%, Int|720, Event@(key_down: Key@(q: Unit))));

@(Bench);
