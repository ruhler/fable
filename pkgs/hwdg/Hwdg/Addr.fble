
Data@ .= /Core/Data%;
Int@ = /Std/Int%.Int@;
Do, Put .= /Std/Stream%;
Unit@ .= /Std/Unit%;

# A unique identifier for a location.
# For convenience when mapping to a 2d grid for graphics, we specify an address
# as a location in a 2d grid. That is not intended to imply any structure for
# the purposes of computation.
Addr@ = *(Int@ x, Int@ y);

Data@<Addr@> Data = (Addr@ a) {
  Unit@ _ := Do(Put(a.x));
  Put(a.y);
};

@(Addr@, Data);
