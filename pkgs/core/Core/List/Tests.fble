
@ Bool@ = /Std/Bool%.Bool@;
% True = /Std/Bool%.True;
% False = /Std/Bool%.False;

<@>% AssertEquals = /Core/Eq/Assert%.AssertEquals;
<@>% AssertNotEquals = /Core/Eq/Assert%.AssertNotEquals;

@ Int@ = /Std/Int%.Int@;
% Int = /Core/Int/Lit%.Int;

% Str = /Core/String%.Str;

@ Test@ = /Core/Test%.Test@;
% Test = /Core/Test%.Test;
% TestSuite = /Core/Test%.TestSuite;

@ Unit@ = /Std/Unit%.Unit@;

<@>@ List@ = /Std/List%.List@;
<@>% List = /Std/List%.List;
<@>% Items = /Std/List%.Items;
<@>% Empty = /Std/List%.Empty;
<@>% Head = /Std/List%.Head;
<@>% Tail = /Std/List%.Tail;
<@>% Last = /Std/List%.Last;
<@>% Append = /Std/List%.Append;
<@>% Init = /Std/List%.Init;
<@>% Concat = /Std/List%.Concat;
<@>% Map = /Std/List%.Map;
<@>% ForEach = /Std/List%.ForEach;
<@>% Reverse = /Std/List%.Reverse;
<@>% Join = /Std/List%.Join;

<@>% Count = /Std/List/Count%.Count;

<@>% HasItems = /Std/List/Eq%.HasItems;
<@>% IsEmpty = /Std/List/Eq%.IsEmpty;
<@>% StartsWith = /Std/List/Eq%.StartsWith;
<@>% EndsWith = /Std/List/Eq%.EndsWith;
<@>% Contains = /Std/List/Eq%.Contains;
<@>% Eq_Skip = /Std/List/Eq%.Skip;
<@>% Eq_Trim = /Std/List/Eq%.Trim;
<@>% Eq_Strip = /Std/List/Eq%.Strip;
<@>% Eq_Break = /Std/List/Eq%.Break;
<@>% Eq_Split = /Std/List/Eq%.Split;
<@>% Replace = /Std/List/Eq%.Replace;

<@>% Sort = /Std/List/Sort%.Sort;

@ Elem@ = /Core/List/Tests/Elem%.Elem@;
% Elems = /Core/List/Tests/Elem%.Elems;
% Eq = /Core/List/Tests/Elem%.Eq;
% Show = /Core/List/Tests/Elem%.Show;
% EL = /Core/List/Tests/Elem%.EL;
% ElemCmp = /Core/List/Tests/Elem%.ElemCmp;
% ElemEq = /Core/List/Tests/Elem%.ElemEq;
% ElemShow = /Core/List/Tests/Elem%.ElemShow;

Test@ Tests = TestSuite(Str|List, List<Test@>[
  Test(Str|'Eq_Same', (Unit@ _) {
    List@<Elem@> a = EL|ABCDE;
    List@<Elem@> b = EL|ABCDE;

    AssertEquals(Eq, Show, a, b);
  }),

  Test(Str|'Eq_DiffElem', (Unit@ _) {
    List@<Elem@> a = EL|ABCDE;
    List@<Elem@> b = EL|ABDDE;

    AssertNotEquals(Eq, Show, a, b);
  }),

  Test(Str|'Eq_DiffSize', (Unit@ _) {
    List@<Elem@> a = EL|ABCDE;
    List@<Elem@> b = EL|ABCD;

    AssertNotEquals(Eq, Show, a, b);
  }),

  Test(Str|'Append', (Unit@ _) {
    List@<Elem@> a = EL|ABC;
    List@<Elem@> b = EL|DEE;
    List@<Elem@> wnt = EL|ABCDEE;
    List@<Elem@> got = Append(a, b);
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|'Init', (Unit@ _) {
    List@<Elem@> l = EL|ABCDE;
    List@<Elem@> wnt = EL|ABCD;
    List@<Elem@> got = Init(l);
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|'Concat', (Unit@ _) {
    List@<List@<Elem@>> l = List[
      EL|ABC,
      EL|DEA,
      EL|BB
    ];

    List@<Elem@> wnt = EL|ABCDEABB;
    List@<Elem@> got = Concat<Elem@>(l);
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|'Map', (Unit@ _) {
    List@<Elem@> l = EL|ABCDE;
    (Elem@) { Elem@; } f = (Elem@ e) {
      e.?(A: Elems.B, B: Elems.C, C: Elems.D, D: Elems.E, E: Elems.A);
    };

    List@<Elem@> wnt = EL|BCDEA;
    List@<Elem@> got = Map(l, f);
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|'ForEach', (Unit@ _) {
    List@<Elem@> l = EL|ABCDE;
    List@<Elem@> wnt = EL|EDCBA;
    List@<Elem@> got =
      ForEach(l, Empty<Elem@>, (Elem@ e, List@<Elem@> b) {
        Items(e, b);
      });
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|'Reverse', (Unit@ _) {
    List@<Elem@> input = EL|ABCDE;
    List@<Elem@> wnt = EL|EDCBA;
    List@<Elem@> got = Reverse(input);
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|'Sort', (Unit@ _) {
    List@<Elem@> unsorted = EL|DABEC;
    List@<Elem@> wnt = EL|ABCDE;
    List@<Elem@> got = Sort(ElemCmp, unsorted);
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|'Count', (Unit@ _) {
    Int@ wnt = Int|5;
    Int@ got = Count(EL|ABCBBAABCEB, ElemEq(Elems.B));
    AssertEquals(/Std/Int/Eq%.Eq, /Core/Int/Show%.Show, wnt, got);
  }),

  Test(Str|Join, (Unit@ _) {
    List@<Elem@> wnt = EL|'AABBCBBDE';
    List@<Elem@> got = Join(List[EL|'AA', EL|'C', EL|'DE'], EL|'BB');
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|HasItems_yes, (Unit@ _) {
    List@<Elem@> list = EL|'ABBCCDDE';
    Bool@ got = HasItems(list);
    Bool@ wnt = True;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|HasItems_no, (Unit@ _) {
    List@<Elem@> list = EL|'';
    Bool@ got = HasItems(list);
    Bool@ wnt = False;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|IsEmpty_yes, (Unit@ _) {
    List@<Elem@> list = EL|'';
    Bool@ got = IsEmpty(list);
    Bool@ wnt = True;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|IsEmpty_no, (Unit@ _) {
    List@<Elem@> list = EL|'ABBCCDDE';
    Bool@ got = IsEmpty(list);
    Bool@ wnt = False;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|StartsWith, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'ABBC';
    Bool@ got = StartsWith(ElemEq, haystack, needle);
    Bool@ wnt = True;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|StartsWith_Mismatch, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'ABC';
    Bool@ got = StartsWith(ElemEq, haystack, needle);
    Bool@ wnt = False;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|StartsWith_EndOfString, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBC';
    List@<Elem@> needle = EL|'ABBCD';
    Bool@ got = StartsWith(ElemEq, haystack, needle);
    Bool@ wnt = False;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|EndsWith, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'CDDE';
    Bool@ got = EndsWith(ElemEq, haystack, needle);
    Bool@ wnt = True;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|EndsWith_Mismatch, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'CDD';
    Bool@ got = EndsWith(ElemEq, haystack, needle);
    Bool@ wnt = False;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|EndsWith_EndOfString, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBC';
    List@<Elem@> needle = EL|'ABBCD';
    Bool@ got = EndsWith(ElemEq, haystack, needle);
    Bool@ wnt = False;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|Contains, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'BCCD';
    Bool@ got = Contains(ElemEq, haystack, needle);
    Bool@ wnt = True;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|Contains_mismatch, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'DCCB';
    Bool@ got = Contains(ElemEq, haystack, needle);
    Bool@ wnt = False;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|Eq_Skip, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'ABBC';
    List@<Elem@> got = Eq_Skip(ElemEq, haystack, needle);
    List@<Elem@> wnt = EL|'CDDE';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Eq_Skip_mismatch, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'ABCD';
    List@<Elem@> got = Eq_Skip(ElemEq, haystack, needle);
    List@<Elem@> wnt = haystack;
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Eq_Trim, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'CDDE';
    List@<Elem@> got = Eq_Trim(ElemEq, haystack, needle);
    List@<Elem@> wnt = EL|'ABBC';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Eq_Trim_mismatch, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'EDDC';
    List@<Elem@> got = Eq_Trim(ElemEq, haystack, needle);
    List@<Elem@> wnt = haystack;
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Eq_Strip, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDEABBC';
    List@<Elem@> needle = EL|'ABBC';
    List@<Elem@> got = Eq_Strip(ElemEq, haystack, needle);
    List@<Elem@> wnt = EL|'CDDE';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Eq_Strip_mismatch, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'EDDC';
    List@<Elem@> got = Eq_Strip(ElemEq, haystack, needle);
    List@<Elem@> wnt = haystack;
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Eq_Strip_overlap, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABABA';
    List@<Elem@> needle = EL|'ABA';
    List@<Elem@> got = Eq_Strip(ElemEq, haystack, needle);
    List@<Elem@> wnt = EL|'BA';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Eq_Break_span, (Unit@ _) {
    List@<Elem@> list = EL|'ABCADBE';
    List@<Elem@> got = Eq_Break(ElemEq, list, EL|'AD').span;
    List@<Elem@> wnt = EL|'ABC';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Eq_Break_tail, (Unit@ _) {
    List@<Elem@> list = EL|'ABCADBE';
    List@<Elem@> got = Eq_Break(ElemEq, list, EL|'AD').tail;
    List@<Elem@> wnt = EL|'ADBE';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|'Eq_Split', (Unit@ _) {
    List@<Elem@> list = EL|'ABCDEBCABC';
    List@<Elem@> delim = EL|'BC';
    List@<List@<Elem@>> wnt = List[EL|'A', EL|'DE', EL|'A', EL|''];
    List@<List@<Elem@>> got = Eq_Split(ElemEq, list, delim);
    AssertEquals(
      /Std/List/Eq%.Eq(Eq),
      /Core/List/Show%.Show(Show),
      wnt, got);
  }),

  Test(Str|'Replace', (Unit@ _) {
    List@<Elem@> list = EL|'ABCDEBCABC';
    List@<Elem@> delim = EL|'BC';
    List@<Elem@> target = EL|'EA';
    List@<Elem@> wnt = EL|'AEADEEAAEA';
    List@<Elem@> got = Replace(ElemEq, list, delim, target);
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Head, (Unit@ _) {
    List@<Elem@> list = EL|'ABCDE';
    Elem@ got = Head(list);
    Elem@ wnt = Elems.A;
    AssertEquals(ElemEq, ElemShow, wnt, got);
  }),

  Test(Str|Tail, (Unit@ _) {
    List@<Elem@> list = EL|'ABCDE';
    List@<Elem@> got = Tail(list);
    List@<Elem@> wnt = EL|'BCDE';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Last, (Unit@ _) {
    List@<Elem@> list = EL|'ABCDE';
    Elem@ got = Last(list);
    Elem@ wnt = Elems.E;
    AssertEquals(ElemEq, ElemShow, wnt, got);
  }),

  /Core/List/Search/Tests%.Tests,
  /Core/List/Index/Tests%.Tests
]);

@(Tests);
