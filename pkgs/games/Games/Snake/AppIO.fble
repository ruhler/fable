
Success = /Std/Io/Cli%.Success;

Int@ = /Std/Int%.Int@;

List@ = /Std/List%.List@;

Monad@ = /Std/Monad%.Monad@;
Io@ = /Std/Io%.Io@;

String@ = /Std/String%.String@;

Unit@ = /Std/Unit%.Unit@;

App@ = /App/App%.App@;
Main@ = /App/Native%.Main@;

Main@
Main = <<@>@ M@>(Monad@<M@> m, Io@<M@> _, App@<M@> app, Int@ width, Int@ height, List@<String@> _args)
{
  Unit@ _ := m.do $ /Games/Snake%.Main(m, app, width, height);
  m.return(Success);
};

Main;
