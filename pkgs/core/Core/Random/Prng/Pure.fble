
<<@>@>@ Rng@ = /Core/Random/Rng%.Rng@;
<<@>@>@ RngM@ = /Core/Random/Rng%.RngM@;
<@>@ Prng@ = /Core/Random/Prng%.Prng@;

<@,@>@ Pure@ = /Core/State/Pure%.Pure@;

# Pure state monad RngM@ implementation of a Prng@.
<@ S@>(Prng@<S@>) { RngM@<Pure@<S@>>; }
Pure = <@ S@>(Prng@<S@> prng) {
  % p = /Core/State/Pure%.Pure<S@>;
  Rng@<p.M@> r = prng.rng<p.M@>(p.s, p.m);
  RngM@<p.M@>(p.M@, p.m, r);
};

@(Pure);
