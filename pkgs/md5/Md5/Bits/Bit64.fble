
Bit64@(.BitXY@), Bits .= /Md5/Bits/BitXY%(/Md5/Bits/Bit32%.Bits, /Md5/Bits/Bit32%.Bits);
B64(.B), H64(.H) .= /Md5/Bits/Lit%(Bits);
Bit .= /Md5/Digits%;

# a << 1
(Bit64@) { Bit64@; } Shl1 = (Bit64@ a) {
  Bits.Shlx(a, Bit.0).x;
};

@(
  Bit64@,
  And: Bits.And,
  Inc: Bits.Inc,
  Add: Bits.Add,
  Shl1,
  IsZero: Bits.IsZero,
  B64, H64
);
