
<@>@ Output@ = /Std/Char/Output%.Output@;

# Show@ --
#   Common facility for converting values to human readable strings. Primarily
#   used for testing and debugging.
#
# Type Parameters:
#   T@ - The type of the value to convert to a string.
#
# Arguments:
#   T@ - The value to convert to a string.
#
# Returns:
#   A deferred computation to show the value to a stream in human readable
#   form.
<@>@ Show@ = <@ T@>(T@) { Output@; };

@(Show@);
