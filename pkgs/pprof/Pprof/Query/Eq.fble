
True, False .= /Std/Bool%;
Eq@ .= /Std/Eq%;

Entry@, Table@ .= /Pprof/Query%;

Eq@<Entry@> Entry = (Entry@ a, Entry@ b) {
  /Pprof/Profile/Eq%.Sequence(a.seq, b.seq).?(false: False);
  /Std/Int/Eq%.Eq(a.value, b.value).?(false: False);
  True;
};

Eq@<Table@> Table = /Std/List/Eq%.Eq(Entry);

@(Entry, Table);
