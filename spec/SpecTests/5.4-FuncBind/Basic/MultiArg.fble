# @@fble-test@@ no-error
Unit@ = *();
Bool@ = +(Unit@ true, Unit@ false);
Bool@ True = Bool@(true: Unit@());
Bool@ False = Bool@(false: Unit@());

(Bool@, (Bool@, Bool@) { Bool@; }) { Bool@; }
Self = (Bool@ x, (Bool@, Bool@) { Bool@; } f) {
  f(x, x);
};

# You can use bind syntax with multi-argument functions.
Bool@ x = {
  Bool@ a, Bool@ b := Self(True);
  a.?(true: b, false: False);
};
x.true;
