
Int@ = /Std/Int%.Int@;
Decr = /Std/Int%.Decr;
IsNegative = /Std/Int/Sign%.IsNegative;
Int = /Std/Int/Lit%.Int;

Str = /Std/Char/Ascii%.Str;

Const = /Std/Func%.Const;

Pure = /Std/State/Pure%.Pure;
Eval = /Std/State/Pure%.Eval;

Test@ = /Std/Test%.Test@;
Test = /Std/Test%.Test;
Pass = /Std/Test%.Pass;

Unit@ = /Std/Unit%.Unit@;
Unit = /Std/Unit%.Unit;

App@ = /App/App%.App@;
Key@ = /App/App%.Key@;
Event@ = /App/App%.Event@;
Effect@ = /App/App%.Effect@;

Test@ Bench = Test(Str|'Snake', (Unit@ _) {
  # 1300 is around the number of iterations the Snake app runs for. Don't try
  # to run more, otherwise we could get deadlock.
  Int@ n = Int|1300;

  Int@ w = Int|640;
  Int@ h = Int|480;

  P = Pure<Int@>;
  M@ = P.M@;
  M = P.Monad;
  S = P.State;

  M@<Event@> event = {
    Int@ n := M.do(S.get);
    IsNegative(n).?(true: M.return(Event@(key_down: Key@(q: Unit))));
    Unit@ _ := M.do(S.put(Decr(n)));
    M.return(Event@(tick: Unit));
  };

  (Effect@) { M@<Unit@>; } effect = Const<Effect@> $ M.return(Unit);

  App@<M@> app = App@<M@>(event, effect);

  Unit@ _ = Eval(/Games/Snake%.Main(M, app, w, h), n);
  Pass;
});

@(Bench);
