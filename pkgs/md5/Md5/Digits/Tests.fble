
Bool@, True, False .= /Std/Bool%;
OnAscii .= /Std/Char/Ascii%;
AssertEquals .= /Std/Eq/Assert%;
Lazy .= /Std/Lazy%;
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

Bit .= /Md5/Digits%;
EqBit .= /Md5/Digits/Eq%;


Test@ Tests = TestSuite|Digits[
  TestSuite|EqBit[
    Test|00({
      Unit@ _ := Lazy;
      Bool@ wnt = True;
      Bool@ got = EqBit(Bit.0, Bit.0);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|01({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = EqBit(Bit.0, Bit.1);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|10({
      Unit@ _ := Lazy;
      Bool@ wnt = False;
      Bool@ got = EqBit(Bit.1, Bit.0);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    }),

    Test|11({
      Unit@ _ := Lazy;
      Bool@ wnt = True;
      Bool@ got = EqBit(Bit.1, Bit.1);
      AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, wnt, got);
    })
  ]
];

@(Tests);
