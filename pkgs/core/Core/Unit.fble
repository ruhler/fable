# @struct[Unit@] A type with a single inhabitant.
#  Useful for building more complex types and when the value being passed to
#  or returned by a function doesn't matter.
#
#  Example Use:
#
#  @code[fble] @
#   Bool@ = +(Unit@ true, Unit@ false);
@ Unit@ = *();

# @value[Unit] The single inhabitant of the @l{Unit@} type.
#  @type[Unit@]
#
#  Example Use:
#
#  @code[fble] @
#   Bool(true: Unit);
Unit@ Unit = Unit@();

@(Unit@, Unit);
