
<@>@ List@ = /Std/List%.List@;

<<@>@>@ Monad@ = /Std/Monad%.Monad@;

<<@>@>@ Stdio@ = /Core/Stdio%.Stdio@;
<<@>@>@ Main@ = /Core/Stdio%.Main@;

@ String@ = /Std/String%.String@;
% Str = /Std/Char/Ascii%.Str;

@ Test@ = /Std/Test%.Test@;

# Run --
#   Create a Stdio@ program to run a set of tests.
#
# Inputs:
#   tests - the list of tests to run.
#
# Result:
#   A Stdio@ program to run the tests.
(Test@) { Main@; } Run = (Test@ tests)<<@>@ M@>(Stdio@<M@> stdio, Monad@<M@> m, List@<String@> args) {
  % Runners = /Core/Test/Run%(m, stdio.out);

  String@ prefix = {
    args.?(empty: Str|'');
    /Std/String/Eq%.Eq(Str|'--prefix', args.items.head).?(false: Str|'');
    args.items.tail.items.head;
  };

  Runners.RunTests(prefix, tests);
};

@(Run);
