
@ Bool@ = /Std/Bool%.Bool@;
% True = /Std/Bool%.True;
% False = /Std/Bool%.False;

<@>@ Eq@ = /Std/Eq%.Eq@;
<@>% AssertEquals = /Core/Eq/Assert%.AssertEquals;
<@>% AssertNotEquals = /Core/Eq/Assert%.AssertNotEquals;

@ Int@ = /Std/Int%.Int@;
% Int = /Core/Int/Lit%.Int;

<@>@ Show@ = /Core/Show%.Show@;

@ String@ = /Core/String%.String@;
% Str = /Core/String%.Str;

@ Test@ = /Core/Test%.Test@;
% Test = /Core/Test%.Test;
% TestSuite = /Core/Test%.TestSuite;

@ Unit@ = /Std/Unit%.Unit@;
% Unit = /Std/Unit%.Unit;

<@>@ List@ = /Std/List%.List@;
<@>% List = /Std/List%.List;
<@>% Items = /Std/List%.Items;
<@>% Empty = /Std/List%.Empty;
<@>% Head = /Std/List%.Head;
<@>% Tail = /Std/List%.Tail;
<@>% Last = /Std/List%.Last;
<@>% Append = /Std/List%.Append;
<@>% Init = /Std/List%.Init;
<@>% Concat = /Std/List%.Concat;
<@>% Map = /Std/List%.Map;
<@>% ForEach = /Std/List%.ForEach;
<@>% Reverse = /Std/List%.Reverse;
<@>% Join = /Std/List%.Join;

<@>% Count = /Std/List/Count%.Count;

<@>% Length = /Std/List/Index%.Length;
<@>% Get = /Std/List/Index%.Get;
<@>% Set = /Std/List/Index%.Set;
<@>% Take = /Std/List/Index%.Take;
<@>% Drop = /Std/List/Index%.Drop;
<@>% Range = /Std/List/Index%.Range;
<@>% Index_Span = /Std/List/Index%.Span;

<@>% Any = /Std/List/Search%.Any;
<@>% Keep = /Std/List/Search%.Keep;
<@>% Remove = /Std/List/Search%.Remove;
<@>% Split = /Std/List/Search%.Split;
<@>% Search = /Std/List/Search%.Search;
<@>% SearchR = /Std/List/Search%.SearchR;
<@>% Skip = /Std/List/Search%.Skip;
<@>% Until = /Std/List/Search%.Until;
<@>% While = /Std/List/Search%.While;
<@>% Trim = /Std/List/Search%.Trim;
<@>% Strip = /Std/List/Search%.Strip;
<@>% Search_Span = /Std/List/Search%.Span;
<@>% Break = /Std/List/Search%.Break;

<@>% HasItems = /Core/List/Eq%.HasItems;
<@>% IsEmpty = /Core/List/Eq%.IsEmpty;
<@>% StartsWith = /Core/List/Eq%.StartsWith;
<@>% EndsWith = /Core/List/Eq%.EndsWith;
<@>% Contains = /Core/List/Eq%.Contains;
<@>% Eq_Skip = /Core/List/Eq%.Skip;
<@>% Eq_Trim = /Core/List/Eq%.Trim;
<@>% Eq_Strip = /Core/List/Eq%.Strip;
<@>% Eq_Break = /Core/List/Eq%.Break;


<@>% Sort = /Core/List/Sort%.Sort;

@ Elem@ = +(Unit@ A, Unit@ B, Unit@ C, Unit@ D, Unit@ E);

% Elems = @(
  A: Elem@(A: Unit),
  B: Elem@(B: Unit),
  C: Elem@(C: Unit),
  D: Elem@(D: Unit),
  E: Elem@(E: Unit));

(List@<Elem@>) { List@<Elem@>; } EL = List<Elem@>;

(Elem@) { String@; } ElemShow = (Elem@ e) {
  e.?(A: Str|A, B: Str|B, C: Str|C, D: Str|D, E: Str|E);
};

(Elem@, Elem@) { Bool@; } ElemLe = (Elem@ a, Elem@ b) {
  a.?(A: True,
      B: b.?(A: False, : True),
      C: b.?(A: False, B: False, : True),
      D: b.?(A: False, B: False, C: False, : True),
      E: b.?(A: False, B: False, C: False, D: False, E: True));
};

(Elem@, Elem@) { Bool@; } ElemGe = (Elem@ a, Elem@ b) {
  ElemLe(b, a);
};

(Elem@, Elem@) { Bool@; } ElemEq = (Elem@ a, Elem@ b) {
  a.?(A: b.?(A: True, : False),
      B: b.?(B: True, : False),
      C: b.?(C: True, : False),
      D: b.?(D: True, : False),
      E: b.?(E: True, : False));
};

Eq@<List@<Elem@>> Eq = /Core/List/Eq%.Eq<Elem@>(ElemEq);
Show@<List@<Elem@>> Show = /Core/List/Show%.Show<Elem@>(ElemShow);

Test@ Tests = TestSuite(Str|List, List<Test@>[
  Test(Str|'Eq_Same', (Unit@ _) {
    List@<Elem@> a = EL|ABCDE;
    List@<Elem@> b = EL|ABCDE;

    AssertEquals(Eq, Show, a, b);
  }),

  Test(Str|'Eq_DiffElem', (Unit@ _) {
    List@<Elem@> a = EL|ABCDE;
    List@<Elem@> b = EL|ABDDE;

    AssertNotEquals(Eq, Show, a, b);
  }),

  Test(Str|'Eq_DiffSize', (Unit@ _) {
    List@<Elem@> a = EL|ABCDE;
    List@<Elem@> b = EL|ABCD;

    AssertNotEquals(Eq, Show, a, b);
  }),

  Test(Str|'Append', (Unit@ _) {
    List@<Elem@> a = EL|ABC;
    List@<Elem@> b = EL|DEE;
    List@<Elem@> wnt = EL|ABCDEE;
    List@<Elem@> got = Append(a, b);
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|'Init', (Unit@ _) {
    List@<Elem@> l = EL|ABCDE;
    List@<Elem@> wnt = EL|ABCD;
    List@<Elem@> got = Init(l);
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|'Concat', (Unit@ _) {
    List@<List@<Elem@>> l = List[
      EL|ABC,
      EL|DEA,
      EL|BB
    ];

    List@<Elem@> wnt = EL|ABCDEABB;
    List@<Elem@> got = Concat<Elem@>(l);
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|'Map', (Unit@ _) {
    List@<Elem@> l = EL|ABCDE;
    (Elem@) { Elem@; } f = (Elem@ e) {
      e.?(A: Elems.B, B: Elems.C, C: Elems.D, D: Elems.E, E: Elems.A);
    };

    List@<Elem@> wnt = EL|BCDEA;
    List@<Elem@> got = Map(l, f);
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|'ForEach', (Unit@ _) {
    List@<Elem@> l = EL|ABCDE;
    List@<Elem@> wnt = EL|EDCBA;
    List@<Elem@> got =
      ForEach(l, Empty<Elem@>, (Elem@ e, List@<Elem@> b) {
        Items(e, b);
      });
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|'Reverse', (Unit@ _) {
    List@<Elem@> input = EL|ABCDE;
    List@<Elem@> wnt = EL|EDCBA;
    List@<Elem@> got = Reverse(input);
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|'Sort', (Unit@ _) {
    List@<Elem@> unsorted = EL|DABEC;
    List@<Elem@> wnt = EL|ABCDE;
    List@<Elem@> got = Sort(ElemLe, unsorted);
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|'Length', (Unit@ _) {
    Int@ wnt = Int|5;
    Int@ got = Length(EL|ABCDE);
    AssertEquals(/Std/Int/Eq%.Eq, /Core/Int/Show%.Show, wnt, got);
  }),

  Test(Str|'Count', (Unit@ _) {
    Int@ wnt = Int|5;
    Int@ got = Count(EL|ABCBBAABCEB, ElemEq(Elems.B));
    AssertEquals(/Std/Int/Eq%.Eq, /Core/Int/Show%.Show, wnt, got);
  }),

  Test(Str|'Split', (Unit@ _) {
    @ T@ = +(Unit@ ' ', Unit@ X);
    Eq@<T@> eq = (T@ a, T@ b) {
      a.?(' ': b.?(' ': True, 'X': False), 'X': b.?(' ': False, 'X': True));
    };
    Show@<T@> show = (T@ x) { x.?(' ': Str|' ', 'X': Str|'X'); };

    (T@) { Bool@; } sep = (T@ x) { x.?(' ': True, 'X': False); };
    List@<T@> list = List<T@>|'  XXX X  XX ';
    List@<List@<T@>> want = List[List<T@>|XXX, List<T@>|X, List<T@>|XX];
    List@<List@<T@>> got = Split(list, sep);
    AssertEquals(
      /Core/List/Eq%.Eq(/Core/List/Eq%.Eq(eq)),
      /Core/List/Show%.Show(/Core/List/Show%.Show(show)),
      want, got);
  }),

  Test(Str|Join, (Unit@ _) {
    List@<Elem@> wnt = EL|'AABBCBBDE';
    List@<Elem@> got = Join(List[EL|'AA', EL|'C', EL|'DE'], EL|'BB');
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Keep, (Unit@ _) {
    List@<Elem@> l = EL|'ABBCDDBCCADEBA';
    List@<Elem@> wnt = EL|'ABBBABA';
    List@<Elem@> got = Keep(l, ElemGe(Elems.B));
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Remove, (Unit@ _) {
    List@<Elem@> l = EL|'ABBCCDDE';
    List@<Elem@> wnt = EL|'ACCDDE';
    List@<Elem@> got = Remove(l, ElemEq(Elems.B));
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Any, (Unit@ _) {
    List@<Elem@> l = EL|'BDBB';
    Bool@ wnt = True;
    Bool@ got = Any(l, (Elem@ e) { e.?(D: True, : False); });
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|AnyNot, (Unit@ _) {
    List@<Elem@> l = EL|'BDBB';
    Bool@ wnt = False;
    Bool@ got = Any(l, (Elem@ e) { e.?(C: True, : False); });
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|Search, (Unit@ _) {
    List@<Elem@> l = EL|'ABCBDCDE';
    List@<Elem@> wnt = EL|'CBDCDE';
    List@<Elem@> got = Search(l, ElemEq(Elems.C));
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|SearchNotFound, (Unit@ _) {
    List@<Elem@> l = EL|'ABBDDE';
    List@<Elem@> wnt = EL|'';
    List@<Elem@> got = Search(l, ElemEq(Elems.C));
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|SearchR, (Unit@ _) {
    List@<Elem@> l = EL|'ABCBDCDE';
    List@<Elem@> wnt = EL|'CDE';
    List@<Elem@> got = SearchR(l, ElemEq(Elems.C));
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Skip, (Unit@ _) {
    List@<Elem@> l = EL|'AABCBDCDE';
    List@<Elem@> wnt = EL|'BCBDCDE';
    List@<Elem@> got = Skip(l, ElemEq(Elems.A));
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Until, (Unit@ _) {
    List@<Elem@> l = EL|'AABCBDCDE';
    List@<Elem@> wnt = EL|'AAB';
    List@<Elem@> got = Until(l, ElemEq(Elems.C));
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|While, (Unit@ _) {
    List@<Elem@> l = EL|'AABCBDCDE';
    List@<Elem@> wnt = EL|'AAB';
    List@<Elem@> got = While(l, ElemGe(Elems.B));
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Trim, (Unit@ _) {
    List@<Elem@> l = EL|'EAABCEBDCDEE';
    List@<Elem@> wnt = EL|'EAABCEBDCD';
    List@<Elem@> got = Trim(l, ElemEq(Elems.E));
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Strip, (Unit@ _) {
    List@<Elem@> l = EL|'EAABCEBDCDEE';
    List@<Elem@> wnt = EL|'AABCEBDCD';
    List@<Elem@> got = Strip(l, ElemEq(Elems.E));
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Search_Span_span, (Unit@ _) {
    List@<Elem@> list = EL|'ABCADBE';
    List@<Elem@> got = Search_Span(list, ElemGe(Elems.B)).span;
    List@<Elem@> wnt = EL|'AB';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Search_Span_tail, (Unit@ _) {
    List@<Elem@> list = EL|'ABCADBE';
    List@<Elem@> got = Search_Span(list, ElemGe(Elems.B)).tail;
    List@<Elem@> wnt = EL|'CADBE';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Break_span, (Unit@ _) {
    List@<Elem@> list = EL|'ABCADBE';
    List@<Elem@> got = Break(list, ElemEq(Elems.C)).span;
    List@<Elem@> wnt = EL|'AB';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Break_tail, (Unit@ _) {
    List@<Elem@> list = EL|'ABCADBE';
    List@<Elem@> got = Break(list, ElemEq(Elems.C)).tail;
    List@<Elem@> wnt = EL|'CADBE';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|HasItems_yes, (Unit@ _) {
    List@<Elem@> list = EL|'ABBCCDDE';
    Bool@ got = HasItems(list);
    Bool@ wnt = True;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|HasItems_no, (Unit@ _) {
    List@<Elem@> list = EL|'';
    Bool@ got = HasItems(list);
    Bool@ wnt = False;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|IsEmpty_yes, (Unit@ _) {
    List@<Elem@> list = EL|'';
    Bool@ got = IsEmpty(list);
    Bool@ wnt = True;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|IsEmpty_no, (Unit@ _) {
    List@<Elem@> list = EL|'ABBCCDDE';
    Bool@ got = IsEmpty(list);
    Bool@ wnt = False;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|StartsWith, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'ABBC';
    Bool@ got = StartsWith(ElemEq, haystack, needle);
    Bool@ wnt = True;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|StartsWith_Mismatch, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'ABC';
    Bool@ got = StartsWith(ElemEq, haystack, needle);
    Bool@ wnt = False;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|StartsWith_EndOfString, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBC';
    List@<Elem@> needle = EL|'ABBCD';
    Bool@ got = StartsWith(ElemEq, haystack, needle);
    Bool@ wnt = False;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|EndsWith, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'CDDE';
    Bool@ got = EndsWith(ElemEq, haystack, needle);
    Bool@ wnt = True;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|EndsWith_Mismatch, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'CDD';
    Bool@ got = EndsWith(ElemEq, haystack, needle);
    Bool@ wnt = False;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|EndsWith_EndOfString, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBC';
    List@<Elem@> needle = EL|'ABBCD';
    Bool@ got = EndsWith(ElemEq, haystack, needle);
    Bool@ wnt = False;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|Contains, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'BCCD';
    Bool@ got = Contains(ElemEq, haystack, needle);
    Bool@ wnt = True;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|Contains_mismatch, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'DCCB';
    Bool@ got = Contains(ElemEq, haystack, needle);
    Bool@ wnt = False;
    AssertEquals(/Std/Bool/Eq%.Eq, /Core/Bool/Show%.Show, wnt, got);
  }),

  Test(Str|Eq_Skip, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'ABBC';
    List@<Elem@> got = Eq_Skip(ElemEq, haystack, needle);
    List@<Elem@> wnt = EL|'CDDE';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Eq_Skip_mismatch, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'ABCD';
    List@<Elem@> got = Eq_Skip(ElemEq, haystack, needle);
    List@<Elem@> wnt = haystack;
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Eq_Trim, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'CDDE';
    List@<Elem@> got = Eq_Trim(ElemEq, haystack, needle);
    List@<Elem@> wnt = EL|'ABBC';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Eq_Trim_mismatch, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'EDDC';
    List@<Elem@> got = Eq_Trim(ElemEq, haystack, needle);
    List@<Elem@> wnt = haystack;
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Eq_Strip, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDEABBC';
    List@<Elem@> needle = EL|'ABBC';
    List@<Elem@> got = Eq_Strip(ElemEq, haystack, needle);
    List@<Elem@> wnt = EL|'CDDE';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Eq_Strip_mismatch, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABBCCDDE';
    List@<Elem@> needle = EL|'EDDC';
    List@<Elem@> got = Eq_Strip(ElemEq, haystack, needle);
    List@<Elem@> wnt = haystack;
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Eq_Strip_overlap, (Unit@ _) {
    List@<Elem@> haystack = EL|'ABABA';
    List@<Elem@> needle = EL|'ABA';
    List@<Elem@> got = Eq_Strip(ElemEq, haystack, needle);
    List@<Elem@> wnt = EL|'BA';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Eq_Break_span, (Unit@ _) {
    List@<Elem@> list = EL|'ABCADBE';
    List@<Elem@> got = Eq_Break(ElemEq, list, EL|'AD').span;
    List@<Elem@> wnt = EL|'ABC';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Eq_Break_tail, (Unit@ _) {
    List@<Elem@> list = EL|'ABCADBE';
    List@<Elem@> got = Eq_Break(ElemEq, list, EL|'AD').tail;
    List@<Elem@> wnt = EL|'ADBE';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Head, (Unit@ _) {
    List@<Elem@> list = EL|'ABCDE';
    Elem@ got = Head(list);
    Elem@ wnt = Elems.A;
    AssertEquals(ElemEq, ElemShow, wnt, got);
  }),

  Test(Str|Tail, (Unit@ _) {
    List@<Elem@> list = EL|'ABCDE';
    List@<Elem@> got = Tail(list);
    List@<Elem@> wnt = EL|'BCDE';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Last, (Unit@ _) {
    List@<Elem@> list = EL|'ABCDE';
    Elem@ got = Last(list);
    Elem@ wnt = Elems.E;
    AssertEquals(ElemEq, ElemShow, wnt, got);
  }),

  Test(Str|Get, (Unit@ _) {
    List@<Elem@> list = EL|'ABCDE';
    Elem@ got = Get(list, Int|2);
    Elem@ wnt = Elems.C;
    AssertEquals(ElemEq, ElemShow, wnt, got);
  }),

  Test(Str|Set, (Unit@ _) {
    List@<Elem@> list = EL|'ABCDE';
    List@<Elem@> got = Set(list, Int|2, Elems.A);
    List@<Elem@> wnt = EL|'ABADE';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Take, (Unit@ _) {
    List@<Elem@> list = EL|'ABCDE';
    List@<Elem@> got = Take(list, Int|2);
    List@<Elem@> wnt = EL|'AB';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Drop, (Unit@ _) {
    List@<Elem@> list = EL|'ABCDE';
    List@<Elem@> got = Drop(list, Int|2);
    List@<Elem@> wnt = EL|'CDE';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Range, (Unit@ _) {
    List@<Elem@> list = EL|'ABCDE';
    List@<Elem@> got = Range(list, Int|1, Int|2);
    List@<Elem@> wnt = EL|'BC';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Index_Span_span, (Unit@ _) {
    List@<Elem@> list = EL|'ABCDE';
    List@<Elem@> got = Index_Span(list, Int|2).span;
    List@<Elem@> wnt = EL|'AB';
    AssertEquals(Eq, Show, wnt, got);
  }),

  Test(Str|Index_Span_tail, (Unit@ _) {
    List@<Elem@> list = EL|'ABCDE';
    List@<Elem@> got = Index_Span(list, Int|2).tail;
    List@<Elem@> wnt = EL|'CDE';
    AssertEquals(Eq, Show, wnt, got);
  })
]);

@(Tests);
