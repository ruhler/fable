
Bool@ = /Std/Bool%.Bool@;

Lfsr = /Core/Random/Lfsr%.Lfsr;
Bits = /Core/Random/Lfsr%.Bits;

List@ = /Std/List%.List@;
List = /Std/List%.List;

Prng@ = /Core/Random/Prng%.Prng@;

Str = /Std/Char/Ascii%.Str;

Test@ = /Std/Test%.Test@;
TestSuite = /Std/Test%.TestSuite;
Test = /Std/Test%.Test;

AssertSequence = /Core/Random/Prng/Assert%.AssertSequence;

Unit@ = /Std/Unit%.Unit@;

Test@ Tests = TestSuite(Str|Lfsr, List[
  Test(Str|Basic, (Unit@ _) {
    # Validate the full sequence of a 3 bit LFSR.
    Prng@<List@<Bool@>> prng = Lfsr(Bits|110);
    AssertSequence(
      /Std/List/Eq%.Eq(/Std/Bool/Eq%.Eq),
      /Std/List/Show%.Show(/Std/Bool/Show%.Show), prng)[
        Bits|010, Bits|101, Bits|011, Bits|111,
        Bits|110, Bits|100, Bits|001, Bits|010];
  })
]);

@(Tests);
