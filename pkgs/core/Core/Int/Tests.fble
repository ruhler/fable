
@ Bool@ = /Std/Bool%.Bool@;
% Not = /Std/Bool%.Not;

<@>% AssertEquals = /Core/Eq/Assert%.AssertEquals;

% Ord = /Std/Cmp%;
@ Compared@ = Ord.Compared@;

<@>% List = /Std/List%.List;

@ String@ = /Core/String%.String@;
% Str = /Core/Char/Ascii%.Str;

@ Test@ = /Core/Test%.Test@;
% Test = /Core/Test%.Test;
% TestSuite = /Core/Test%.TestSuite;
% Pass = /Core/Test%.Pass;
% Fail = /Core/Test%.Fail;

@ Unit@ = /Std/Unit%.Unit@;

@ Int@ = /Std/Int%.Int@;
% Neg = /Std/Int%.Neg;
% Incr = /Std/Int%.Incr;
% Decr = /Std/Int%.Decr;
% Add = /Std/Int%.Add;
% Sub = /Std/Int%.Sub;
% Mul = /Std/Int%.Mul;
% Mul2 = /Std/Int%.Mul2;
% Exp2 = /Std/Int%.Exp2;
% Exp = /Std/Int%.Exp;
% Shl = /Std/Int%.Shl;
% Shr = /Std/Int%.Shr;

% Div = /Std/Int/Div%.Div;
% Quot = /Std/Int/Div%.Quot;
% Mod = /Std/Int/Div%.Mod;
% Sqrt = /Std/Int/Sqrt%.Sqrt;

% Eq = /Std/Int/Eq%.Eq;
% Ne = /Std/Int/Eq%.Ne;
% Lt = /Std/Int/Ord%.Lt;
% Le = /Std/Int/Ord%.Le;
% Gt = /Std/Int/Ord%.Gt;
% Ge = /Std/Int/Ord%.Ge;
% Min = /Std/Int/Ord%.Min;
% Max = /Std/Int/Ord%.Max;
% Int = /Core/Int/Lit%.Int;
% IOrd = /Core/Int/Ord%.Ord;
% IsZero = /Std/Int/Sign%.IsZero;
% Abs = /Std/Int/Sign%.Abs;

Int@ 0 = Int|0;
Int@ 1 = Int|1;
Int@ 2 = Int|2;
Int@ 3 = Int|3;
Int@ 4 = Int|4;
Int@ 5 = Int|5;
Int@ 6 = Int|6;
Int@ 7 = Int|7;
Int@ 8 = Int|8;

(String@, (Unit@) { Bool@; }) { Test@; }
T = (String@ name, (Unit@) { Bool@; } p) {
  Test(name, (Unit@ u) {
    p(u).?(true: Pass, : Fail(Str|failed));
  });
};

(String@, (Unit@) { Bool@; }) { Test@; }
F = (String@ name, (Unit@) { Bool@; } p) {
  Test(name, (Unit@ u) {
    p(u).?(false: Pass, : Fail(Str|failed));
  });
};

(String@, Int@, (Unit@) { Int@; }) { Test@; }
TEq = (String@ name, Int@ a, (Unit@) { Int@; } b) {
  Test(name, (Unit@ u) {
    AssertEquals(/Std/Int/Eq%.Eq, /Core/Int/Show%.Show, a, b(u));
  });
};

(String@, Compared@, (Unit@) { Compared@; }) { Test@; }
TOrd = (String@ name, Compared@ a, (Unit@) { Compared@; } b) {
  Test(name, (Unit@ u) {
    AssertEquals(/Core/Ord/Eq%.Eq, /Core/Ord/Show%.Show, a, b(u));
  });
};

Test@ Tests = TestSuite(Str|Int, List[
  T(Str|Eq_0_0, (Unit@ _ ) { Eq(0, 0); }),
  F(Str|Eq_0_1, (Unit@ _ ) { Eq(0, 1); }),
  T(Str|Eq_4_4, (Unit@ _ ) { Eq(4, 4); }),
  T(Str|Eq_5_5, (Unit@ _ ) { Eq(5, 5); }),
  F(Str|Eq_4_5, (Unit@ _ ) { Eq(4, 5); }),
  F(Str|Eq_5_m5, (Unit@ _) { Eq(5, Neg(5)); }),
  T(Str|Eq_m1_m1, (Unit@ _) { Eq(Neg(5), Neg(5)); }),

  F(Str|Ne_0_0, (Unit@ _ ) { Ne(0, 0); }),
  T(Str|Ne_0_1, (Unit@ _ ) { Ne(0, 1); }),
  F(Str|Ne_4_4, (Unit@ _ ) { Ne(4, 4); }),
  F(Str|Ne_5_5, (Unit@ _ ) { Ne(5, 5); }),
  T(Str|Ne_4_5, (Unit@ _ ) { Ne(4, 5); }),
  T(Str|Ne_5_m5, (Unit@ _) { Ne(5, Neg(5)); }),
  F(Str|Ne_m1_m1, (Unit@ _) { Ne(Neg(5), Neg(5)); }),

  T(Str|IsZero_0, (Unit@ _) { IsZero(0); }),
  F(Str|IsZero_3, (Unit@ _) { IsZero(3); }),

  F(Str|Lt_4_2, (Unit@ _) { Lt(4, 2); }),
  F(Str|Lt_4_3, (Unit@ _) { Lt(4, 3); }),
  F(Str|Lt_4_4, (Unit@ _) { Lt(4, 4); }),
  T(Str|Lt_4_5, (Unit@ _) { Lt(4, 5); }),
  T(Str|Lt_4_6, (Unit@ _) { Lt(4, 6); }),

  F(Str|Lt_5_3, (Unit@ _) { Lt(5, 3); }),
  F(Str|Lt_5_4, (Unit@ _) { Lt(5, 4); }),
  F(Str|Lt_5_5, (Unit@ _) { Lt(5, 5); }),
  T(Str|Lt_5_6, (Unit@ _) { Lt(5, 6); }),
  T(Str|Lt_5_7, (Unit@ _) { Lt(5, 7); }),

  T(Str|Lt_m5_m7, (Unit@ _) { Not(Lt(Neg(5), Neg(7))); }),
  T(Str|Lt_m7_m5, (Unit@ _) { Lt(Neg(7), Neg(5)); }),

  T(Str|Lt_0_7, (Unit@ _) { Lt(0, 7); }),
  T(Str|Lt_7_0, (Unit@ _) { Not(Lt(7, 0)); }),
  T(Str|Lt_0_m7, (Unit@ _) { Not(Lt(0, Neg(7))); }),
  T(Str|Lt_m7_0, (Unit@ _) { Lt(Neg(7), 0); }),

  T(Str|Le_4_2, (Unit@ _) { Not(Le(4, 2)); }),
  T(Str|Le_4_3, (Unit@ _) { Not(Le(4, 3)); }),
  T(Str|Le_4_4, (Unit@ _) { Le(4, 4); }),
  T(Str|Le_4_5, (Unit@ _) { Le(4, 5); }),
  T(Str|Le_4_6, (Unit@ _) { Le(4, 6); }),

  T(Str|Le_5_3, (Unit@ _) { Not(Le(5, 3)); }),
  T(Str|Le_5_4, (Unit@ _) { Not(Le(5, 4)); }),
  T(Str|Le_5_5, (Unit@ _) { Le(5, 5); }),
  T(Str|Le_5_6, (Unit@ _) { Le(5, 6); }),
  T(Str|Le_5_7, (Unit@ _) { Le(5, 7); }),

  T(Str|Gt_4_2, (Unit@ _) { Gt(4, 2); }),
  T(Str|Gt_4_3, (Unit@ _) { Gt(4, 3); }),
  T(Str|Gt_4_4, (Unit@ _) { Not(Gt(4, 4)); }),
  T(Str|Gt_4_5, (Unit@ _) { Not(Gt(4, 5)); }),
  T(Str|Gt_4_6, (Unit@ _) { Not(Gt(4, 6)); }),

  T(Str|Gt_5_3, (Unit@ _) { Gt(5, 3); }),
  T(Str|Gt_5_4, (Unit@ _) { Gt(5, 4); }),
  T(Str|Gt_5_5, (Unit@ _) { Not(Gt(5, 5)); }),
  T(Str|Gt_5_6, (Unit@ _) { Not(Gt(5, 6)); }),
  T(Str|Gt_5_7, (Unit@ _) { Not(Gt(5, 7)); }),

  T(Str|Gt_m5_m7, (Unit@ _) { Gt(Neg(5), Neg(7)); }),
  T(Str|Gt_m7_m5, (Unit@ _) { Not(Gt(Neg(7), Neg(5))); }),

  T(Str|Ge_4_2, (Unit@ _) { Ge(4, 2); }),
  T(Str|Ge_4_3, (Unit@ _) { Ge(4, 3); }),
  T(Str|Ge_4_4, (Unit@ _) { Ge(4, 4); }),
  T(Str|Ge_4_5, (Unit@ _) { Not(Ge(4, 5)); }),
  T(Str|Ge_4_6, (Unit@ _) { Not(Ge(4, 6)); }),

  T(Str|Ge_5_3, (Unit@ _) { Ge(5, 3); }),
  T(Str|Ge_5_4, (Unit@ _) { Ge(5, 4); }),
  T(Str|Ge_5_5, (Unit@ _) { Ge(5, 5); }),
  T(Str|Ge_5_6, (Unit@ _) { Not(Ge(5, 6)); }),
  T(Str|Ge_5_7, (Unit@ _) { Not(Ge(5, 7)); }),

  T(Str|Ge_m5_0, (Unit@ _) { Not(Ge(Neg(5), 0)); }),
  T(Str|Ge_m5_1, (Unit@ _) { Not(Ge(Neg(5), 1)); }),

  TEq(Str|Incr_3, 4, (Unit@ _) { Incr(3); }),
  TEq(Str|Decr_3, 2, (Unit@ _) { Decr(3); }),
  TEq(Str|Add_2_3, 5, (Unit@ _) { Add(2, 3); }),
  TEq(Str|Add_3_m5, Neg(2), (Unit@ _) { Add(3, Neg(5)); }),
  TEq(Str|Sub_5_3, 2, (Unit@ _) { Sub(5, 3); }),
  TEq(Str|Sub_3_5, Neg(2), (Unit@ _) { Sub(3, 5); }),
  TEq(Str|Neg_m2, 2, (Unit@ _) { Neg(Neg(2)); }),
  TEq(Str|Neg_0, 0, (Unit@ _) { Neg(0); }),

  TEq(Str|Min_0_5, Int|0, (Unit@ _) { Min(0, 5); }),
  TEq(Str|Min_3_0, Int|0, (Unit@ _) { Min(3, 0); }),
  TEq(Str|Max_0_5, Int|5, (Unit@ _) { Max(0, 5); }),
  TEq(Str|Max_3_0, Int|3, (Unit@ _) { Max(3, 0); }),

  TEq(Str|Abs_0, Int|0, (Unit@ _) { Abs(0); }),
  TEq(Str|Abs_3, Int|3, (Unit@ _) { Abs(3); }),
  TEq(Str|Abs_m3, Int|3, (Unit@ _) { Abs(Neg(3)); }),

  TEq(Str|Mul_3_5, Int|15, (Unit@ _) { Mul(3, 5); }),
  TEq(Str|Mul_m3_5, Neg(Int|15), (Unit@ _) { Mul(Neg(3), 5); }),
  TEq(Str|Mul_3_m5, Neg(Int|15), (Unit@ _) { Mul(3, Neg(5)); }),
  TEq(Str|Mul_m3_m5, Int|15, (Unit@ _) { Mul(Neg(3), Neg(5)); }),
  TEq(Str|Mul_0_5, Int|0, (Unit@ _) { Mul(0, 5); }),
  TEq(Str|Mul_3_0, Int|0, (Unit@ _) { Mul(3, 0); }),

  TEq(Str|Mul2_3, Int|6, (Unit@ _) { Mul2(3); }),
  TEq(Str|Mul2_0, Int|0, (Unit@ _) { Mul2(0); }),
  TEq(Str|Mul2_m3, Neg(Int|6), (Unit@ _) { Mul2(Neg(3)); }),

  TEq(Str|DivQ_11_4, Int|2, (Unit@ _) { Div(Int|11, Int|4).q; }),
  TEq(Str|DivR_11_4, Int|3, (Unit@ _) { Div(Int|11, Int|4).r; }),
  TEq(Str|DivQ_m11_4, Neg(Int|3), (Unit@ _) { Div(Neg(Int|11), Int|4).q; }),
  TEq(Str|DivR_m11_4, Int|1, (Unit@ _) { Div(Neg(Int|11), Int|4).r; }),
  TEq(Str|DivQ_11_m4, Neg(Int|3), (Unit@ _) { Div(Int|11, Neg(Int|4)).q; }),
  TEq(Str|DivR_11_m4, Neg(Int|1), (Unit@ _) { Div(Int|11, Neg(Int|4)).r; }),
  TEq(Str|DivQ_m11_m4, Int|2, (Unit@ _) { Div(Neg(Int|11), Neg(Int|4)).q; }),
  TEq(Str|DivR_m11_m4, Neg(Int|3), (Unit@ _) { Div(Neg(Int|11), Neg(Int|4)).r; }),

  TEq(Str|Quot_11_4, Int|2, (Unit@ _) { Quot(Int|11, Int|4); }),
  TEq(Str|Quot_m11_4, Neg(Int|3), (Unit@ _) { Quot(Neg(Int|11), Int|4); }),
  TEq(Str|Quot_11_m4, Neg(Int|3), (Unit@ _) { Quot(Int|11, Neg(Int|4)); }),
  TEq(Str|Quot_m11_m4, Int|2, (Unit@ _) { Quot(Neg(Int|11), Neg(Int|4)); }),

  TEq(Str|Mod_11_4, Int|3, (Unit@ _) { Mod(Int|11, Int|4); }),
  TEq(Str|Mod_m11_4, Int|1, (Unit@ _) { Mod(Neg(Int|11), Int|4); }),
  TEq(Str|Mod_11_m4, Neg(Int|1), (Unit@ _) { Mod(Int|11, Neg(Int|4)); }),
  TEq(Str|Mod_m11_m4, Neg(Int|3), (Unit@ _) { Mod(Neg(Int|11), Neg(Int|4)); }),

  TEq(Str|Sqrt_0_q, Int|0, (Unit@ _) { Sqrt(Int|0).q; }),
  TEq(Str|Sqrt_0_r, Int|0, (Unit@ _) { Sqrt(Int|0).r; }),
  TEq(Str|Sqrt_29_q, Int|5, (Unit@ _) { Sqrt(Int|29).q; }),
  TEq(Str|Sqrt_29_r, Int|4, (Unit@ _) { Sqrt(Int|29).r; }),
  TEq(Str|Sqrt_12345_q, Int|111, (Unit@ _) { Sqrt(Int|12345).q; }),
  TEq(Str|Sqrt_12345_r, Int|24, (Unit@ _) { Sqrt(Int|12345).r; }),

  TEq(Str|Exp2_0, Int|1, (Unit@ _) { Exp2(0); }),
  TEq(Str|Exp2_8, Int|256, (Unit@ _) { Exp2(8); }),
  TEq(Str|Exp2_7, Int|128, (Unit@ _) { Exp2(7); }),

  TEq(Str|Exp_3_4, Int|81, (Unit@ _) { Exp(3, 4); }),
  TEq(Str|Exp_0_0, Int|1, (Unit@ _) { Exp(0, 0); }),

  TEq(Str|Shl_3_4, Int|48, (Unit@ _) { Shl(3, 4); }),
  TEq(Str|Shl_0_4, Int|0, (Unit@ _) { Shl(0, 4); }),
  TEq(Str|Shl_m3_4, Neg(Int|48), (Unit@ _) { Shl(Neg(3), 4); }),

  TEq(Str|Shr_48_4, Int|3, (Unit@ _) { Shr(Int|48, 4); }),
  TEq(Str|Shr_0_4, Int|0, (Unit@ _) { Shr(0, 4); }),
  TEq(Str|Shr_m48_4, Neg(Int|3), (Unit@ _) { Shr(Neg(Int|48), 4); }),

  TOrd(Str|Ord_3_5, Ord.Less, (Unit@ _) { IOrd(3, 5); }),
  TOrd(Str|Ord_5_3, Ord.Greater, (Unit@ _) { IOrd(5, 3); }),
  TOrd(Str|Ord_5_5, Ord.Equal, (Unit@ _) { IOrd(5, 5); }),
  TOrd(Str|Ord_0_5, Ord.Less, (Unit@ _) { IOrd(0, 5); }),
  TOrd(Str|Ord_5_0, Ord.Greater, (Unit@ _) { IOrd(5, 0); }),
  TOrd(Str|Ord_0_0, Ord.Equal, (Unit@ _) { IOrd(0, 0); }),
  TOrd(Str|Ord_3_m5, Ord.Greater, (Unit@ _) { IOrd(3, Neg(5)); }),
  TOrd(Str|Ord_m5_3, Ord.Less, (Unit@ _) { IOrd(Neg(5), 3); }),
  TOrd(Str|Ord_m5_m5, Ord.Equal, (Unit@ _) { IOrd(Neg(5), Neg(5)); }),
  TOrd(Str|Ord_0_m5, Ord.Greater, (Unit@ _) { IOrd(0, Neg(5)); }),
  TOrd(Str|Ord_m5_0, Ord.Less, (Unit@ _) { IOrd(Neg(5), 0); }),

  /Core/Int/Show/Tests%.Tests,
  /Core/Int/Map/Tests%.Tests
]);

@(Tests);
