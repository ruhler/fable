
Bool@, True, False .= /Std/Bool%;
OnAscii .= /Std/Char/Ascii%;
AssertEquals .= /Std/Eq/Assert%;
Int@ .= /Std/Int%;
Int .= /Std/Int/Lit%;
Lazy .= /Std/Lazy%;
List .= /Std/List%;
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

Game@, Game, Solved, Toggle, ToggleSelected, ToggleDismissed .= /SatGame/Game%;
Generate = /SatGame/Generate%;
Params@, Puzzle@ .= /SatGame/Puzzle%;
Var .= /SatGame/Var/Lit%;


Puzzle@ puzzle = List[
  List[
    @(var: Var|0, pos: True),
    @(var: Var|1, pos: False),
    @(var: Var|2, pos: True)],
  List[
    @(var: Var|2, pos: True),
    @(var: Var|0, pos: False),
    @(var: Var|1, pos: True)]];

Test@ Tests = TestSuite|SatGame[
  Test|'Generate.Length'({
    Unit@ _ := Lazy;
    Params@ params = @(
      num_vars: Int|6,
      num_clauses: Int|6,
      num_literals_per_clause: Int|3
    );
    Int@ seed = Int|0;
    Puzzle@ puzzle = Generate(params, seed);
    AssertEquals(/Std/Int/Eq%.Eq, /Std/Int/Show%.Show,
      Int|6, /Std/List/Index%.Length(puzzle));
  }),

  Test|'Game.Unsolved'({
    Unit@ _ := Lazy;
    Game@ game = Game(puzzle);
    Bool@ solved = Solved(game);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, False, solved);
  }),

  Test|'Game.Solved'({
    Unit@ _ := Lazy;
    Game@ start = Game(puzzle);
    Game@ finish = Toggle(
      ToggleDismissed, Int|0, Int|0, Toggle(
      ToggleDismissed, Int|0, Int|1, Toggle(
      ToggleSelected, Int|0, Int|2, Toggle(
      ToggleSelected, Int|1, Int|0, Toggle(
      ToggleDismissed, Int|1, Int|1, Toggle(
      ToggleDismissed, Int|1, Int|2, start))))));

    Bool@ solved = Solved(finish);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, True, solved);
  }),

  Test|'Game.Incomplete'({
    Unit@ _ := Lazy;
    Game@ start = Game(puzzle);
    Game@ finish = Toggle(
      ToggleDismissed, Int|0, Int|0, Toggle(
      ToggleSelected, Int|0, Int|2, Toggle(
      ToggleSelected, Int|1, Int|0, Toggle(
      ToggleDismissed, Int|1, Int|1, Toggle(
      ToggleDismissed, Int|1, Int|2, start)))));

    Bool@ solved = Solved(finish);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, False, solved);
  }),

  Test|'Game.Incorrect'({
    Unit@ _ := Lazy;
    Game@ start = Game(puzzle);
    Game@ finish = Toggle(
      ToggleDismissed, Int|0, Int|0, Toggle(
      ToggleSelected, Int|0, Int|1, Toggle(
      ToggleDismissed, Int|0, Int|2, Toggle(
      ToggleDismissed, Int|1, Int|0, Toggle(
      ToggleDismissed, Int|1, Int|1, Toggle(
      ToggleSelected, Int|1, Int|2, start))))));

    Bool@ solved = Solved(finish);
    AssertEquals(/Std/Bool/Eq%.Eq, /Std/Bool/Show%.Show, False, solved);
  })
];

/Std/Test/Cli%.Run(Tests);
