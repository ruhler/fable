
Char@ .= /Std/Char%;
Io@ .= /Std/Io%;
Main@ .= /Std/Io/Cli%;
List@ .= /Std/List%;
Maybe@ .= /Std/Maybe%;
Monad@ .= /Std/Monad%;
String@ .= /Std/String%;
In@ .= /Std/Stream/In%;
Out@ .= /Std/Stream/Out%;

Main@ Main = <<@>@ M@>(Monad@<M@> m, Io@<M@> io, List@<String@> args) {
  In@<Char@, M@> in := m.do(/Std/Io/File/Utf8%.Stdin(m, io));
  Out@<Char@, M@> out := m.do(/Std/Io/File/Utf8%.Stdout(m, io));
  Out@<Char@, M@> err := m.do(/Std/Io/File/Utf8%.Stderr(m, io));
  (String@) { M@<Maybe@<In@<Char@, M@>>>; } read = /Std/Io/File/Utf8%.Read(m, io);
  /Fbld/Main%.Main(m, @(in, out, err, read), args);
};

Main;

