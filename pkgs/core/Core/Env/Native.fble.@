
@ Env@ = /Core/Env%.Env@;
<<@>@>@ Monad@ = /Std/Monad%.Monad@;
<<@>@>@ Native@ = /Core/Native%.Native@;

# Reads and returns all the environment variables from the native side.
# Note: This requires nobody is concurrently modifying environment variables.
# There's no real way to enforce that, but that's what everyone assumes in
# practice anytime they read environment variables, so... hope you're lucky?
#
# No mechanism is provided to set environment variables because it leaks
# memory and isn't thread safe.
#
# The intent of this API is to allow you to read the environment passed into
# your program once at startup. It is not intended to be able to observe side
# effects from modifications to the environment after the program has started.
<<@>@ M@>(Native@<M@>, Monad@<M@>) { M@<Env@>; } GetEnv;

@(GetEnv);
