
And, Not .= /Std/Bool%;
AssertEquals .= /Std/Eq/Assert%;
Str .= /Std/Char/Ascii%;
List@, List, Items .= /Std/List%;
Maybe@, Just, Nothing .= /Std/Maybe%;
Format .= /Std/Char/Ascii/Stream%;
TestSuite .= /Std/Test%;
Unit@ .= /Std/Unit%;

Key@, Value@, Map, Key, A, B, C, Value, X, Y .= /Core/Map/Tests/Map%;
Map@, Put, Get, Empty, Remove, Replace, ForEach .= Map;

Tests = TestSuite(Str|'Map')[
  /Std/Test%.Test(Str|'empty', (Unit@ _) {
    Maybe@<Value@> wnt = Nothing<Value@>;
    Maybe@<Value@> got = Get(Empty, B);
    AssertEquals(
      /Std/Maybe/Eq%.Eq(Value.Eq),
      /Std/Maybe/Show%.Show(Value.Show),
      wnt, got);
  }),

  /Std/Test%.Test(Str|'not found', (Unit@ _) {
    Map@ map = Put(Empty, C, X);
    Maybe@<Value@> wnt = Nothing<Value@>;
    Maybe@<Value@> got = Get(map, B);
    AssertEquals(
      /Std/Maybe/Eq%.Eq(Value.Eq),
      /Std/Maybe/Show%.Show(Value.Show),
      wnt, got);
  }),

  /Std/Test%.Test(Str|'found', (Unit@ _) {
    Map@ map = Put(Put(Put(Empty, A, Y), B, X), C, Y);
    Maybe@<Value@> wnt = Just(X);
    Maybe@<Value@> got = Get(map, B);
    AssertEquals(
      /Std/Maybe/Eq%.Eq(Value.Eq),
      /Std/Maybe/Show%.Show(Value.Show),
      wnt, got);
  }),

  /Std/Test%.Test(Str|'replace', (Unit@ _) {
    Map@ map = Put(Put(Empty, B, Y), B, X);
    Maybe@<Value@> wnt = Just(X);
    Maybe@<Value@> got = Get(map, B);
    AssertEquals(
      /Std/Maybe/Eq%.Eq(Value.Eq),
      /Std/Maybe/Show%.Show(Value.Show),
      wnt, got);
  }),

  /Std/Test%.Test(Str|'delete', (Unit@ _) {
    Map@ map = Remove(Put(Empty, B, Y), B);
    Maybe@<Value@> wnt = Nothing<Value@>;
    Maybe@<Value@> got = Get(map, B);
    AssertEquals(
      /Std/Maybe/Eq%.Eq(Value.Eq),
      /Std/Maybe/Show%.Show(Value.Show),
      wnt, got);
  }),

  /Std/Test%.Test(Str|'delete nothing', (Unit@ _) {
    Map@ map = Remove(Put(Empty, B, Y), A);
    Maybe@<Value@> wnt = Just(Y);
    Maybe@<Value@> got = Get(map, B);
    AssertEquals(
      /Std/Maybe/Eq%.Eq(Value.Eq),
      /Std/Maybe/Show%.Show(Value.Show),
      wnt, got);
  }),

  /Std/Test%.Test(Str|'replace update', (Unit@ _) {
    Map@ map = {
      Value@ x := Replace(Put(Empty, B, Y), B);
      Just(Not(x));
    };
    Maybe@<Value@> wnt = Just(X);
    Maybe@<Value@> got = Get(map, B);
    AssertEquals(
      /Std/Maybe/Eq%.Eq(Value.Eq),
      /Std/Maybe/Show%.Show(Value.Show),
      wnt, got);
  }),

  /Std/Test%.Test(Str|'replace absent', (Unit@ _) {
    Map@ map = {
      Value@ x := Replace(Put(Empty, B, Y), A);
      Just(Not(x));
    };
    Maybe@<Value@> wnt = Just(Y);
    Maybe@<Value@> got = Get(map, B);
    AssertEquals(
      /Std/Maybe/Eq%.Eq(Value.Eq),
      /Std/Maybe/Show%.Show(Value.Show),
      wnt, got);
  }),

  /Std/Test%.Test(Str|'replace remove', (Unit@ _) {
    Map@ map = {
      Value@ _ := Replace(Put(Empty, B, Y), B);
      Nothing<Value@>;
    };
    Maybe@<Value@> wnt = Nothing<Value@>;
    Maybe@<Value@> got = Get(map, B);
    AssertEquals(
      /Std/Maybe/Eq%.Eq(Value.Eq),
      /Std/Maybe/Show%.Show(Value.Show),
      wnt, got);
  }),

  /Std/Test%.Test(Str|'foreach', (Unit@ _) {
    Map@ map = Put(Put(Put(Empty, B, X), A, X), B, Y);

    # Note: A < B, we expect the ForEach to iterate in the order A, B. Because
    # we add A to the end of the list before B, we expect the resulting list
    # to be in the order B, A.
    Entry@ = *(Key@ key, Value@ value);
    List@<Entry@> wnt = List[Entry@(B, Y), Entry@(A, X)];
    List@<Entry@> got = ForEach(map, /Std/List%.Empty<Entry@>,
      (Key@ k, Value@ v, List@<Entry@> l) {
        Items(Entry@(k, v), l);
      });
    AssertEquals(
      /Std/List/Eq%.Eq((Entry@ A, Entry@ B) {
        And(Key.Eq(A.key, B.key), Value.Eq(A.value, B.value));
      }),
      /Std/List/Show%.Show((Entry@ e) {
        Format|'%s: %s'[Key.Show(e.key), Value.Show(e.value)];
      }),
      wnt, got);
  }),

  /Core/Map/Eq/Tests%.Tests
];

@(Tests);
