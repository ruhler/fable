
Addr@ .= /Hwdg/Addr%;
Design@, Designs, Rule .= /Hwdg/Design%;
Build@, Return .= /Hwdg/Build%;

(Addr@, Addr@, Addr@, Addr@) { Build@<Design@>; }
Wire = (Addr@ in, Addr@ in_ready, Addr@ out, Addr@ out_ready) {
    Return(Designs[
        Rule[in, in_ready, out_ready]|010[out, out_ready, in_ready]|010, # 0 ==> 0
        Rule[in, in_ready, out_ready]|110[out, out_ready, in_ready]|110  # 1 ==> 1
    ]);
};

@(Wire);
