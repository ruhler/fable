
Bool@ = /Std/Bool%.Bool@;
Not = /Std/Bool%.Not;

Int@ = /Std/Int%.Int@;
IsZero = /Std/Int/Sign%.IsZero;
Int = /Std/Int/Lit%.Int;

Monad@ = /Std/Monad%.Monad@;
Rng@ = /Core/Random/Rng%.Rng@;

# Generates a random boolean.
<<@>@ M@>(Monad@<M@>, Rng@<M@>) { M@<Bool@>; }
Rand = <<@>@ M@>(Monad@<M@> m, Rng@<M@> rng) {
  Int@ x := m.do(rng.rand(Int|1));
  m.return $ Not(IsZero(x));
};

@(Rand);
