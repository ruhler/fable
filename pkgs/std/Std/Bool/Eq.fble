# @module[/Std/Bool/Eq%]
#  The Eq@ instance for Bool@.

Bool@, True .= /Std/Bool%;
Eq@ .= /Std/Eq%;

# @func[Eq] Check two booleans for equality.
#  @arg[Bool@][a] The first operand.
#  @arg[Bool@][b] The second operand.
#  @returns[Bool@] True if the operands are equal, false otherwise.
Eq@<Bool@> Eq = (Bool@ a, Bool@ b) {
  a.?(true: b);
  b.?(true: a);
  True;
};

@(Eq);
