
Data@ .= /Core/Data%;

Drawing@ = /App/Drawing%.Drawing@;
Color@ = /App/Drawing%.Color@;
Point@ = /App/Drawing%.Point@;

Bool@ = /Std/Bool%.Bool@;
True = /Std/Bool%.True;
False = /Std/Bool%.False;

Eq@ = /Std/Eq%.Eq@;

Int@ = /Std/Int%.Int@;
Add = /Std/Int%.Add;
Mul = /Std/Int%.Mul;
Eq = /Std/Int/Eq%.Eq;
Lt = /Std/Int/Cmp%.Lt;
Int = /Std/Int/Lit%.Int;
Range = /Std/Int/Stream%.Range;
Ord = /Std/Int/Cmp%.Cmp;

List@ = /Std/List%.List@;

Cmp@ = /Std/Cmp%.Cmp@;
Compared@ = /Std/Cmp%.Compared@;

Show@ = /Std/Show%.Show@;
Do, Put .= /Std/Stream%;

Format = /Std/Char/Ascii/Stream%.Format;

TestResult@ = /Std/Test%.TestResult@;
Unit@ .= /Std/Unit%;

(Point@, Point@) { Bool@; } EqPoint = (Point@ a, Point@ b) {
  Eq(a.x, b.x).?(false: False);
  Eq(a.y, b.y).?(false: False);
  True;
};

(Point@, Point@) { Bool@; } LtPoint = (Point@ a, Point@ b) {
  Lt(a.x, b.x).?(true: True);
  Lt(b.x, a.x).?(true: False);
  Lt(a.y, b.y);
};

Cmp@<Point@> OrdPoint = (Point@ a, Point@ b) {
  Compared@ r = Ord(a.x, b.x);
  r.?(equal: Ord(a.y, b.y), : r);
};

Data@<Point@> DataPoint = (Point@ a) {
  Unit@ _ := Do(Put(a.x));
  Put(a.y);
};

Show@<Point@> ShowPoint = (Point@ x) {
  Format|'(%s, %s)'[/Std/Int/Show%.Show(x.x), /Std/Int/Show%.Show(x.y)];
};

(Color@, Color@) { Bool@; } EqColor = (Color@ a, Color@ b) {
  Eq(a.r, b.r).?(false: False);
  Eq(a.g, b.g).?(false: False);
  Eq(a.b, b.b).?(false: False);
  True;
};

Show@<Color@> ShowColor = (Color@ c) {
  # TODO: Show color as hex string.
  Format|'(%s, %s, %s)'[
    /Std/Int/Show%.Show(c.r),
    /Std/Int/Show%.Show(c.g),
    /Std/Int/Show%.Show(c.b)];
};

Drawn@(.Map@), Empty, Insert .= /Core/Map/Data%.Map(DataPoint)<Color@>;
Eq@<Drawn@> EqDrawn = /Core/Map/Eq%.Eq(EqPoint, EqColor);
Show@<Drawn@> ShowDrawn = /Core/Map/Show%.Show(ShowPoint, ShowColor);

Pixel@ = *(Int@ x, Int@ y, Color@ color);

# Drawn --
#   Create a drawing by listing raw pixels.
(List@<Pixel@>) { Drawn@; } Drawn = (List@<Pixel@> pixels) {
  pixels.?(empty: Empty);

  Pixel@ head = pixels.items.head;
  Insert(Drawn(pixels.items.tail), Point@(head.x, head.y), head.color);
};

# Draw --
#   Render a drawing.
# 
# Inputs:
#   a, b - current affine transformation
#   drawing - the drawing to draw
#   drawn - the canvas that has been drawn so far.
(Point@, Point@, Drawing@, Drawn@) { Drawn@; }
Draw_ = {
  (Point@ a, Point@ b, Drawing@ drawing, Drawn@ drawn) {
    drawing.?(
      blank: drawn,
      triangle: /Std/Undef%.Undef.undef<Drawn@>,  # TODO
      rect: {
        Int@ x = Add(Mul(a.x, drawing.rect.x), b.x);
        Int@ y = Add(Mul(a.y, drawing.rect.y), b.y);
        Int@ w = Mul(a.x, drawing.rect.w);
        Int@ h = Mul(a.y, drawing.rect.h);

        Int@ xmin = Lt(w, Int|0).?(true: Add(x, w), false: x);
        Int@ xmax = Lt(w, Int|0).?(true: x, false: Add(x, w));
        Int@ ymin = Lt(h, Int|0).?(true: Add(y, h), false: y);
        Int@ ymax = Lt(h, Int|0).?(true: y, false: Add(y, h));

        /Std/Stream%.ForEach(Range(xmin, xmax), drawn, (Int@ x, Drawn@ d) {
          /Std/Stream%.ForEach(Range(ymin, ymax), d, (Int@ y, Drawn@ d) {
            Insert(d, Point@(x, y), drawing.rect.color);
          });
        });
      },
      transformed: {
        Int@ axi = drawing.transformed.a.x;
        Int@ ayi = drawing.transformed.a.y;
        Int@ bxi = drawing.transformed.b.x;
        Int@ byi = drawing.transformed.b.y;

        Point@ a_ = @(x: Mul(a.x, axi), y: Mul(a.y, ayi));
        Point@ b_ = @(x: Add(Mul(a.x, bxi), b.x), y: Add(Mul(a.y, byi), b.y));
        Draw_(a_, b_, drawing.transformed.drawing, drawn);
      },
      over: {
        Draw_(a, b, drawing.over.above, Draw_(a, b, drawing.over.below, drawn));
      });
  };
};

(Drawing@) { Drawn@; } Draw = (Drawing@ d) {
  Draw_(Point@(Int|1, Int|1), Point@(Int|0, Int|0), d, Empty);
};

(Drawn@, Drawn@) { TestResult@; }
AssertEquals = (Drawn@ expected, Drawn@ actual) {
  /Std/Eq/Assert%.AssertEquals(EqDrawn, ShowDrawn, expected, actual);
};

@(Drawn@, Pixel@,
  Draw, Drawn, ShowColor, EqColor, LtPoint, OrdPoint, DataPoint, AssertEquals);

