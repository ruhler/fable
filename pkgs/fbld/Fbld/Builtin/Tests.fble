
OnAscii, Str .= /Std/Char/Ascii%;
String .= /Std/Char/Ascii/Stream%;
AssertEquals .= /Std/Eq/Assert%;
Int .= /Std/Int/Lit%;
Lazy .= /Std/Lazy%;
List@, List .= /Std/List%;
String@ .= /Std/String%;
Lines .= /Std/String/Lines%;
Test@ .= /Std/Test%;
Test = OnAscii(/Std/Test%.Test);
TestSuite = OnAscii(/Std/Test%.TestSuite);
Unit@ .= /Std/Unit%;

Loc@, Start .= /Fbld/Loc%;
Markup@, ToString .= /Fbld/Markup%;
Result@, Ok, Error, r(.Monad) .= /Fbld/Result%;
ShowErrors .= /Fbld/Result/Show%;
Text .= /Fbld/Text%;

(List@<String@>) { Result@<String@>; } Run = (List@<String@> lines) {
  String@ text = Lines(lines);
  Markup@ parsed := r.do(/Fbld/Parse%.Parse(List[Text(Start(Str|'foo.fbld'), text)]));
  Markup@ evaled := r.do(/Fbld/Eval%.Eval(/Fbld/Builtin%.Env, parsed));
  ToString(evaled);
};

Test@ Tests = TestSuite|Builtin[
  Test|Define({
    Unit@ _ := Lazy;

    Result@<String@> got = Run[
      Str|'@define[foo][a b] a: @a, b: @b @@',
      Str|'@foo[hello][there]'
    ];
    Result@<String@> wnt = Ok(Str|'a: hello, b: there');
    AssertEquals(
      /Fbld/Result/Eq%.Eq(/Std/String/Eq%.Eq),
      /Fbld/Result/Show%.Show(/Std/String/Show%.Show), wnt, got);
  }),

  Test|DefineArgEval({
    Unit@ _ := Lazy;

    Result@<String@> got = Run[
      Str|'@define[a][] AAAA @@',
      Str|'@define[c][] CCCC @@',
      Str|'@define[foo][a b] @a,@b,@c @@',
      Str|'@foo[hello][@a]'
    ];
    Result@<String@> wnt = Ok(Str|'hello,AAAA,CCCC');
    AssertEquals(
      /Fbld/Result/Eq%.Eq(/Std/String/Eq%.Eq),
      /Fbld/Result/Show%.Show(/Std/String/Show%.Show), wnt, got);
  }),

  Test|DefineSameArgEval({
    Unit@ _ := Lazy;

    Result@<String@> got = Run[
      Str|'@define[a][] AAAA @@',
      Str|'@define[a][a] @a @@',
      Str|'@a[hello]'
    ];
    Result@<String@> wnt = Ok(Str|'hello');
    AssertEquals(
      /Fbld/Result/Eq%.Eq(/Std/String/Eq%.Eq),
      /Fbld/Result/Show%.Show(/Std/String/Show%.Show), wnt, got);
  }),

  Test|Let({
    Unit@ _ := Lazy;

    Result@<String@> got = Run[
      Str|'@let[x] a @@',
      Str|'@let[y] @x@x @@',
      Str|'@let[z] @y@y @@',
      Str|'@z'
    ];
    Result@<String@> wnt = Ok(Str|'aaaa');
    AssertEquals(
      /Fbld/Result/Eq%.Eq(/Std/String/Eq%.Eq),
      /Fbld/Result/Show%.Show(/Std/String/Show%.Show), wnt, got);
  }),

  Test|IfEq({
    Unit@ _ := Lazy;

    Result@<String@> got = Run[
      Str|'@ifeq[foo][bar][hello][there]',
      Str|'@ifeq[foo][foo][whats][up]'
    ];
    Result@<String@> wnt = Ok(Str|'therewhats');
    AssertEquals(
      /Fbld/Result/Eq%.Eq(/Std/String/Eq%.Eq),
      /Fbld/Result/Show%.Show(/Std/String/Show%.Show), wnt, got);
  }),

  Test|IfNEq({
    Unit@ _ := Lazy;

    Result@<String@> got = Run[
      Str|'@ifneq[foo][bar][hello][there]',
      Str|'@ifneq[foo][foo][whats][up]'
    ];
    Result@<String@> wnt = Ok(Str|'helloup');
    AssertEquals(
      /Fbld/Result/Eq%.Eq(/Std/String/Eq%.Eq),
      /Fbld/Result/Show%.Show(/Std/String/Show%.Show), wnt, got);
  }),

  Test|DefineRecursive({
    Unit@ _ := Lazy;

    Result@<String@> got = Run[
      Str|'@define[foo][x]',
      Str|' @ifeq[@x][a][done][@foo[a]]',
      Str|'@@',
      Str|'@foo[hello]'
    ];
    Result@<String@> wnt = Ok(Str|'done');
    AssertEquals(
      /Fbld/Result/Eq%.Eq(/Std/String/Eq%.Eq),
      /Fbld/Result/Show%.Show(/Std/String/Show%.Show), wnt, got);
  }),

  Test|Head({
    Unit@ _ := Lazy;

    Result@<String@> got = Run[
      Str|'@head[foo]'
    ];
    Result@<String@> wnt = Ok(Str|'f');
    AssertEquals(
      /Fbld/Result/Eq%.Eq(/Std/String/Eq%.Eq),
      /Fbld/Result/Show%.Show(/Std/String/Show%.Show), wnt, got);
  }),

  Test|Tail({
    Unit@ _ := Lazy;

    Result@<String@> got = Run[
      Str|'@tail[foo]'
    ];
    Result@<String@> wnt = Ok(Str|'oo');
    AssertEquals(
      /Fbld/Result/Eq%.Eq(/Std/String/Eq%.Eq),
      /Fbld/Result/Show%.Show(/Std/String/Show%.Show), wnt, got);
  }),

  Test|Eval({
    Unit@ _ := Lazy;

    Result@<String@> got = Run[
      Str|'@define[foo][x]',
      Str|' @define[cmd][y] hi @y @@',
      Str|' @eval[@x]',
      Str|' @define[cmd][y] bye @y @@',
      Str|' @eval[@x]',
      Str|'@@',
      Str|'@foo[a@cmd[b]c]'
    ];
    Result@<String@> wnt = Ok(Str|'ahi bcabye bc');
    AssertEquals(
      /Fbld/Result/Eq%.Eq(/Std/String/Eq%.Eq),
      /Fbld/Result/Show%.Show(/Std/String/Show%.Show), wnt, got);
  }),

  Test|Plain({
    Unit@ _ := Lazy;

    Result@<String@> got = Run[
      Str|'@define[foo][x]',
      Str|' @define[keep][y] @y @@',
      Str|' @eval[@x]',
      Str|'@@',
      Str|'@define[ignore][x][] @@',
      Str|'@foo[@plain[ignore][a@keep[b]c@keep[d]e]]'
    ];
    Result@<String@> wnt = Ok(Str|'bd');
    AssertEquals(
      /Fbld/Result/Eq%.Eq(/Std/String/Eq%.Eq),
      /Fbld/Result/Show%.Show(/Std/String/Show%.Show), wnt, got);
  }),

  Test|PlainEvalArg({
    Unit@ _ := Lazy;

    Result@<String@> got = Run[
      Str|'@define[foo][x]',
      Str|' @define[keep][y] @y @@',
      Str|' @eval[@x]',
      Str|'@@',
      Str|'@define[ignore][x][] @@',
      Str|'@define[arg][][a@keep[b]c@keep[d]e] @@',
      Str|'@foo[@plain[ignore][@arg]]'
    ];
    Result@<String@> wnt = Ok(Str|'bd');
    AssertEquals(
      /Fbld/Result/Eq%.Eq(/Std/String/Eq%.Eq),
      /Fbld/Result/Show%.Show(/Std/String/Show%.Show), wnt, got);
  }),

  Test|Error({
    Unit@ _ := Lazy;

    Result@<String@> got = Run[
      Str|'@error[Oh no!]'
    ];
    Result@<String@> wnt = Error<String@>(
      Loc@(Str|'foo.fbld', Int|1, Int|2),
      String|'Oh no!'
    );
    AssertEquals(
      /Fbld/Result/Eq%.Eq(/Std/String/Eq%.Eq),
      /Fbld/Result/Show%.Show(/Std/String/Show%.Show), wnt, got);
  }),

  Test|MultiError({
    Unit@ _ := Lazy;

    String@ got = /Std/Stream/String%.ToString(ShowErrors(Run[
      Str|'@error[Oh no!]',
      Str|'@error[Not good.]'
    ]));

    String@ wnt = Lines[
      Str|'foo.fbld:1:2: error: Oh no!',
      Str|'foo.fbld:2:2: error: Not good.'];
    AssertEquals(/Std/String/Eq%.Eq, /Std/String/Show%.Show, wnt, got);
  })
];

@(Tests);
