
Data@, Bit@, 0, 1 .= /Std/Data%;
Int@ .= /Std/Int%;

Data@<Int@>
Data = (Int@ x)<@ S@>(S@ return, (Bit@, S@) { S@; } put) {
  x.?(
    n: put(0, put(0, /Core/Int/IntP/Data%.Data(x.n, return, put))),
    0: put(0, put(1, return)),
    p: put(1, /Core/Int/IntP/Data%.Data(x.p, return, put)));
};

@(Data);

