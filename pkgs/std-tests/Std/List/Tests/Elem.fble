# @module[/Std/List/Tests/Elem%]
#  Element type for use in list tests.

Bool@ = /Std/Bool%.Bool@;
True = /Std/Bool%.True;
False = /Std/Bool%.False;

Cmp@ = /Std/Cmp%.Cmp@;
Less = /Std/Cmp%.Less;
Equal = /Std/Cmp%.Equal;
Greater = /Std/Cmp%.Greater;

Eq@ = /Std/Eq%.Eq@;

List@ = /Std/List%.List@;
List = /Std/List%.List;

Show@ = /Std/Show%.Show@;

String = /Std/Char/Ascii/Output%.String;

Unit@ = /Std/Unit%.Unit@;
Unit = /Std/Unit%.Unit;


Elem@ = +(Unit@ A, Unit@ B, Unit@ C, Unit@ D, Unit@ E);

Elem = @(
  A: Elem@(A: Unit),
  B: Elem@(B: Unit),
  C: Elem@(C: Unit),
  D: Elem@(D: Unit),
  E: Elem@(E: Unit));

(List@<Elem@>) { List@<Elem@>; } Elems = List<Elem@>;

Show@<Elem@> Show = (Elem@ e) {
  e.?(A: String|A, B: String|B, C: String|C, D: String|D, E: String|E);
};

Cmp@<Elem@> Cmp = (Elem@ a, Elem@ b) {
  a.?(A: b.?(A: Equal, : Less),
      B: b.?(A: Greater, B: Equal, : Less),
      C: b.?(A: Greater, B: Greater, C: Equal, : Less),
      D: b.?(A: Greater, B: Greater, C: Greater, D: Equal, E: Less),
      E: b.?(A: Greater, B: Greater, C: Greater, D: Greater, E: Equal));
};

(Elem@, Elem@) { Bool@; } Le = (Elem@ a, Elem@ b) {
  a.?(A: True,
      B: b.?(A: False, : True),
      C: b.?(A: False, B: False, : True),
      D: b.?(A: False, B: False, C: False, : True),
      E: b.?(A: False, B: False, C: False, D: False, E: True));
};

(Elem@, Elem@) { Bool@; } Ge = (Elem@ a, Elem@ b) {
  Le(b, a);
};

Eq@<Elem@> Eq = (Elem@ a, Elem@ b) {
  a.?(A: b.?(A: True, : False),
      B: b.?(B: True, : False),
      C: b.?(C: True, : False),
      D: b.?(D: True, : False),
      E: b.?(E: True, : False));
};

Eq@<List@<Elem@>> Eqs = /Std/List/Eq%.Eq(Eq);
Show@<List@<Elem@>> Shows = /Std/List/Show%.Show(Show);

@(Elem@, Elem, Elems, Show, Cmp, Le, Ge, Eq, Eqs, Shows);
