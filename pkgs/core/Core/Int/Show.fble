
@ Char@ = /Core/Char%.Char@;

@ Int@ = /Std/Int%.Int@;
% Add = /Std/Int%.Add;
% Neg = /Std/Int%.Neg;
% Mul = /Std/Int%.Mul;
% Int = /Core/Int/Lit%.Int;

<@>% Append = /Std/List%.Append;

<@>@ Show@ = /Core/Show%.Show@;

@ String@ = /Core/String%.String@;
% Str = /Core/String%.Str;

(String@) { Int@; } Read = {
  (Char@) { Int@; } Digit = (Char@ c) {
    c.?(
      '0': Int|0, '1': Int|1, '2': Int|2, '3': Int|3, '4': Int|4,
      '5': Int|5, '6': Int|6, '7': Int|7, '8': Int|8, '9': Int|9,
      : Int|0);
  };

  (Int@, String@) { Int@; } ReadP = (Int@ x, String@ s) {
    s.?(empty: x);
    ReadP(Add(Mul(Int|10, x), Digit(s.items.head)), s.items.tail);
  };
  
  (String@ s) {
    s.?(empty: Int|0);
    s.items.head.?('-': Neg(ReadP(Int|0, s.items.tail)), : ReadP(Int|0, s));
  };
};

Show@<Int@> Show = (Int@ x) {
  x.?(
    n: Append(Str|'-', /Core/Int/IntP/Show%.Show(x.n)),
    0: Str|0,
    p: /Core/Int/IntP/Show%.Show(x.p));
};

@(Read, Show);
