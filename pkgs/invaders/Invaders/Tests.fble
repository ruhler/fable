
<@>% List = /Std/List%.List;

% Str = /Std/Char/Ascii%.Str;

@ Test@ = /Std/Test%.Test@;
% TestSuite = /Std/Test%.TestSuite;

# Import to test compilation.
% _ = /Invaders/AppIO%;
% _ = /Invaders/Bench%;
% _ = /Invaders/Screenshot/AppIO%;

Test@ Tests = TestSuite(Str|Invaders, List<Test@>[]);

/Core/Stdio/IO%.Run(/Core/Test/Stdio%.Run(Tests));
