# @module[/Std/Test%]
#  Unit test framework.

Bool@ .= /Std/Bool%;
Char@ .= /Std/Char%;
String, Format .= /Std/Char/Ascii/Stream%;
Lazy@ .= /Std/Lazy%;
List@ .= /Std/List%;
Stream@ .= /Std/Stream%;
ToString .= /Std/Stream/String%;
String@ .= /Std/String%;
Unit@, Unit .= /Std/Unit%;

# @union[TestResult@] The result of running a test.
#  @field[Unit@][pass] The test passed.
#  @field[Stream@<Char@>][fail] The test failed with given error message.
#  @field[Unit@][expected_fail] The test was expected to fail and it did.
#  @field[Stream@<Char@>][skip] The test was skipped, with explanation as to why.
TestResult@ = +(Unit@ pass, Stream@<Char@> fail, Unit@ expected_fail, Stream@<Char@> skip);

# @struct[TestCase@] A test case.
#  @field[String@][name] The name of the test.
#  @field[Lazy@<TestResult@>][test] The test code to run.
TestCase@ = *(String@ name, Lazy@<TestResult@> test);

# @struct[TestSuite@] A test suite.
#  @field[String@][name] The name of the test suite.
#  @field[List@<Test@>][tests] The tests in the test suite.
TestSuite@ = *(String@ name, List@<Test@> tests),

# @union[Test@] A test.
#  @field[TestCase@][case] An individual test case.
#  @field[TestSuite@][suite] A suite of tests.
Test@ = +(TestCase@ case, TestSuite@ suite);

# @value[Pass] A passing test result.
#  @type[TestResult@];
TestResult@ Pass = TestResult@(pass: Unit);

# @func[Fail] A failing test result.
#  @arg[Stream@<Char@>][msg] Test failure message.
#  @returns[TestResult@] A failing test result.
(Stream@<Char@>) { TestResult@; } Fail = (Stream@<Char@> msg) {
  TestResult@(fail: msg);
};

# @func[ExpectFails] Check a test result for an expected failure.
#  Changes the test result to expected failure if the given test result is
#  failing and msg is contained somewhere in the failure message.
#
#  The test result is passed lazily for convenience assuming the test result
#  is being computed in a statement context. That way function bind syntax can
#  be used to apply the expected failure to an existing test result
#  computation without modifying the computation itself. For example:
#
#  @code[fble] @
#   Unit@ _ := ExpectFails|', but got Ball@(pos=(257/128, 262/128), vel=(2/128, 254/128)';
#   AssertEquals(/Pinball/Ball%.Eq, /Pinball/Ball%.Show, want, got);
#
#  @arg[String@][msg] Substring expected to be found in the error message.
#  @arg[Lazy@<TestResult@>][result] The result that is expected to be failing.
#  @returns[TestResult@] The result of checking for the expected failure.
(String@, Lazy@<TestResult@>) { TestResult@; }
ExpectFails = (String@ msg, Lazy@<TestResult@> result) {
  TestResult@ r = /Std/Lazy%.Run(result);
  r.?(pass: Fail(String|'Expected failure, but test passed'));
  r.?(expected_fail: Fail(String|'Expected failure, but was expected_fail'));
  r.?(skip: Fail(String|'Expected failure, but was skip'));

  String@ failure = ToString(r.fail);
  /Std/String/Eq%.Contains(failure, msg).?(true: TestResult@(expected_fail: Unit));

  Fail(Format|'Expected failure containing "%s", but failed with "%s"'
        [/Std/Stream/String%.String(msg), /Std/Stream/String%.String(failure)]);
};

# @func[Skip] A skipped test result.
#  @arg[Stream@<Char@>][msg] Explanation for why the test was skipped.
#  @returns[TestResult@] A skipped test result.
(Stream@<Char@>) { TestResult@; }
Skip = (Stream@<Char@> msg) {
  TestResult@(skip: msg);
};

# @func[Test] Creates an individual test.
#  @arg[String@][name] The name of the test.
#  @arg[Lazy@<TestResult@>][test]
#   A function that returns the result of the test.
#  @returns[Test@] The constructed test.
(String@, Lazy@<TestResult@>) { Test@; }
Test = (String@ name, Lazy@<TestResult@> test) {
  Test@(case: TestCase@(name, test));
};

# @func[TestSuite] Creates a suite of tests.
#  @arg[String@][name] The name of the test suite.
#  @arg[List@<Test@>][tests] The list of tests in the test suite.
#  @returns[Test@] The constructed test suite.
(String@, List@<Test@>) { Test@; }
TestSuite = (String@ name, List@<Test@> tests) {
  Test@(suite: TestSuite@(name, tests));
};

# @func[SkipTest] Skips a test or suite of tests.
#  @arg[Stream@<Char@>][msg] Explanation for why the test is skipped.
#  @arg[Test@][test] The test or test suite to skip.
#  @returns[Test@] A skipped test.
(Stream@<Char@>, Test@) { Test@; }
SkipTest = (Stream@<Char@> msg, Test@ test) {
  test.?(case: Test(test.case.name, (Unit@ _) { Skip(msg); }));
  TestSuite(test.suite.name, /Std/List%.Map(test.suite.tests, SkipTest(msg)));
};

# @func[SkipTestIf] Conditionally skips a test or test suite.
#  @arg[Bool@][if] Skip the test or test suite if this condition holds.
#  @arg[Stream@<Char@>][msg] Explanation for why the test is skipped.
#  @arg[Test@][test] The test to skip.
#  @returns[Test@] A skipped test.
(Bool@, Stream@<Char@>, Test@) { Test@; }
SkipTestIf = (Bool@ if, Stream@<Char@> msg) {
  if.?(true: SkipTest(msg), false: /Std/Func%.Id<Test@>);
};

# @func[SkipTestUnless] Conditionally skips a test or test suite.
#  @arg[Bool@][unless] Skip the test or test suite unless this condition holds.
#  @arg[Stream@<Char@>][msg] Explanation for why the test is skipped.
#  @arg[Test@][test] The test to skip.
#  @returns[Test@] A skipped test.
(Bool@, Stream@<Char@>, Test@) { Test@; }
SkipTestUnless = (Bool@ unless, Stream@<Char@> msg) {
  unless.?(true: /Std/Func%.Id<Test@>, false: SkipTest(msg));
};

@(TestResult@, Test@, TestSuite@, TestCase@,
  Pass, Fail, Skip,
  Test, TestSuite,
  ExpectFails,
  SkipTest, SkipTestIf, SkipTestUnless
);
