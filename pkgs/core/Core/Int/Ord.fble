
<@>@ Cmp@ = /Core/Ord%.Cmp@;
% Less = /Core/Ord%.Less;
% Equal = /Core/Ord%.Equal;
% Greater = /Core/Ord%.Greater;

% OrdP = /Core/Int/IntP/Ord%.Ord;

@ Int@ = /Std/Int%.Int@;

Cmp@<Int@> Ord = (Int@ a, Int@ b) {
  a.?(
      n: b.?(n: OrdP(b.n, a.n), 0: Less, p: Less),
      0: b.?(n: Greater, 0: Equal, p: Less),
      p: b.?(n: Greater, 0: Greater, p: OrdP(a.p, b.p)));
};

@(Ord);
